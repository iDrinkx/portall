<div class="login-page">
  <div class="login-logo">
    <img src="<%= basePath %>/logo.png" alt="MonPlex" />
  </div>

  <div class="login-card">
    <h1>Connectez-vous pour continuer</h1>
    <% if (typeof error !== "undefined" && error === "unauthorized") { %>
    <div class="login-error"><%= t("login.unauthorized", { serverName: plexServerName }) %></div>
    <% } %>
    <a class="plex-btn plex-btn--logo" href="<%= basePath %>/login" aria-label="<%= t("login.withPlex") %>">
      <span class="plex-btn-label"><%= locale === "en" ? "Sign in with" : "Se connecter avec" %></span>
      <img src="<%= basePath %>/img/plex-alt-light.svg" alt="Plex" class="plex-btn-logo" />
    </a>
  </div>
</div>

<style>
  .login-card h1 {
    font-size: 18px;
    margin-bottom: 20px;
  }

  .plex-btn--logo {
    min-width: 280px;
    min-height: 48px;
    gap: 4px;
    padding: 12px 24px;
    justify-content: center;
    color: #f4f1ec;
    background: #533f2b;
    border: 1px solid #a66822;
    box-shadow: none;
    filter: none;
  }

  .plex-btn-label {
    display: inline-flex;
    align-items: center;
    line-height: 1;
    font-size: 15px;
    font-weight: 700;
    color: #f4f1ec;
  }

  .plex-btn-logo {
    width: 36px;
    height: auto;
    display: block;
    flex-shrink: 0;
    transform: none;
  }

  .plex-btn--logo::before {
    display: none;
  }

  .plex-btn--logo:hover {
    background: #614a33;
    border-color: #bf7c2d;
    color: #fff7ef;
    transform: translateY(-1px);
  }

  @media (max-width: 640px) {
    .plex-btn--logo {
      width: min(100%, 320px);
      min-width: 0;
      display: grid;
      grid-template-columns: 1fr auto auto 1fr;
      align-items: center;
      column-gap: 8px;
      padding: 12px 18px;
      margin-inline: auto;
    }

    .plex-btn-label {
      grid-column: 2;
      justify-content: center;
      text-align: center;
      white-space: nowrap;
      font-size: 14px;
    }

    .plex-btn-logo {
      grid-column: 3;
      justify-self: start;
      width: 34px;
    }
  }
</style>
