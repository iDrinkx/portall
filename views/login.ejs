<%
  const statusData = uptimeKuma && uptimeKuma.enabled ? uptimeKuma : null;
  const overallStatusLabel = !statusData
    ? ""
    : (statusData.overall === "operational"
        ? t("login.status.allOperational")
        : t("login.status.someIssues"));

  function getServiceStateLabel(statusClassName) {
    if (statusClassName === "operational") return "En ligne";
    if (statusClassName === "pending") return "En attente";
    if (statusClassName === "maintenance") return "En maintenance";
    if (statusClassName === "down") return "Hors ligne";
    return "Indisponible";
  }

  function formatSince(isoDate) {
    if (!isoDate) return "";
    const timestamp = Date.parse(isoDate);
    if (Number.isNaN(timestamp)) return "";

    const diffMs = Math.max(0, Date.now() - timestamp);
    const totalMinutes = Math.floor(diffMs / 60000);

    if (totalMinutes < 1) return "Depuis moins d'une minute";
    if (totalMinutes < 60) return `Depuis ${totalMinutes} min`;

    const totalHours = Math.floor(totalMinutes / 60);
    if (totalHours < 24) {
      const remainingMinutes = totalMinutes % 60;
      return remainingMinutes > 0
        ? `Depuis ${totalHours} h ${remainingMinutes} min`
        : `Depuis ${totalHours} h`;
    }

    const totalDays = Math.floor(totalHours / 24);
    const remainingHours = totalHours % 24;
    return remainingHours > 0
      ? `Depuis ${totalDays} j ${remainingHours} h`
      : `Depuis ${totalDays} j`;
  }
%>

<div class="login-page<%= statusData ? " login-page--with-status" : "" %>">
  <div class="login-logo">
    <img src="<%= basePath %>/logo.png" alt="MonPlex" />
  </div>

  <div class="login-card">
    <h1>Connectez-vous pour continuer</h1>
    <% if (typeof error !== "undefined" && error === "unauthorized") { %>
    <div class="login-error"><%= t("login.unauthorized", { serverName: plexServerName }) %></div>
    <% } %>
    <a class="plex-btn plex-btn--logo" href="<%= basePath %>/login" aria-label="<%= t("login.withPlex") %>">
      <span class="plex-btn-label"><%= locale === "en" ? "Sign in with" : "Se connecter avec" %></span>
      <img src="<%= basePath %>/img/plex-alt-light.svg" alt="Plex" class="plex-btn-logo" />
    </a>
  </div>

  <% if (statusData) { %>
  <section class="login-status-panel" aria-labelledby="login-status-heading">
    <div class="login-status-summary login-status-summary--<%= statusData.overall === "operational" ? "operational" : "issues" %>">
      <span
        class="login-status-summary__icon login-status-summary__icon--<%= statusData.overall === "operational" ? "operational" : "issues" %>"
        aria-hidden="true"
      ><%- statusData.overall === "operational" ? "&#10003;" : "!" %></span>
      <div class="login-status-summary__text">
        <h2 id="login-status-heading"><%= overallStatusLabel %></h2>
        <% if (statusData.description) { %>
        <p><%= statusData.description %></p>
        <% } %>
      </div>
    </div>

    <div class="login-status-section">
      <div class="login-status-section__header">
        <h3><%= t("login.status.services") %></h3>
      </div>

      <% if (statusData.privateError) { %>
      <div class="login-status-error"><%= statusData.privateError %></div>
      <% } %>

      <div class="login-status-list">
        <% if (!statusData.services.length) { %>
        <article class="login-status-item login-status-item--empty">
          <div class="login-status-item__meta">
            <div class="login-status-item__headline">
              <strong>Uptime Kuma</strong>
              <span class="login-status-state login-status-state--unknown">
                <span class="login-status-state__dot" aria-hidden="true"></span>
                <span>Indisponible</span>
              </span>
            </div>
            <div class="login-status-item__tags">
              <span class="login-status-item__tag">Aucune donnee</span>
            </div>
          </div>
        </article>
        <% } %>

        <% statusData.services.forEach(service => { %>
        <article class="login-status-item">
          <div class="login-status-item__row">
            <div class="login-status-item__meta">
              <div class="login-status-item__headline">
                <strong><%= service.name %></strong>
              </div>
              <% if (service.tags && service.tags.length) { %>
              <div class="login-status-item__tags">
                <% service.tags.slice(0, 3).forEach(tag => { %>
                <span class="login-status-item__tag" style="background-color: <%= tag.color %>;"><%= tag.name %></span>
                <% }) %>
              </div>
              <% } %>
            </div>

            <div class="login-status-item__state-block">
              <span class="login-status-state login-status-state--<%= service.status.className %>">
                <span class="login-status-state__dot" aria-hidden="true"></span>
                <span><%= getServiceStateLabel(service.status.className) %></span>
              </span>
              <% if (service.statusChangedAt) { %>
              <div class="login-status-item__since"><%= formatSince(service.statusChangedAt) %></div>
              <% } %>
            </div>
          </div>
        </article>
        <% }) %>
      </div>
    </div>
  </section>
  <% } %>
</div>

<style>
  .login-card h1 {
    font-size: 18px;
    margin-bottom: 20px;
  }

  .plex-btn--logo {
    min-width: 280px;
    min-height: 48px;
    gap: 4px;
    padding: 12px 24px;
    color: #f4f1ec;
    background: #533f2b;
    border: 1px solid #a66822;
    box-shadow: none;
    filter: none;
  }

  .plex-btn-label {
    line-height: 1;
    font-size: 15px;
    font-weight: 700;
    color: #f4f1ec;
  }

  .plex-btn-logo {
    width: 36px;
    height: auto;
    display: block;
    transform: translateY(1px);
  }

  .plex-btn--logo::before {
    display: none;
  }

  .plex-btn--logo:hover {
    background: #a66822;
    border-color: #a66822;
    box-shadow: none;
    filter: none;
    transform: none;
  }

  .plex-btn--logo:active {
    transform: none;
  }

  @media (max-width: 768px) {
    .plex-btn--logo {
      width: 100%;
      min-width: 0;
      max-width: 100%;
      margin: 0 auto;
      padding-left: 16px;
      padding-right: 16px;
    }
  }
</style>
