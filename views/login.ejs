<div class="login-page">
  <div class="login-logo">
    <img src="<%= basePath %>/logo.png" alt="MonPlex" />
  </div>

  <div class="login-card">
    <h1><%= t("login.title") %></h1>
    <% if (typeof error !== 'undefined' && error === 'unauthorized') { %>
    <div class="login-error"><%= t("login.unauthorized", { serverName: plexServerName }) %></div>
    <% } %>
    <a class="plex-btn plex-btn--logo" href="<%= basePath %>/login" aria-label="<%= t('login.withPlex') %>">
      <span class="plex-btn-label"><%= locale === "en" ? "Sign in with" : "Se connecter avec" %></span>
      <img src="<%= basePath %>/img/plex-alt-light.svg" alt="Plex" class="plex-btn-logo" />
    </a>
  </div>
</div>

<style>
  .login-logo {
    display: none;
  }

  .login-page {
    gap: 0;
    padding: 40px 24px;
  }

  .login-card {
    width: min(820px, 100%);
    padding: 26px 30px 32px;
    background: transparent;
    border: 0;
    box-shadow: none;
    backdrop-filter: none;
    -webkit-backdrop-filter: none;
  }

  .login-card::before,
  .login-card::after {
    display: none;
  }

  .login-card h1 {
    margin: 0 0 56px;
    font-size: clamp(34px, 4vw, 38px);
    line-height: 1.08;
    font-weight: 800;
    color: #f3f1ec;
    letter-spacing: -0.03em;
  }

  .plex-btn--logo {
    width: 100%;
    min-width: 0;
    min-height: 78px;
    gap: 6px;
    padding: 0 28px;
    color: #f4f1ec;
    background: linear-gradient(90deg, rgba(83, 63, 43, 0.94) 0%, rgba(116, 84, 50, 0.94) 100%);
    border: 1px solid #a66822;
    border-radius: 14px;
    box-shadow: inset 0 0 0 1px rgba(255, 176, 76, 0.08);
    filter: none;
    font-size: 0;
  }

  .plex-btn-label {
    line-height: 1;
    font-size: 18px;
    font-weight: 700;
    color: #f4f1ec;
  }

  .plex-btn-logo {
    width: 64px;
    height: auto;
    display: block;
    transform: translateY(2px);
  }

  .plex-btn--logo::before {
    display: none;
  }

  .plex-btn--logo:hover {
    background: #a66822;
    border-color: #a66822;
    box-shadow: none;
    filter: none;
    transform: none;
  }

  .plex-btn--logo:active {
    transform: none;
  }

  .login-error {
    background: rgba(239, 68, 68, 0.12);
    border: 1px solid rgba(239, 68, 68, 0.4);
    color: #fca5a5;
    border-radius: 8px;
    padding: 12px 16px;
    margin: 0 0 24px;
    font-size: 0.88rem;
    text-align: center;
  }
</style>
