<div class="login-page">
  <div class="login-logo">
    <img src="<%= basePath %>/logo.png" alt="MonPlex" />
  </div>

  <div class="login-card">
    <h1><%= t("login.title") %></h1>
    <% if (typeof error !== 'undefined' && error === 'unauthorized') { %>
    <div class="login-error"><%= t("login.unauthorized", { serverName: plexServerName }) %></div>
    <% } %>
    <a class="plex-btn plex-btn--logo" href="<%= basePath %>/login" aria-label="<%= t('login.withPlex') %>">
      <span class="plex-btn-label"><%= locale === "en" ? "Sign in with" : "Se connecter avec" %></span>
      <img src="<%= basePath %>/img/plex-alt-light.svg" alt="Plex" class="plex-btn-logo" />
    </a>
  </div>
</div>

<style>
  .plex-btn--logo {
    min-width: 360px;
    min-height: 40px;
    gap: 4px;
    color: #f4f1ec;
    background: #533f2b;
    border: 1px solid #a66822;
    box-shadow: none;
    filter: none;
  }

  .plex-btn-label {
    line-height: 1;
  }

  .plex-btn-logo {
    width: 28px;
    height: auto;
    display: block;
    transform: translateY(1px);
  }

  .plex-btn--logo::before {
    display: none;
  }

  .plex-btn--logo:hover {
    background: #a66822;
    border-color: #a66822;
    box-shadow: none;
    filter: none;
    transform: none;
  }

  .plex-btn--logo:active {
    transform: none;
  }

  .login-error {
    background: rgba(239, 68, 68, 0.12);
    border: 1px solid rgba(239, 68, 68, 0.4);
    color: #fca5a5;
    border-radius: 8px;
    padding: 12px 16px;
    margin-bottom: 16px;
    font-size: 0.88rem;
    text-align: center;
  }
</style>
