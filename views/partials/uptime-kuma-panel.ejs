<%
  const uptimeLayout = layout === "dashboard" ? "dashboard" : "login";
  const rawStatusData = uptimeKuma && uptimeKuma.enabled ? uptimeKuma : null;
  const filteredServices = rawStatusData && Array.isArray(rawStatusData.services)
    ? rawStatusData.services.filter(service => {
        const serviceName = String(service?.name || "").trim().toLowerCase();
        const tags = Array.isArray(service?.tags)
          ? service.tags.map(tag => String(tag?.name || "").trim().toLowerCase()).filter(Boolean)
          : [];
        const values = [serviceName, ...tags];
        return !values.includes("portall") && !values.includes("site web");
      })
    : [];
  const statusData = rawStatusData
    ? { ...rawStatusData, services: filteredServices }
    : null;

  function getSummaryMeta(data) {
    if (!data) {
      return { label: "", className: "issues", icon: "!" };
    }

    if (data.overall === "operational") {
      return {
        label: t("login.status.allOperational"),
        className: "operational",
        icon: "&#10003;"
      };
    }

    if (data.overall === "maintenance") {
      return {
        label: "En maintenance",
        className: "maintenance",
        icon: `
          <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
            <path d="M21.2 7.4a5.7 5.7 0 0 1-7.6 5.4L7 19.4a1.8 1.8 0 0 1-2.5 0l-.9-.9a1.8 1.8 0 0 1 0-2.5l6.6-6.6a5.7 5.7 0 0 1 5.4-7.6l-2.8 2.8 1.8 1.8L17.4 3a5.7 5.7 0 0 1 3.8 4.4Z" fill="currentColor"/>
          </svg>
        `
      };
    }

    return {
      label: t("login.status.someIssues"),
      className: "issues",
      icon: "!"
    };
  }

  const summaryMeta = getSummaryMeta(statusData);

  function getServiceStateLabel(statusClassName) {
    if (statusClassName === "operational") return "En ligne";
    if (statusClassName === "pending") return "En attente";
    if (statusClassName === "maintenance") return "En maintenance";
    if (statusClassName === "down") return "Hors ligne";
    return "Indisponible";
  }

  function getServiceLogo(service) {
    const serviceName = String(service?.name || "").trim().toLowerCase();
    const tags = Array.isArray(service?.tags)
      ? service.tags.map(tag => String(tag?.name || "").trim().toLowerCase()).filter(Boolean)
      : [];
    const values = [serviceName, ...tags];

    if (values.includes("plex")) {
      return {
        src: `${basePath}/img/plex.svg`,
        alt: "Plex",
        className: "login-status-item__service-logo login-status-item__service-logo--plex"
      };
    }

    if (values.includes("seerr") || values.includes("overseerr")) {
      return {
        src: `${basePath}/img/seerr-icon.svg`,
        alt: "Seerr",
        className: "login-status-item__service-logo login-status-item__service-logo--seerr"
      };
    }

    if (values.includes("komga")) {
      return {
        src: `${basePath}/img/komga-icon.svg`,
        alt: "Komga",
        className: "login-status-item__service-logo login-status-item__service-logo--komga"
      };
    }

    if (values.includes("jellyfin")) {
      return {
        src: `${basePath}/img/jellyfin-icon.svg`,
        alt: "Jellyfin",
        className: "login-status-item__service-logo login-status-item__service-logo--jellyfin"
      };
    }

    if (values.includes("romm")) {
      return {
        src: `${basePath}/img/romm-icon.svg`,
        alt: "RomM",
        className: "login-status-item__service-logo login-status-item__service-logo--romm"
      };
    }

    if (values.includes("portall") || values.includes("site web")) {
      return {
        src: `${basePath}/img/portall-logo.png`,
        alt: "Portall",
        className: "login-status-item__service-logo login-status-item__service-logo--portall"
      };
    }

    return null;
  }

  function formatSince(isoDate) {
    if (!isoDate) return "";
    const timestamp = Date.parse(isoDate);
    if (Number.isNaN(timestamp)) return "";

    const diffMs = Math.max(0, Date.now() - timestamp);
    const totalMinutes = Math.floor(diffMs / 60000);

    if (totalMinutes < 1) return "Depuis moins d'une minute";
    if (totalMinutes < 60) return `Depuis ${totalMinutes} min`;

    const totalHours = Math.floor(totalMinutes / 60);
    if (totalHours < 24) {
      const remainingMinutes = totalMinutes % 60;
      return remainingMinutes > 0
        ? `Depuis ${totalHours} h ${remainingMinutes} min`
        : `Depuis ${totalHours} h`;
    }

    const totalDays = Math.floor(totalHours / 24);
    const remainingHours = totalHours % 24;
    return remainingHours > 0
      ? `Depuis ${totalDays} j ${remainingHours} h`
      : `Depuis ${totalDays} j`;
  }
%>

<% if (statusData) { %>
<section class="login-status-panel <%= uptimeLayout === 'dashboard' ? 'login-status-panel--dashboard' : '' %>" aria-labelledby="login-status-heading">
  <div class="login-status-summary login-status-summary--<%= summaryMeta.className %>">
    <span
      class="login-status-summary__icon login-status-summary__icon--<%= summaryMeta.className %>"
      aria-hidden="true"
    ><%- summaryMeta.icon %></span>
    <div class="login-status-summary__text">
      <h2 id="login-status-heading"><%= summaryMeta.label %></h2>
      <% if (statusData.description) { %>
      <p><%= statusData.description %></p>
      <% } %>
    </div>
  </div>

  <div class="login-status-section">
    <div class="login-status-section__header">
      <h3><%= t("login.status.services") %></h3>
    </div>

    <% if (statusData.privateError) { %>
    <div class="login-status-error"><%= statusData.privateError %></div>
    <% } %>

    <div class="login-status-list">
      <% if (!statusData.services.length) { %>
      <article class="login-status-item login-status-item--empty">
        <div class="login-status-item__meta">
          <div class="login-status-item__headline">
            <strong>Uptime Kuma</strong>
            <span class="login-status-state login-status-state--unknown">
              <span class="login-status-state__dot" aria-hidden="true"></span>
              <span>Indisponible</span>
            </span>
          </div>
          <div class="login-status-item__tags">
            <span class="login-status-item__tag">Aucune donnee</span>
          </div>
        </div>
      </article>
      <% } %>

      <% statusData.services.forEach(service => { %>
      <% const serviceLogo = getServiceLogo(service); %>
      <article class="login-status-item">
        <div class="login-status-item__row">
          <div class="login-status-item__meta">
            <div class="login-status-item__headline">
              <% if (serviceLogo) { %>
              <span class="login-status-item__service-brand">
                <img
                  src="<%= serviceLogo.src %>"
                  alt="<%= serviceLogo.alt %>"
                  class="<%= serviceLogo.className %>"
                />
                <% if (service.tags && service.tags.length) { %>
                <span class="login-status-item__tag" style="background-color: <%= service.tags[0].color %>;"><%= service.tags[0].name %></span>
                <% } %>
              </span>
              <% } else { %>
              <strong><%= service.name %></strong>
              <% } %>
            </div>
            <% if (!serviceLogo && service.tags && service.tags.length) { %>
            <div class="login-status-item__tags">
              <% service.tags.slice(0, 3).forEach(tag => { %>
              <span class="login-status-item__tag" style="background-color: <%= tag.color %>;"><%= tag.name %></span>
              <% }) %>
            </div>
            <% } %>
          </div>

          <div class="login-status-item__state-block">
            <span class="login-status-state login-status-state--<%= service.status.className %>">
              <span class="login-status-state__dot" aria-hidden="true"></span>
              <span><%= getServiceStateLabel(service.status.className) %></span>
            </span>
            <% if (service.statusChangedAt) { %>
            <div class="login-status-item__since"><%= formatSince(service.statusChangedAt) %></div>
            <% } %>
          </div>
        </div>
      </article>
      <% }) %>
    </div>
  </div>
</section>
<% } %>
