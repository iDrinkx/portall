<!doctype html>
<html lang="<%= locale || 'fr' %>">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title><%= t("setup.title") %></title>
  <script>
    window.APP_LOCALE = "<%= locale || 'fr' %>";
    window.APP_RUNTIME_TEXT_MAP = <%- JSON.stringify(runtimeTextMap || {}) %>;
  </script>
  <style>
    :root {
      color-scheme: dark;
      --bg-1: #07111f;
      --bg-2: #0d1b2f;
      --panel: rgba(8, 16, 28, 0.84);
      --panel-border: rgba(124, 178, 255, 0.2);
      --text: #edf4ff;
      --muted: #9ab0cc;
      --accent: #79c0ff;
      --accent-2: #38bdf8;
      --success: #86efac;
      --success-bg: rgba(34, 197, 94, 0.12);
      --success-border: rgba(34, 197, 94, 0.3);
      --warning: #fde68a;
      --warning-bg: rgba(245, 158, 11, 0.12);
      --warning-border: rgba(245, 158, 11, 0.3);
      --danger: #fca5a5;
    }

    * { box-sizing: border-box; }

    body {
      margin: 0;
      min-height: 100vh;
      font-family: "Segoe UI", sans-serif;
      color: var(--text);
      background:
        radial-gradient(circle at top left, rgba(56, 189, 248, 0.12), transparent 34%),
        radial-gradient(circle at bottom right, rgba(59, 130, 246, 0.14), transparent 28%),
        linear-gradient(160deg, var(--bg-1), var(--bg-2));
      padding: 32px 18px;
    }

    .setup-shell {
      max-width: 1100px;
      margin: 0 auto;
      display: grid;
      gap: 18px;
    }

    .setup-hero,
    .setup-card {
      background: var(--panel);
      border: 1px solid var(--panel-border);
      border-radius: 20px;
      backdrop-filter: blur(10px);
      box-shadow: 0 24px 60px rgba(0, 0, 0, 0.32);
    }

    .setup-hero {
      padding: 26px;
    }

    .setup-hero h1 {
      margin: 0 0 8px;
      font-size: 34px;
    }

    .setup-hero p {
      margin: 0;
      color: var(--muted);
      line-height: 1.55;
      max-width: 760px;
    }

    .setup-card {
      padding: 22px;
    }

    .setup-alert {
      margin-top: 14px;
      padding: 12px 14px;
      border-radius: 12px;
      background: rgba(248, 113, 113, 0.12);
      border: 1px solid rgba(248, 113, 113, 0.3);
      color: var(--danger);
    }

    .setup-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 16px;
    }

    .setup-section {
      padding: 16px;
      border-radius: 16px;
      background: rgba(255, 255, 255, 0.03);
      border: 1px solid rgba(255, 255, 255, 0.08);
    }

    .setup-section h2 {
      margin: 0 0 12px;
      font-size: 18px;
    }

    .setup-field {
      display: flex;
      flex-direction: column;
      gap: 6px;
      margin-bottom: 12px;
    }

    .setup-field:last-child {
      margin-bottom: 0;
    }

    .setup-field label {
      font-size: 13px;
      color: #d8e6fb;
    }

    .setup-required {
      color: #fbbf24;
      font-size: 12px;
      margin-left: 6px;
    }

    .setup-field input,
    .setup-field select {
      width: 100%;
      border: 1px solid rgba(148, 163, 184, 0.22);
      border-radius: 12px;
      background: rgba(2, 6, 23, 0.5);
      color: var(--text);
      padding: 11px 12px;
      font-size: 14px;
      outline: none;
    }

    .setup-field input:focus,
    .setup-field select:focus {
      border-color: rgba(121, 192, 255, 0.75);
      box-shadow: 0 0 0 3px rgba(121, 192, 255, 0.15);
    }

    .setup-actions {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 14px;
      margin-top: 18px;
      flex-wrap: wrap;
    }

    .setup-note {
      color: var(--muted);
      font-size: 13px;
    }

    .setup-btn {
      border: none;
      border-radius: 12px;
      background: linear-gradient(135deg, var(--accent), var(--accent-2));
      color: #031120;
      font-weight: 800;
      font-size: 14px;
      padding: 12px 18px;
      cursor: pointer;
    }

    .setup-btn-secondary {
      background: transparent;
      color: var(--text);
      border: 1px solid rgba(121, 192, 255, 0.35);
    }

    .setup-btn:disabled {
      opacity: 0.65;
      cursor: wait;
    }

    .setup-state {
      margin-top: 14px;
      color: var(--muted);
      font-size: 13px;
    }

    .setup-actions-buttons {
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
      justify-content: flex-end;
    }

    .setup-btn.is-hidden {
      display: none;
    }

    .setup-diagnostics {
      margin-top: 18px;
      padding-top: 18px;
      border-top: 1px solid rgba(255, 255, 255, 0.08);
    }

    .setup-diagnostics-list {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
      gap: 12px;
      margin-top: 12px;
    }

    .setup-diagnostics-card {
      padding: 14px;
      border-radius: 14px;
      border: 1px solid rgba(148, 163, 184, 0.18);
      background: rgba(255, 255, 255, 0.03);
    }

    .setup-diagnostics-card.is-ok {
      border-color: var(--success-border);
      background: var(--success-bg);
    }

    .setup-diagnostics-card.is-warning {
      border-color: var(--warning-border);
      background: var(--warning-bg);
    }

    .setup-diagnostics-card.is-error {
      border-color: rgba(248, 113, 113, 0.28);
      background: rgba(248, 113, 113, 0.1);
    }

    .setup-diagnostics-head {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 10px;
      margin-bottom: 8px;
    }

    .setup-diagnostics-title {
      font-weight: 700;
    }

    .setup-diagnostics-badge {
      padding: 4px 8px;
      border-radius: 999px;
      font-size: 12px;
      font-weight: 700;
      white-space: nowrap;
    }

    .setup-diagnostics-badge.is-ok {
      background: rgba(34, 197, 94, 0.16);
      color: var(--success);
    }

    .setup-diagnostics-badge.is-warning {
      background: rgba(245, 158, 11, 0.16);
      color: var(--warning);
    }

    .setup-diagnostics-badge.is-error {
      background: rgba(248, 113, 113, 0.14);
      color: var(--danger);
    }

    .setup-diagnostics-message {
      color: var(--muted);
      font-size: 13px;
      line-height: 1.45;
    }

    @media (max-width: 720px) {
      .setup-actions {
        flex-direction: column;
        align-items: stretch;
      }
    }
  </style>
</head>
<body>
  <section class="setup-shell">
    <div class="setup-hero">
      <h1><%= t("setup.title") %></h1>
      <p><%= t("setup.subtitle") %></p>
      <% if (error) { %>
        <div class="setup-alert"><%= error %></div>
      <% } %>
      <% if (missingKeys && missingKeys.length) { %>
        <div class="setup-alert"><%= t("setup.missing", { keys: missingKeys.join(", ") }) %></div>
      <% } %>
    </div>

    <div class="setup-card">
      <form id="setupForm">
        <div class="setup-grid">
          <% (configSections || []).forEach(function(section) { %>
            <div class="setup-section">
              <h2><%= section.group %></h2>
              <% (section.fields || []).forEach(function(field) { %>
                <div class="setup-field">
                  <label for="setup-<%= field.key %>">
                    <%= field.label %>
                    <% if (field.required) { %><span class="setup-required"><%= t("common.required") %></span><% } %>
                  </label>
                  <% if (field.type === 'select') { %>
                  <select
                    id="setup-<%= field.key %>"
                    name="<%= field.key %>"
                    <% if (field.visibleForProviders && field.visibleForProviders.length) { %>
                      data-uptime-provider-visible-for="<%= field.visibleForProviders.join(',') %>"
                    <% } %>
                  >
                    <% (field.options || []).forEach(function(option) { %>
                      <option value="<%= option.value %>" <%= String(field.value || '') === String(option.value) ? 'selected' : '' %>><%= option.label %></option>
                    <% }) %>
                  </select>
                  <% } else { %>
                  <input
                    id="setup-<%= field.key %>"
                    name="<%= field.key %>"
                    type="<%= field.secret ? 'password' : 'text' %>"
                    value="<%= field.value || '' %>"
                    autocomplete="off"
                    spellcheck="false"
                    <% if (field.visibleForProviders && field.visibleForProviders.length) { %>
                      data-uptime-provider-visible-for="<%= field.visibleForProviders.join(',') %>"
                    <% } %>
                  >
                  <% } %>
                </div>
              <% }) %>
            </div>
          <% }) %>
        </div>

        <div class="setup-actions">
          <div class="setup-note"><%= t("setup.note") %></div>
          <div class="setup-actions-buttons">
            <button class="setup-btn setup-btn-secondary" id="runSetupDiagnosticsBtn" type="button"><%= t("setup.diagnostics.run") %></button>
            <button class="setup-btn" type="submit"><%= t("setup.save") %></button>
            <button class="setup-btn setup-btn-secondary is-hidden" id="continueToPlexBtn" type="button"><%= t("setup.continue") %></button>
          </div>
        </div>
        <div class="setup-state" id="setupState"><%= t("setup.state.empty") %></div>
        <div class="setup-diagnostics" id="setupDiagnostics">
          <div class="setup-note" id="setupDiagnosticsState"><%= t("setup.diagnostics.empty") %></div>
          <div class="setup-diagnostics-list" id="setupDiagnosticsList"></div>
        </div>
      </form>
    </div>
  </section>

  <script>
    (function () {
      if ((window.APP_LOCALE || "fr") === "fr") return;
      const textMap = window.APP_RUNTIME_TEXT_MAP || {};
      const keys = Object.keys(textMap);
      if (!keys.length) return;

      function translateText(value) {
        const original = String(value == null ? "" : value);
        const trimmed = original.trim();
        if (!trimmed || !Object.prototype.hasOwnProperty.call(textMap, trimmed)) return original;
        const leading = original.match(/^\s*/)?.[0] || "";
        const trailing = original.match(/\s*$/)?.[0] || "";
        return leading + textMap[trimmed] + trailing;
      }

      function walk(node) {
        if (!node) return;
        if (node.nodeType === Node.TEXT_NODE) {
          const next = translateText(node.nodeValue);
          if (next !== node.nodeValue) node.nodeValue = next;
          return;
        }
        if (node.nodeType !== Node.ELEMENT_NODE) return;
        ["placeholder", "title", "aria-label", "value"].forEach(function (attr) {
          if (!node.hasAttribute(attr)) return;
          const current = node.getAttribute(attr);
          const next = translateText(current);
          if (next !== current) node.setAttribute(attr, next);
        });
        Array.from(node.childNodes).forEach(walk);
      }

      document.addEventListener("DOMContentLoaded", function () {
        walk(document.body);
      });
    })();
  </script>

  <script>
    (function () {
      const form = document.getElementById("setupForm");
      const state = document.getElementById("setupState");
      const diagnosticsState = document.getElementById("setupDiagnosticsState");
      const diagnosticsList = document.getElementById("setupDiagnosticsList");
      const diagnosticsBtn = document.getElementById("runSetupDiagnosticsBtn");
      const continueBtn = document.getElementById("continueToPlexBtn");
      const uptimeProviderInput = document.getElementById("setup-UPTIME_PROVIDER");
      if (!form || !state || !diagnosticsState || !diagnosticsList) return;
      let continueUrl = "<%= basePath %>/";

      function escHtml(value) {
        return String(value == null ? "" : value)
          .replace(/&/g, "&amp;")
          .replace(/</g, "&lt;")
          .replace(/>/g, "&gt;")
          .replace(/"/g, "&quot;")
          .replace(/'/g, "&#39;");
      }

      function updateUptimeProviderFields() {
        const provider = uptimeProviderInput ? String(uptimeProviderInput.value || "kuma").trim().toLowerCase() : "kuma";
        Array.from(document.querySelectorAll("[data-uptime-provider-visible-for]")).forEach(function (field) {
          const allowed = String(field.getAttribute("data-uptime-provider-visible-for") || "")
            .split(",")
            .map(function (entry) { return String(entry || "").trim().toLowerCase(); })
            .filter(Boolean);
          field.style.display = !allowed.length || allowed.includes(provider) ? "" : "none";
        });
      }

      function getPayload() {
        const payload = {};
        new FormData(form).forEach((value, key) => {
          payload[key] = String(value || "").trim();
        });
        return payload;
      }

      async function parseJsonResponse(resp) {
        const raw = await resp.text();
        let data = null;
        try {
          data = raw ? JSON.parse(raw) : null;
        } catch (_) {
          data = null;
        }

        if (!data) {
          const compact = String(raw || "").replace(/\s+/g, " ").trim();
          throw new Error(compact ? compact.slice(0, 140) : ("HTTP " + resp.status));
        }

        return data;
      }

      function renderDiagnostics(diagnostics) {
        const tests = Array.isArray(diagnostics && diagnostics.tests) ? diagnostics.tests : [];
        if (!tests.length) {
          diagnosticsState.textContent = "<%= t('setup.diagnostics.empty') %>";
          diagnosticsList.innerHTML = "";
          return;
        }

        const blockingErrors = tests.filter(function (test) { return !test.ok && !!test.blocking; }).length;
        const optionalPending = tests.filter(function (test) { return !!test.optional; }).length;

        if (blockingErrors === 0) {
          diagnosticsState.textContent = optionalPending > 0
            ? "<%= t('setup.diagnostics.okEssential') %>"
            : "<%= t('setup.diagnostics.okAll') %>";
        } else {
          diagnosticsState.textContent = "<%= t('setup.diagnostics.blocking', { count: '__COUNT__' }) %>".replace("__COUNT__", String(blockingErrors));
        }

        diagnosticsList.innerHTML = tests.map(function (test) {
          const tone = test.ok ? (test.optional ? "warning" : "ok") : (test.blocking ? "error" : "warning");
          const badge = test.ok
            ? (test.optional ? "<%= t('setup.diagnostics.badge.optional') %>" : "<%= t('setup.diagnostics.badge.ok') %>")
            : (test.blocking ? "Erreur" : "<%= t('setup.diagnostics.badge.optional') %>");
          return `
            <div class="setup-diagnostics-card is-${tone}">
              <div class="setup-diagnostics-head">
                <div class="setup-diagnostics-title">${escHtml(test.label || "Service")}</div>
                <div class="setup-diagnostics-badge is-${tone}">${badge}</div>
              </div>
              <div class="setup-diagnostics-message">${escHtml(test.message || "")}</div>
            </div>
          `;
        }).join("");
      }

      async function runDiagnostics() {
        if (diagnosticsBtn) diagnosticsBtn.disabled = true;
        diagnosticsState.textContent = "<%= t('setup.diagnostics.running') %>";
        try {
          const response = await fetch("<%= basePath %>/api/setup/diagnostics", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify(getPayload())
          });
          const data = await parseJsonResponse(response);
          if (!response.ok) {
            throw new Error(data.error || ("HTTP " + response.status));
          }
          renderDiagnostics(data);
        } catch (error) {
          diagnosticsState.textContent = error.message || "<%= t('setup.diagnostics.error') %>";
          diagnosticsList.innerHTML = "";
        } finally {
          if (diagnosticsBtn) diagnosticsBtn.disabled = false;
        }
      }

      if (uptimeProviderInput) {
        uptimeProviderInput.addEventListener("change", updateUptimeProviderFields);
        updateUptimeProviderFields();
      }

      if (diagnosticsBtn) {
        diagnosticsBtn.addEventListener("click", runDiagnostics);
      }

      if (continueBtn) {
        continueBtn.addEventListener("click", function () {
          window.location.href = continueUrl || "<%= basePath %>/";
        });
      }

      form.addEventListener("submit", async function (event) {
        event.preventDefault();
        state.textContent = "<%= t('setup.state.saving') %>";

        try {
          const payload = getPayload();
          const response = await fetch("<%= basePath %>/api/setup", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify(payload)
          });
          const data = await response.json();
          if (!response.ok) {
            throw new Error(data.error || ("HTTP " + response.status));
          }

          state.textContent = "<%= t('setup.state.saved') %>";
          continueUrl = data.redirectTo || "<%= basePath %>/";
          if (continueBtn) continueBtn.classList.remove("is-hidden");
        } catch (error) {
          state.textContent = error.message || "<%= t('setup.state.error') %>";
        }
      });
    })();
  </script>
</body>
</html>
