<style>
  .badges-container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 40px 20px;
  }

  /* HEADER */
  .badges-header {
    margin-bottom: 50px;
  }

  .badges-header-top {
    display: flex;
    align-items: center;
    gap: 20px;
    margin-bottom: 15px;
  }

  .back-button {
    color: #a0a0a0;
    text-decoration: none;
    font-size: 14px;
    font-weight: 500;
    transition: all 0.3s ease;
    padding: 8px 16px;
    border-radius: 6px;
    border: 1px solid rgba(160, 160, 160, 0.3);
    display: inline-block;
  }

  .back-button:hover {
    color: #E5A00D;
    background: rgba(229, 160, 13, 0.1);
    border-color: rgba(229, 160, 13, 0.5);
  }

  .badges-title {
    font-size: 32px;
    font-weight: bold;
    color: #E5A00D;
    letter-spacing: 1px;
    margin: 0;
  }

  .badges-subtitle {
    font-size: 14px;
    color: #a0a0a0;
    margin: 0;
  }

  /* STATS */
  .badges-stats {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 20px;
    margin-bottom: 40px;
  }

  .stat-box {
    background: linear-gradient(135deg, rgba(139, 69, 19, 0.2), rgba(218, 165, 32, 0.1));
    border: 2px solid rgba(218, 165, 32, 0.3);
    border-radius: 12px;
    padding: 25px;
    text-align: center;
    backdrop-filter: blur(10px);
  }

  .stat-number {
    font-size: 36px;
    font-weight: bold;
    color: #E5A00D;
    display: block;
  }

  .stat-label {
    font-size: 12px;
    color: #a0a0a0;
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-top: 8px;
  }

  /* CATEGORIES */
  .achievements-section {
    margin-bottom: 50px;
  }

  .category-header {
    display: flex;
    align-items: center;
    gap: 15px;
    margin-bottom: 30px;
    padding-bottom: 15px;
    border-bottom: 2px solid rgba(255, 255, 255, 0.1);
  }

  .category-icon {
    font-size: 28px;
  }

  .category-name {
    font-size: 24px;
    font-weight: bold;
    color: #fff;
  }

  .achievements-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
    gap: 20px;
  }

  /* ACHIEVEMENT CARD */
  .achievement-card {
    background: rgba(255, 255, 255, 0.02);
    border: 2px solid rgba(255, 255, 255, 0.1);
    border-radius: 12px;
    padding: 20px;
    text-align: center;
    transition: all 0.3s ease;
    cursor: pointer;
    position: relative;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    min-height: 220px;
  }

  .achievement-card:hover {
    transform: translateY(-5px);
    border-color: rgba(255, 255, 255, 0.3);
    background: rgba(255, 255, 255, 0.05);
  }

  .achievement-card.locked {
    opacity: 0.8;
    border-color: rgba(255, 255, 255, 0.08);
  }

  .achievement-card.locked .achievement-icon {
    filter: grayscale(100%);
    opacity: 0.6;
  }

  /* Couleurs de bordure par catégorie */
  .achievement-card.temporels {
    border-left: 4px solid #E67E22;
  }

  .achievement-card.activites {
    border-left: 4px solid #E74C3C;
  }

  .achievement-card.films {
    border-left: 4px solid #E67E22;
  }

  .achievement-card.series {
    border-left: 4px solid #3498DB;
  }

  .achievement-card.mensuels {
    border-left: 4px solid #F39C12;
  }

  .achievement-card.secrets {
    border-left: 4px solid #9B59B6;
  }

  .achievement-icon {
    font-size: 40px;
    margin-bottom: 12px;
    display: block;
  }

  .achievement-name {
    font-size: 14px;
    font-weight: 700;
    color: #fff;
    margin-bottom: 8px;
    line-height: 1.2;
  }

  .achievement-description {
    font-size: 12px;
    color: #a0a0a0;
    margin-bottom: 12px;
    flex-grow: 1;
    line-height: 1.4;
  }

  .achievement-date {
    font-size: 11px;
    color: #8BC34A;
    margin-top: auto;
  }

  .achievement-date.secret {
    color: #9B59B6;
  }

  .achievement-secret-text {
    font-size: 11px;
    color: #9B59B6;
    margin-top: auto;
  }

  /* PROGRESS BAR */
  .achievement-progress {
    margin-top: 12px;
    font-size: 11px;
    color: #a0a0a0;
  }

  .achievement-progress-bar {
    width: 100%;
    height: 6px;
    background: rgba(255, 255, 255, 0.1);
    border-radius: 3px;
    overflow: hidden;
    margin-top: 6px;
  }

  .achievement-progress-fill {
    height: 100%;
    background: linear-gradient(90deg, #E5A00D, #DAA520);
    border-radius: 3px;
    transition: width 0.3s ease;
  }

  /* Loading state */
  .loading {
    text-align: center;
    padding: 60px 20px;
    color: #a0a0a0;
  }

  .spinner {
    display: inline-block;
    width: 40px;
    height: 40px;
    border: 3px solid rgba(229, 160, 13, 0.3);
    border-top: 3px solid #E5A00D;
    border-radius: 50%;
    animation: spin 0.8s linear infinite;
  }

  @keyframes spin {
    to { transform: rotate(360deg); }
  }

  @media (max-width: 768px) {
    .badges-title {
      font-size: 28px;
    }

    .achievements-grid {
      grid-template-columns: repeat(auto-fill, minmax(120px, 1fr));
      gap: 15px;
    }

    .achievement-card {
      padding: 15px;
    }

    .achievement-icon {
      font-size: 32px;
    }

    .achievement-tooltip {
      display: none !important;
    }
  }
</style>

<div class="badges-container">
  <!-- HEADER WITH BACK BUTTON -->
  <div class="badges-header">
    <div class="badges-header-top">
      <a href="<%= basePath %>/profil" class="back-button">← Retour au Profil</a>
      <h1 class="badges-title">Mes Succès</h1>
    </div>
    <p class="badges-subtitle">Débloquez des succès en regardant du contenu sur Dark TV !</p>
  </div>

  <!-- STATS -->
  <div class="badges-stats">
    <div class="stat-box">
      <span class="stat-number" id="unlockedCount"><%= stats.unlocked %></span>
      <span class="stat-label">Succès Débloqués</span>
    </div>
    <div class="stat-box">
      <span class="stat-number" id="lockedCount"><%= stats.locked %></span>
      <span class="stat-label">Succès Restants</span>
    </div>
    <div class="stat-box">
      <span class="stat-number" id="progressPercent"><%= stats.progress %>%</span>
      <span class="stat-label">Progression</span>
    </div>
  </div>

  <!-- ACHIEVEMENTS BY CATEGORY -->
  <% const categories = ['temporels', 'activites', 'films', 'series', 'mensuels', 'collections', 'secrets']; %>
  
  <% categories.forEach(categoryKey => {
    const category = ACHIEVEMENTS[categoryKey];
    if (!category || !category.achievements || category.achievements.length === 0) return;
  %>
    <div class="achievements-section">
      <div class="category-header">
        <span class="category-icon"><%= category.icon %></span>
        <span class="category-name"><%= category.name %></span>
      </div>

      <div class="achievements-grid">
        <% category.achievements.forEach(achievement => { %>
          <div class="achievement-card <%= achievement.category %> <%= achievement.unlocked ? 'unlocked' : 'locked' %>">
            <span class="achievement-icon"><%= achievement.icon %></span>
            <div class="achievement-name"><%= achievement.name %></div>
            
            <% if (achievement.unlocked) { %>
              <!-- DÉBLOQUÉ -->
              <div class="achievement-description"><%= achievement.description %></div>
              <div class="achievement-date">
                <% if (achievement.unlockedDate) { %>
                  ✓ Débloqué le <%= achievement.unlockedDate %>
                <% } else { %>
                  ✓ Débloqué
                <% } %>
              </div>
            <% } else { %>
              <!-- VERROUILLÉ -->
              <% if (!achievement.revocable && (achievement.isSecret || achievement.category === 'secrets')) { %>
                <!-- SECRET VERROUILLÉ : on ne révèle rien -->
                <div class="achievement-secret-text">🔒 Badge secret</div>
              <% } else if (achievement.revocable) { %>
                <!-- BADGE COLLECTION : description + barre de progression -->
                <div class="achievement-description"><%= achievement.description %></div>
                <% const prog = typeof progressMap !== 'undefined' && progressMap && progressMap[achievement.id]; %>
                <% if (prog && prog.total > 0) { %>
                  <div class="achievement-progress">
                    <span class="current"><%= prog.current %></span> / <span class="total"><%= prog.total %></span> (<span class="percent"><%= Math.round((prog.current / prog.total) * 100) %></span>%)
                  </div>
                  <div class="achievement-progress-bar">
                    <div class="achievement-progress-fill" style="width: <%= Math.min(100, Math.round((prog.current / prog.total) * 100)) %>%"></div>
                  </div>
                <% } else { %>
                  <div class="achievement-secret-text">🔒 Badge secret</div>
                <% } %>
              <% } else { %>
                <!-- NON-SECRET VERROUILLÉ -->
                <% const emptyData = { daysSince: 0, sessionCount: 0, totalHours: 0, movieCount: 0, episodeCount: 0 }; %>
                <% const progInfo = achievement.getProgress ? achievement.getProgress(emptyData) : { current: 0, total: 100, percent: 0 }; %>
                <div class="achievement-description"><%= achievement.conditionText %></div>
                <div class="achievement-progress" id="progress-<%= achievement.id %>">
                  <span class="current">0</span> / <span class="total"><%= progInfo.total %></span> (<span class="percent">0</span>%)
                </div>
                <div class="achievement-progress-bar">
                  <div class="achievement-progress-fill" id="fill-<%= achievement.id %>" style="width: 0%"></div>
                </div>
              <% } %>
            <% } %>
          </div>
        <% }); %>
      </div>
    </div>
  <% }); %>
</div>

<script>
  document.addEventListener("DOMContentLoaded", function() {
    // Les données sont déjà affichées via EJS
    console.log("🏆 Page Badges chargée!");

    // Récupérer les stats pour calculer les progressions
    fetch('<%= basePath %>/api/stats')
      .then(res => res.json())
      .then(stats => {
        // Utiliser stats.joinedAt (API) en priorité, sinon joinedAtTimestamp de session
        const joinedAtMs = stats.joinedAt
          ? new Date(stats.joinedAt).getTime()
          : (<%= user.joinedAtTimestamp || 0 %> * 1000);
        const data = {
          totalHours: stats.watchStats?.totalHours || 0,
          movieCount: stats.watchStats?.movieCount || 0,
          episodeCount: stats.watchStats?.episodeCount || 0,
          sessionCount: stats.sessionCount || 0,
          monthlyHours: stats.monthlyHours || 0,
          nightCount: stats.nightCount || 0,
          morningCount: stats.morningCount || 0,
          daysSince: joinedAtMs > 0 ? Math.floor((Date.now() - joinedAtMs) / (1000 * 60 * 60 * 24)) : 0
        };

        console.log("[BADGES-JS] Data:", data);

        // Mettre à jour les barres de progression des achievements débloqués
        // Temporels
        updateProgress('first-anniversary', Math.min(data.daysSince, 365), 365);
        updateProgress('veteran', Math.min(data.daysSince, 730), 730);
        updateProgress('old-timer', Math.min(data.daysSince, 1825), 1825);
        updateProgress('og', 0, 1);

        // Activités
        updateProgress('first-watch', Math.min(data.sessionCount, 1), 1);
        updateProgress('regular', Math.min(data.sessionCount, 7), 7);
        updateProgress('night-owl', Math.min(data.nightCount, 30), 30);
        updateProgress('early-bird', Math.min(data.morningCount, 50), 50);
        updateProgress('centurion', Math.min(Math.round(data.totalHours), 100), 100);
        updateProgress('marathoner', Math.min(Math.round(data.totalHours), 500), 500);

        // Films
        updateProgress('cinema-marathon', Math.min(data.movieCount, 5), 5);
        updateProgress('cinephile', Math.min(data.movieCount, 50), 50);
        updateProgress('film-critic', Math.min(data.movieCount, 100), 100);
        updateProgress('cinema-master', Math.min(data.movieCount, 250), 250);
        updateProgress('hollywood-legend', Math.min(data.movieCount, 500), 500);

        // Séries
        updateProgress('binge-watcher', Math.min(data.episodeCount, 10), 10);
        updateProgress('series-addict', Math.min(data.episodeCount, 100), 100);
        updateProgress('series-master', Math.min(data.episodeCount, 500), 500);
        updateProgress('serial-killer-legend', Math.min(data.episodeCount, 1000), 1000);

        // Mensuels
        updateProgress('busy-month', Math.min(data.monthlyHours, 50), 50);
        updateProgress('intense-month', Math.min(data.monthlyHours, 100), 100);
      })
      .catch(err => console.error('[BADGES-JS] Erreur:', err));

    function updateProgress(achievementId, current, total) {
      const progressEl = document.getElementById('progress-' + achievementId);
      const fillEl = document.getElementById('fill-' + achievementId);
      
      if (!progressEl || !fillEl) return;

      const percent = Math.min(Math.round((current / total) * 100), 100);
      
      progressEl.querySelector('.current').textContent = current;
      progressEl.querySelector('.total').textContent = total;
      progressEl.querySelector('.percent').textContent = percent;
      fillEl.style.width = percent + '%';
    }
  });
</script>
