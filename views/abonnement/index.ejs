<div class="content">
  <h1 class="dashboard-title">Abonnement</h1>

  <div class="card subscription-card loading" id="subscriptionCard">

    <div class="subscription-row">
      <span class="label">Statut</span>
      <span class="status-badge loading" id="subStatus">
        Chargement...
      </span>
    </div>

    <div class="subscription-row">
      <span class="label">Jours restants</span>
      <span class="value" id="subDays">—</span>
    </div>

    <div class="subscription-row">
      <span class="label">Expire le</span>
      <span class="value" id="subExpire">—</span>
    </div>

    <div class="progress-wrapper">
      <div class="progress-bar">
        <div class="progress" id="subProgress" style="width:0%"></div>
      </div>
    </div>

  </div>
</div>

<script>
async function loadSubscription() {
  try {
    const res = await fetch("/api/subscription");
    const data = await res.json();

    const card = document.getElementById("subscriptionCard");
    const statusEl = document.getElementById("subStatus");
    const daysEl = document.getElementById("subDays");
    const expireEl = document.getElementById("subExpire");
    const progressEl = document.getElementById("subProgress");

    // Reset classes
    card.className = "card subscription-card " + data.status;
    statusEl.className = "status-badge " + data.status;

    statusEl.textContent = data.label;
    daysEl.textContent = data.daysLeft || "—";
    expireEl.textContent = data.expiresAt || "—";

    progressEl.style.width = (data.progressPercent || 0) + "%";

  } catch (err) {
    console.error("Erreur abonnement:", err);
  }
}

loadSubscription();
</script>
