<style>
/* ═══════════════════════════════════════════
   CLASSEMENT — Variables & Base
═══════════════════════════════════════════ */
:root {
  --lb-blue:      #3B82F6;
  --lb-blue-dim:  rgba(59,130,246,0.15);
  --lb-blue-glow: rgba(59,130,246,0.35);
}

.lb-page {
  max-width: 1100px;
  margin: 0 auto;
  padding: 28px 20px 60px;
}

/* ── Header ── */
.lb-header {
  margin-bottom: 28px;
}
.lb-title {
  font-size: 26px;
  font-weight: 800;
  color: #fff;
  margin: 0 0 4px;
}
.lb-subtitle {
  font-size: 13px;
  color: #555;
  margin: 0;
}

/* ── Onglets principaux ── */
.lb-tabs {
  display: flex;
  gap: 8px;
  margin-bottom: 28px;
}
.lb-tab {
  padding: 9px 22px;
  border-radius: 24px;
  border: 1.5px solid rgba(255,255,255,0.1);
  background: transparent;
  color: #888;
  font-size: 13px;
  font-weight: 700;
  cursor: pointer;
  transition: all 0.2s ease;
  letter-spacing: 0.3px;
}
.lb-tab:hover {
  color: #fff;
  border-color: rgba(255,255,255,0.25);
}
.lb-tab.active {
  background: var(--lb-blue);
  border-color: var(--lb-blue);
  color: #fff;
  box-shadow: 0 4px 16px var(--lb-blue-glow);
}

/* ── Contenu des onglets ── */
.lb-section { display: none; }
.lb-section.active { display: block; }

/* ── Compteur ── */
.lb-count {
  font-size: 12px;
  color: #555;
  margin-bottom: 20px;
  letter-spacing: 0.5px;
  text-transform: uppercase;
}
.lb-count span { color: var(--lb-blue); font-weight: 700; }

/* ═══════════════════════════════════════════
   SECTION MEMBRES — Grille de cartes
═══════════════════════════════════════════ */
.lb-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(175px, 1fr));
  gap: 16px;
}

.lb-card {
  background: #111318;
  border: 1px solid rgba(255,255,255,0.07);
  border-radius: 16px;
  padding: 24px 16px 20px;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10px;
  cursor: default;
  transition: border-color 0.2s ease, transform 0.2s ease;
  position: relative;
  overflow: hidden;
}
.lb-card::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 2px;
  background: var(--card-rank-color, #3B82F6);
  opacity: 0.6;
  border-radius: 16px 16px 0 0;
}
.lb-card:hover {
  transform: translateY(-4px);
  border-color: rgba(255,255,255,0.15);
}

/* Avatar wrapper avec rank ring */
.lb-avatar-wrap {
  position: relative;
  width: 80px;
  height: 80px;
  flex-shrink: 0;
}
.lb-rank-ring {
  position: absolute;
  inset: -4px;
  border-radius: 50%;
  background: transparent;
  -webkit-mask: radial-gradient(farthest-side, transparent calc(100% - 3px), #fff calc(100% - 3px));
  mask: radial-gradient(farthest-side, transparent calc(100% - 3px), #fff calc(100% - 3px));
  animation: rank-ring-breathe 3.5s ease-in-out infinite;
  pointer-events: none;
}
.lb-avatar {
  width: 80px;
  height: 80px;
  border-radius: 50%;
  object-fit: cover;
  display: block;
  position: relative;
  z-index: 1;
}
.lb-avatar-placeholder {
  width: 80px;
  height: 80px;
  border-radius: 50%;
  background: #1e2030;
  border: 2px solid rgba(255,255,255,0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28px;
  font-weight: 800;
  color: #fff;
  position: relative;
  z-index: 1;
}

/* Badge niveau (coin bas droite) */
.lb-level-badge {
  position: absolute;
  bottom: -2px;
  right: -2px;
  background: #0d0f14;
  border: 1.5px solid rgba(255,255,255,0.12);
  border-radius: 10px;
  font-size: 10px;
  font-weight: 800;
  color: #ccc;
  padding: 2px 5px;
  z-index: 2;
  line-height: 1.2;
  min-width: 24px;
  text-align: center;
}

/* Nom flouté */
.lb-username {
  font-size: 15px;
  font-weight: 700;
  color: #fff;
  filter: blur(7px);
  user-select: none;
  width: 100%;
  text-align: center;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* Badge rang */
.lb-rank-badge {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  padding: 3px 10px;
  border-radius: 20px;
  font-size: 11px;
  font-weight: 700;
}

/* Heures */
.lb-hours {
  font-size: 22px;
  font-weight: 800;
  color: var(--plex, #e5a00d);
  line-height: 1;
}
.lb-hours-label {
  font-size: 10px;
  color: #555;
  text-transform: uppercase;
  letter-spacing: 0.6px;
  margin-top: 1px;
  text-align: center;
}

/* Skeleton */
.lb-card.skel { pointer-events: none; }
.lb-card.skel .lb-avatar-placeholder { background: #1a1c22; }
.lb-card.skel .lb-username,
.lb-card.skel .lb-hours { background: #1a1c22; border-radius: 6px; color: transparent; }

/* ═══════════════════════════════════════════
   SECTION CLASSEMENTS — Deux listes côte à côte
═══════════════════════════════════════════ */
.lb-rankings {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20px;
}
@media (max-width: 700px) {
  .lb-rankings { grid-template-columns: 1fr; }
}

.lb-ranking-block {
  background: #111318;
  border: 1px solid rgba(255,255,255,0.07);
  border-radius: 16px;
  overflow: hidden;
}
.lb-ranking-header {
  padding: 18px 20px 14px;
  border-bottom: 1px solid rgba(255,255,255,0.06);
  display: flex;
  align-items: center;
  gap: 10px;
}
.lb-ranking-icon { font-size: 20px; }
.lb-ranking-title {
  font-size: 15px;
  font-weight: 800;
  color: #fff;
  margin: 0;
}

/* Ligne du classement */
.lb-row {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 12px 18px;
  border-bottom: 1px solid rgba(255,255,255,0.04);
  transition: background 0.15s ease;
}
.lb-row:last-child { border-bottom: none; }
.lb-row:hover { background: rgba(255,255,255,0.03); }

/* Podium */
.lb-pos {
  width: 28px;
  text-align: center;
  font-size: 13px;
  font-weight: 800;
  flex-shrink: 0;
}
.lb-pos-1 { font-size: 20px; }
.lb-pos-2 { font-size: 18px; }
.lb-pos-3 { font-size: 16px; }
.lb-pos-n { color: #444; font-size: 12px; }

/* Petit avatar pour la liste */
.lb-row-avatar-wrap {
  position: relative;
  width: 40px;
  height: 40px;
  flex-shrink: 0;
}
.lb-row-ring {
  position: absolute;
  inset: -3px;
  border-radius: 50%;
  background: transparent;
  -webkit-mask: radial-gradient(farthest-side, transparent calc(100% - 2px), #fff calc(100% - 2px));
  mask: radial-gradient(farthest-side, transparent calc(100% - 2px), #fff calc(100% - 2px));
  animation: rank-ring-breathe 3.5s ease-in-out infinite;
  pointer-events: none;
}
.lb-row-avatar {
  width: 40px;
  height: 40px;
  border-radius: 50%;
  object-fit: cover;
  display: block;
  position: relative;
  z-index: 1;
}
.lb-row-placeholder {
  width: 40px;
  height: 40px;
  border-radius: 50%;
  background: #1e2030;
  border: 1.5px solid rgba(255,255,255,0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 14px;
  font-weight: 800;
  color: #fff;
  position: relative;
  z-index: 1;
}

/* Infos dans la ligne */
.lb-row-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 2px;
}
.lb-row-name {
  font-size: 13px;
  font-weight: 700;
  color: #fff;
  filter: blur(7px);
  user-select: none;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.lb-row-meta {
  font-size: 11px;
  color: #555;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* Stat à droite */
.lb-row-stat {
  flex-shrink: 0;
  text-align: right;
}
.lb-row-stat-main {
  font-size: 14px;
  font-weight: 800;
  color: var(--plex, #e5a00d);
  line-height: 1;
}
.lb-row-stat-sub {
  font-size: 10px;
  color: #555;
  margin-top: 1px;
}

/* Niveau en couleur rang */
.lb-row-level {
  font-size: 11px;
  font-weight: 700;
  padding: 2px 6px;
  border-radius: 8px;
}

/* ── État chargement ── */
.lb-loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 12px;
  padding: 60px 20px;
  color: #555;
  font-size: 14px;
}
.lb-spinner {
  width: 32px;
  height: 32px;
  border: 3px solid rgba(59,130,246,0.2);
  border-top-color: var(--lb-blue);
  border-radius: 50%;
  animation: lb-spin 0.8s linear infinite;
}
@keyframes lb-spin { to { transform: rotate(360deg); } }

/* ── État erreur ── */
.lb-error {
  text-align: center;
  padding: 60px 20px;
  color: #555;
}
.lb-error-icon { font-size: 36px; margin-bottom: 10px; }

/* Responsive */
@media (max-width: 500px) {
  .lb-grid { grid-template-columns: repeat(2, 1fr); }
  .lb-card { padding: 16px 10px 14px; }
}
</style>

<div class="lb-page">

  <!-- Header -->
  <div class="lb-header">
    <h1 class="lb-title">🏆 Classement</h1>
    <p class="lb-subtitle">Membres du serveur — heures de visionnage et progression</p>
  </div>

  <!-- Onglets -->
  <div class="lb-tabs">
    <button class="lb-tab active" data-tab="membres">👥 Membres</button>
    <button class="lb-tab" data-tab="classements">🏅 Classements</button>
  </div>

  <!-- ── Section Membres ── -->
  <section class="lb-section active" id="tab-membres">
    <div class="lb-loading" id="membresLoading">
      <div class="lb-spinner"></div>
      <span>Chargement des membres…</span>
    </div>
    <p class="lb-count" id="membresCount" style="display:none"></p>
    <div class="lb-grid" id="membresGrid"></div>
  </section>

  <!-- ── Section Classements ── -->
  <section class="lb-section" id="tab-classements">
    <div class="lb-loading" id="classementsLoading">
      <div class="lb-spinner"></div>
      <span>Chargement du classement…</span>
    </div>
    <div class="lb-rankings" id="classementsContent" style="display:none">
      <!-- Classement heures -->
      <div class="lb-ranking-block">
        <div class="lb-ranking-header">
          <span class="lb-ranking-icon">🎬</span>
          <h2 class="lb-ranking-title">Plus d'heures visionnées</h2>
        </div>
        <div id="rankHoursList"></div>
      </div>
      <!-- Classement niveaux -->
      <div class="lb-ranking-block">
        <div class="lb-ranking-header">
          <span class="lb-ranking-icon">⭐</span>
          <h2 class="lb-ranking-title">Par niveau</h2>
        </div>
        <div id="rankLevelList"></div>
      </div>
    </div>
  </section>

</div>

<script>
(function () {
  // ── Onglets ──
  document.querySelectorAll('.lb-tab').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.lb-tab').forEach(b => b.classList.remove('active'));
      document.querySelectorAll('.lb-section').forEach(s => s.classList.remove('active'));
      btn.classList.add('active');
      document.getElementById('tab-' + btn.dataset.tab).classList.add('active');
    });
  });

  // ── Helpers ──
  let _uid = 0; // compteur ID unique pour les rings

  function _rankGrad(c) {
    return `conic-gradient(from -90deg, ${c}2e 0deg, ${c} 90deg, ${c}cc 180deg, ${c} 270deg, ${c}2e 360deg)`;
  }

  function posLabel(i) {
    if (i === 0) return '<span class="lb-pos lb-pos-1" title="#1">🥇</span>';
    if (i === 1) return '<span class="lb-pos lb-pos-2" title="#2">🥈</span>';
    if (i === 2) return '<span class="lb-pos lb-pos-3" title="#3">🥉</span>';
    return `<span class="lb-pos lb-pos-n">#${i + 1}</span>`;
  }

  function avatarHtml(user, size) {
    const isRow = size === 'row';
    const wrapCls = isRow ? 'lb-row-avatar-wrap' : 'lb-avatar-wrap';
    const ringCls = isRow ? 'lb-row-ring'        : 'lb-rank-ring';
    const imgCls  = isRow ? 'lb-row-avatar'       : 'lb-avatar';
    const phCls   = isRow ? 'lb-row-placeholder'  : 'lb-avatar-placeholder';
    const imgSize = isRow ? 40 : 80;
    const initials = (user.username || '?').charAt(0).toUpperCase();

    const ringStyle = `background:${_rankGrad(user.rank.color)}`;
    const filterVal = `drop-shadow(0 0 6px ${user.rank.color}99)`;

    const imgPart = user.thumb
      ? `<img src="${user.thumb}" class="${imgCls}" width="${imgSize}" height="${imgSize}" alt="" loading="lazy" onerror="this.style.display='none';this.nextElementSibling.style.display='flex'">`
        + `<div class="${phCls}" style="display:none">${initials}</div>`
      : `<div class="${phCls}">${initials}</div>`;

    const levelBadge = isRow ? '' : `<div class="lb-level-badge">${user.level}</div>`;

    return `<div class="${wrapCls}" style="filter:${filterVal}">
      <div class="${ringCls}" style="${ringStyle}"></div>
      ${imgPart}
      ${levelBadge}
    </div>`;
  }

  // ── Rendu grille membres ──
  function renderMembers(byHours) {
    const grid = document.getElementById('membresGrid');
    grid.innerHTML = '';

    byHours.forEach(user => {
      const card = document.createElement('div');
      card.className = 'lb-card';
      card.style.setProperty('--card-rank-color', user.rank.color);

      const hrs = Number.isInteger(user.totalHours)
        ? user.totalHours + 'h'
        : user.totalHours.toFixed(0) + 'h';

      card.innerHTML = `
        ${avatarHtml(user, 'card')}
        <p class="lb-username">${user.username}</p>
        <span class="lb-rank-badge" style="background:${user.rank.bgColor};color:${user.rank.color};border:1px solid ${user.rank.borderColor}40">
          ${user.rank.icon} ${user.rank.name}
        </span>
        <div>
          <div class="lb-hours">${hrs}</div>
          <div class="lb-hours-label">Heures visionnées</div>
        </div>
      `;
      grid.appendChild(card);
    });

    const cnt = document.getElementById('membresCount');
    cnt.innerHTML = `<span>${byHours.length}</span> membres inscrits`;
    cnt.style.display = 'block';
    document.getElementById('membresLoading').style.display = 'none';
  }

  // ── Rendu ligne classement ──
  function renderRankingRow(user, pos) {
    const hrs = Number.isInteger(user.totalHours)
      ? user.totalHours + 'h'
      : user.totalHours.toFixed(0) + 'h';

    return `<div class="lb-row">
      ${posLabel(pos)}
      ${avatarHtml(user, 'row')}
      <div class="lb-row-info">
        <div class="lb-row-name">${user.username}</div>
        <div class="lb-row-meta" style="color:${user.rank.color}55">
          <span style="color:${user.rank.color};font-weight:700">${user.rank.icon} ${user.rank.name}</span>
        </div>
      </div>
      <div class="lb-row-stat">
        <div class="lb-row-level" style="background:${user.rank.bgColor};color:${user.rank.color}">Nv.&nbsp;${user.level}</div>
      </div>
      <div class="lb-row-stat" style="margin-left:8px;min-width:44px">
        <div class="lb-row-stat-main">${hrs}</div>
        <div class="lb-row-stat-sub">heures</div>
      </div>
    </div>`;
  }

  // ── Rendu classements ──
  function renderClassements(data) {
    document.getElementById('rankHoursList').innerHTML =
      data.byHours.map((u, idx) => renderRankingRow(u, idx)).join('');
    document.getElementById('rankLevelList').innerHTML =
      data.byLevel.map((u, idx) => renderRankingRow(u, idx)).join('');

    document.getElementById('classementsLoading').style.display = 'none';
    document.getElementById('classementsContent').style.display = 'grid';
  }

  // ── Fetch ──
  const bp = window.APP_BASE_PATH || '';

  fetch(bp + '/api/classement')
    .then(r => r.ok ? r.json() : Promise.reject(r.status))
    .then(data => {
      renderMembers(data.byHours);
      renderClassements(data);
    })
    .catch(err => {
      ['membresLoading', 'classementsLoading'].forEach(id => {
        const el = document.getElementById(id);
        if (el) el.innerHTML = `
          <div class="lb-error">
            <div class="lb-error-icon">😞</div>
            <p>Impossible de charger le classement.<br><small>Erreur ${err}</small></p>
          </div>`;
      });
    });
})();
</script>
