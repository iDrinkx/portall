<style>
/* 
   CLASSEMENT PAGE
 */
:root {
  --lb-blue:      #3B82F6;
  --lb-blue-dim:  rgba(59,130,246,0.12);
  --lb-blue-glow: rgba(59,130,246,0.35);
  --lb-gold:      #E5A00D;
  --lb-silver:    #C0C0C0;
  --lb-bronze:    #CD7F32;
}

.lb-page {
  max-width: 1140px;
  margin: 0 auto;
  padding: 28px 20px 60px;
}

/*  Header  */
.lb-header { margin-bottom: 32px; }
.lb-title  { font-size: 26px; font-weight: 800; color: #fff; margin: 0 0 4px; }
.lb-subtitle { font-size: 13px; color: #555; margin: 0; }
.lb-refresh-timer { font-size: 11px; color: #555; margin-top: 8px; font-style: italic; }

/* 
   PODIUM TOP 3
 */
.lb-podium-section {
  margin-bottom: 36px;
}
.lb-podium-title {
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 1.5px;
  text-transform: uppercase;
  color: #444;
  margin-bottom: 16px;
}

.lb-podium {
  display: flex;
  align-items: flex-end;
  justify-content: center;
  gap: 12px;
}

.lb-podium-card {
  background: #111318;
  border: 1px solid rgba(255,255,255,0.07);
  border-radius: 18px;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10px;
  position: relative;
  overflow: hidden;
  transition: transform 0.2s ease, border-color 0.2s ease;
  cursor: default;
}
.lb-podium-card::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 2px;
  opacity: 0.7;
  border-radius: 18px 18px 0 0;
}
.lb-podium-card:hover { transform: translateY(-4px); }

/* Tailles podium */
.lb-podium-card--1 { padding: 28px 20px 22px; flex: 0 0 210px; }
.lb-podium-card--2 { padding: 22px 18px 18px; flex: 0 0 185px; }
.lb-podium-card--3 { padding: 22px 18px 18px; flex: 0 0 185px; }

.lb-podium-card--1::before { background: var(--lb-gold); }
.lb-podium-card--2::before { background: var(--lb-silver); }
.lb-podium-card--3::before { background: var(--lb-bronze); }

.lb-podium-medal {
  position: absolute;
  top: 10px; left: 12px;
  font-size: 22px;
  line-height: 1;
}
.lb-podium-card--1 .lb-podium-medal { font-size: 26px; }

/* Avatar dans le podium */
.lb-pod-avatar-wrap {
  position: relative;
  flex-shrink: 0;
  overflow: visible;
  will-change: filter;
}
.lb-pod-ring {
  position: absolute;
  border-radius: 50%;
  background: transparent;
  -webkit-mask: radial-gradient(farthest-side, transparent calc(100% - 3px), #fff calc(100% - 3px));
  mask: radial-gradient(farthest-side, transparent calc(100% - 3px), #fff calc(100% - 3px));
  animation: rank-ring-breathe 3.5s ease-in-out infinite;
  pointer-events: none;
}
.lb-podium-card--1 .lb-pod-avatar-wrap { width: 88px; height: 88px; }
.lb-podium-card--1 .lb-pod-ring        { inset: -4px; }
.lb-podium-card--2 .lb-pod-avatar-wrap,
.lb-podium-card--3 .lb-pod-avatar-wrap { width: 72px; height: 72px; }
.lb-podium-card--2 .lb-pod-ring,
.lb-podium-card--3 .lb-pod-ring        { inset: -4px; }

.lb-pod-img {
  width: 100%; height: 100%;
  border-radius: 50%;
  object-fit: cover;
  display: block;
  position: relative;
  z-index: 1;
}
.lb-pod-placeholder {
  width: 100%; height: 100%;
  border-radius: 50%;
  background: #1e2030;
  border: 2px solid rgba(255,255,255,0.1);
  display: flex; align-items: center; justify-content: center;
  font-size: 26px; font-weight: 800; color: #fff;
  position: relative; z-index: 1;
}
.lb-pod-level {
  position: absolute;
  bottom: -2px; right: -2px;
  background: #0d0f14;
  border: 1.5px solid rgba(255,255,255,0.12);
  border-radius: 10px;
  font-size: 10px; font-weight: 800; color: #ccc;
  padding: 2px 5px;
  z-index: 2;
  min-width: 24px; text-align: center;
}

.lb-pod-username {
  font-size: 14px; font-weight: 700; color: #fff;
  filter: blur(7px); user-select: none;
  text-align: center;
  max-width: 140px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
}
.lb-pod-username--me { filter: none; color: var(--lb-blue); }

.lb-pod-rank-badge {
  display: inline-flex; align-items: center; gap: 4px;
  padding: 3px 10px; border-radius: 20px;
  font-size: 11px; font-weight: 700;
}

.lb-pod-hours {
  font-size: 20px; font-weight: 800;
  color: var(--lb-gold); line-height: 1;
}
.lb-podium-card--1 .lb-pod-hours { font-size: 24px; }
.lb-pod-hours-lbl {
  font-size: 10px; color: #555;
  text-transform: uppercase; letter-spacing: 0.6px;
  margin-top: 1px;
}

/* 
   TABLEAUX RANKINGS
 */
.lb-rankings {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20px;
}
@media (max-width: 720px) {
  .lb-rankings { grid-template-columns: 1fr; }
  .lb-podium   { flex-direction: column; align-items: center; }
  .lb-podium-card--1,
  .lb-podium-card--2,
  .lb-podium-card--3 { flex: 0 0 auto; width: 100%; max-width: 280px; }
  /* Ordre mobile : 1er en haut, puis 2e, puis 3e */
  .lb-podium-card--1 { order: 1; }
  .lb-podium-card--2 { order: 2; }
  .lb-podium-card--3 { order: 3; }

}

.lb-ranking-block {
  background: #111318;
  border: 1px solid rgba(255,255,255,0.07);
  border-radius: 16px;
  overflow: hidden;
}
.lb-ranking-header {
  padding: 16px 20px 12px;
  border-bottom: 1px solid rgba(255,255,255,0.06);
  display: flex; align-items: center; gap: 10px;
}
.lb-ranking-icon { font-size: 18px; }
.lb-ranking-title { font-size: 14px; font-weight: 800; color: #fff; margin: 0; }

/* TABS / Boutons d'onglets */
.lb-tabs {
  display: flex;
  gap: 12px;
  margin-bottom: 24px;
  border-bottom: 1px solid rgba(255,255,255,0.06);
}

.lb-tab-btn {
  background: none;
  border: none;
  padding: 12px 20px;
  font-size: 14px;
  font-weight: 700;
  color: #888;
  cursor: pointer;
  transition: all 0.2s ease;
  border-bottom: 2px solid transparent;
  margin-bottom: -1px;
}

.lb-tab-btn:hover {
  color: #bbb;
}

.lb-tab-btn--active {
  color: var(--lb-blue);
  border-bottom-color: var(--lb-blue);
}

/* Vues des classements */
.lb-ranking-view {
  display: none;
}

.lb-ranking-view--active {
  display: block;
}

.lb-row {
  display: flex; align-items: center; gap: 12px;
  padding: 10px 18px;
  border-bottom: 1px solid rgba(255,255,255,0.04);
  transition: background 0.15s ease;
}
.lb-row:last-child { border-bottom: none; }
.lb-row:hover { background: rgba(255,255,255,0.03); }

.lb-row--me {
  background: rgba(59,130,246,0.08) !important;
  border-left: 3px solid var(--lb-blue);
  padding-left: 15px;
}
.lb-row--me .lb-row-name { filter: none; color: var(--lb-blue); }
.lb-row--me .lb-pos-n    { color: var(--lb-blue); font-weight: 800; }

.lb-row-sep {
  display: flex; align-items: center; gap: 8px;
  padding: 6px 18px;
  border-top: 1px dashed rgba(255,255,255,0.07);
  pointer-events: none;
}
.lb-row-sep-label { font-size: 10px; color: #444; text-transform: uppercase; letter-spacing: 0.6px; white-space: nowrap; }
.lb-row-sep-dots  { font-size: 11px; color: #2a2a2a; letter-spacing: 3px; flex: 1; text-align: center; }

.lb-pos       { width: 28px; text-align: center; font-size: 13px; font-weight: 800; flex-shrink: 0; }
.lb-pos-1     { font-size: 20px; }
.lb-pos-2     { font-size: 18px; }
.lb-pos-3     { font-size: 16px; }
.lb-pos-n     { color: #444; font-size: 12px; }

.lb-row-avatar-wrap {
  position: relative; width: 40px; height: 40px; flex-shrink: 0;
  overflow: visible;
  will-change: filter;
}
.lb-row-ring {
  position: absolute; inset: -4px; border-radius: 50%;
  background: transparent;
  -webkit-mask: radial-gradient(farthest-side, transparent calc(100% - 3px), #fff calc(100% - 3px));
  mask: radial-gradient(farthest-side, transparent calc(100% - 3px), #fff calc(100% - 3px));
  animation: rank-ring-breathe 3.5s ease-in-out infinite;
  pointer-events: none;
}
.lb-row-avatar {
  width: 40px; height: 40px; border-radius: 50%;
  object-fit: cover; display: block; position: relative; z-index: 1;
}
.lb-row-placeholder {
  width: 40px; height: 40px; border-radius: 50%;
  background: #1e2030; border: 1.5px solid rgba(255,255,255,0.1);
  display: flex; align-items: center; justify-content: center;
  font-size: 14px; font-weight: 800; color: #fff;
  position: relative; z-index: 1;
}

.lb-row-info { flex: 1; min-width: 0; display: flex; flex-direction: column; gap: 2px; }
.lb-row-name {
  font-size: 13px; font-weight: 700; color: #fff;
  filter: blur(7px); user-select: none;
  white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
}
.lb-row-meta { font-size: 11px; color: #555; }

.lb-row-stat      { flex-shrink: 0; text-align: right; }
.lb-row-stat-main { font-size: 14px; font-weight: 800; color: var(--lb-gold); line-height: 1; }
.lb-row-stat-sub  { font-size: 10px; color: #555; margin-top: 1px; }
.lb-row-level     { font-size: 11px; font-weight: 700; padding: 2px 7px; border-radius: 8px; }

/*  Loader / Erreur  */
.lb-loading {
  display: flex; flex-direction: column; align-items: center;
  justify-content: center; gap: 12px; padding: 80px 20px; color: #555; font-size: 14px;
}
.lb-spinner {
  width: 32px; height: 32px;
  border: 3px solid rgba(59,130,246,0.2);
  border-top-color: var(--lb-blue);
  border-radius: 50%;
  animation: lb-spin 0.8s linear infinite;
}
@keyframes lb-spin { to { transform: rotate(360deg); } }
.lb-error { text-align: center; padding: 80px 20px; color: #555; }
.lb-error-icon { font-size: 36px; margin-bottom: 10px; }
</style>

<div class="lb-page">

  <div class="lb-header">
    <h1 class="lb-title">&#x1F3C6; Classement</h1>
    <p class="lb-subtitle">Top membres du serveur &mdash; heures de visionnage &amp; niveaux</p>
    <div class="lb-refresh-timer" id="lbRefreshTimer"></div>
  </div>

  <div class="lb-loading" id="lbLoading">
    <div class="lb-spinner"></div>
    <span>Chargement du classement&hellip;</span>
  </div>

  <div id="lbContent" style="display:none">

    <!-- Boutons d'onglets -->
    <div class="lb-tabs">
      <button class="lb-tab-btn lb-tab-btn--active" id="tabLevel">⭐ Par Niveau</button>
      <button class="lb-tab-btn" id="tabHours">🎬 Plus d'heures</button>
    </div>

    <!-- Classement par Niveau -->
    <div class="lb-ranking-view lb-ranking-view--active" id="viewLevel">
      <div id="rankLevelList"></div>
    </div>

    <!-- Classement par Heures -->
    <div class="lb-ranking-view" id="viewHours">
      <div id="rankHoursList"></div>
    </div>

  </div>

  <div class="lb-error" id="lbError" style="display:none">
    <div class="lb-error-icon">&#x1F625;</div>
    <p>Impossible de charger le classement.</p>
  </div>

</div>

<script>
(function () {
  const ME = '<%= user.username %>';

  function _grad(c) {
    return 'conic-gradient(from -90deg, ' + c + '2e 0deg, ' + c + ' 90deg, ' + c + 'cc 180deg, ' + c + ' 270deg, ' + c + '2e 360deg)';
  }
  function hrs(h) { return Math.round(h) + 'h'; }

  function podiumCard(user, rank) {
    var isMe     = user.username === ME;
    var medals   = ['<%= "" %>', '<%= "" %>', '<%= "" %>'];
    var medal    = rank === 1 ? '\uD83E\uDD47' : rank === 2 ? '\uD83E\uDD48' : '\uD83E\uDD49';
    var initials = (user.username || '?').charAt(0).toUpperCase();
    // Augmenter l'intensité du glow sur mobile
    var isMobile = window.innerWidth <= 720;
    var glow = isMobile
      ? 'drop-shadow(0 0 16px ' + user.rank.color + 'ff) drop-shadow(0 0 32px ' + user.rank.color + '88) drop-shadow(0 0 48px ' + user.rank.color + '44)'
      : 'drop-shadow(0 0 9px ' + user.rank.color + 'cc) drop-shadow(0 0 22px ' + user.rank.color + '55)';
    var imgPart  = user.thumb
      ? '<img src="' + user.thumb + '" class="lb-pod-img" alt="" loading="lazy" style="filter:' + glow + '" onerror="this.style.display=\'none\';this.nextElementSibling.style.display=\'flex\'">'
        + '<div class="lb-pod-placeholder" style="display:none;filter:' + glow + '">' + initials + '</div>'
      : '<div class="lb-pod-placeholder" style="filter:' + glow + '">' + initials + '</div>';

    return '<div class="lb-podium-card lb-podium-card--' + rank + '">'
      + '<span class="lb-podium-medal">' + medal + '</span>'
      + '<div class="lb-pod-avatar-wrap">'
        + '<div class="lb-pod-ring" style="background:' + _grad(user.rank.color) + '"></div>'
        + imgPart
        + '<div class="lb-pod-level">' + user.level + '</div>'
      + '</div>'
      + '<div class="lb-pod-username' + (isMe ? ' lb-pod-username--me' : '') + '">' + user.username + '</div>'
      + '<span class="lb-pod-rank-badge" style="background:' + user.rank.bgColor + ';color:' + user.rank.color + ';border:1px solid ' + user.rank.borderColor + '40">'
        + user.rank.icon + ' ' + user.rank.name
      + '</span>'
      + '<div class="lb-pod-hours">Nv.\u00a0' + user.level + '</div>'
      + '<div class="lb-pod-hours-lbl">' + user.totalXp + '\u00a0XP</div>'
    + '</div>';
  }

  function rankRow(user, pos, mode) {
    var isMe     = user.username === ME;
    var initials = (user.username || '?').charAt(0).toUpperCase();
    // Augmenter l'intensité du glow sur mobile
    var isMobile = window.innerWidth <= 720;
    var glow = isMobile
      ? 'drop-shadow(0 0 14px ' + user.rank.color + 'ff) drop-shadow(0 0 28px ' + user.rank.color + '88) drop-shadow(0 0 40px ' + user.rank.color + '44)'
      : 'drop-shadow(0 0 8px ' + user.rank.color + 'cc) drop-shadow(0 0 18px ' + user.rank.color + '55)';
    var posHtml;
    if      (pos === 0) posHtml = '<span class="lb-pos lb-pos-1">\uD83E\uDD47</span>';
    else if (pos === 1) posHtml = '<span class="lb-pos lb-pos-2">\uD83E\uDD48</span>';
    else if (pos === 2) posHtml = '<span class="lb-pos lb-pos-3">\uD83E\uDD49</span>';
    else                posHtml = '<span class="lb-pos lb-pos-n">#' + (pos + 1) + '</span>';

    var statHtml = mode === 'hours'
      ? '<div class="lb-row-stat"><div class="lb-row-stat-main">' + hrs(user.totalHours) + '</div><div class="lb-row-stat-sub">heures</div></div>'
      : '<div class="lb-row-stat"><div class="lb-row-level" style="background:' + user.rank.bgColor + ';color:' + user.rank.color + '">Nv.\u00a0' + user.level + '</div></div>';

    var imgPart = user.thumb
      ? '<img src="' + user.thumb + '" class="lb-row-avatar" width="40" height="40" alt="" loading="lazy" style="filter:' + glow + '" onerror="this.style.display=\'none\';this.nextElementSibling.style.display=\'flex\'">'
        + '<div class="lb-row-placeholder" style="display:none;filter:' + glow + '">' + initials + '</div>'
      : '<div class="lb-row-placeholder" style="filter:' + glow + '">' + initials + '</div>';

    return '<div class="lb-row' + (isMe ? ' lb-row--me' : '') + '">'
      + posHtml
      + '<div class="lb-row-avatar-wrap">'
        + '<div class="lb-row-ring" style="background:' + _grad(user.rank.color) + '"></div>'
        + imgPart
      + '</div>'
      + '<div class="lb-row-info">'
        + '<div class="lb-row-name">' + user.username + '</div>'
        + '<div class="lb-row-meta" style="color:' + user.rank.color + ';font-weight:700">' + user.rank.icon + ' ' + user.rank.name + '</div>'
      + '</div>'
      + statHtml
    + '</div>';
  }

  function renderTable(list, containerId, mode, startFrom) {
    startFrom = startFrom || 0;
    var slice = list.slice(startFrom, startFrom + 10);
    var myPos = list.findIndex(function(u) { return u.username === ME; });
    var html  = slice.map(function(u, i) { return rankRow(u, i + startFrom, mode); }).join('');
    // Afficher la position de l'user s'il est en dessous du tableau visible
    if (myPos >= startFrom + 10) {
      html += '<div class="lb-row-sep"><span class="lb-row-sep-label">Votre position</span><span class="lb-row-sep-dots">\u00b7 \u00b7 \u00b7</span></div>';
      html += rankRow(list[myPos], myPos, mode);
    }
    document.getElementById(containerId).innerHTML = html;
  }

  function renderPodium(byHours) {
    var top3 = byHours.slice(0, 3);
    // Ordre visuel podium : 2e (gauche) - 1er (centre) - 3e (droite)
    var visual = [top3[1], top3[0], top3[2]];
    var ranks  = [2, 1, 3];
    var html   = '';
    for (var i = 0; i < visual.length; i++) {
      if (visual[i]) html += podiumCard(visual[i], ranks[i]);
    }
    document.getElementById('lbPodium').innerHTML = html;
  }

  // Gestion des onglets
  var tabLevel = document.getElementById('tabLevel');
  var tabHours = document.getElementById('tabHours');
  var viewLevel = document.getElementById('viewLevel');
  var viewHours = document.getElementById('viewHours');

  tabLevel.addEventListener('click', function() {
    tabLevel.classList.add('lb-tab-btn--active');
    tabHours.classList.remove('lb-tab-btn--active');
    viewLevel.classList.add('lb-ranking-view--active');
    viewHours.classList.remove('lb-ranking-view--active');
  });

  tabHours.addEventListener('click', function() {
    tabHours.classList.add('lb-tab-btn--active');
    tabLevel.classList.remove('lb-tab-btn--active');
    viewHours.classList.add('lb-ranking-view--active');
    viewLevel.classList.remove('lb-ranking-view--active');
  });

  var bp = (window.APP_BASE_PATH || '');
  var lastRefreshTime = null;

  function updateTimer() {
    if (!lastRefreshTime) return;
    var now = Date.now();
    var diff = Math.floor((now - lastRefreshTime) / 1000);
    var text;
    if (diff < 60) {
      text = 'Données actualisées il y a ' + diff + 's';
    } else {
      var minutes = Math.floor(diff / 60);
      text = 'Données actualisées il y a ' + minutes + 'm';
    }
    var timerEl = document.getElementById('lbRefreshTimer');
    if (timerEl) timerEl.textContent = text;
  }

  fetch(bp + '/api/classement')
    .then(function(r) { return r.ok ? r.json() : Promise.reject(r.status); })
    .then(function(data) {
      if (data.lastRefresh) {
        lastRefreshTime = new Date(data.lastRefresh).getTime();
        updateTimer();
        setInterval(updateTimer, 1000);
      }
      document.getElementById('lbLoading').style.display = 'none';
      document.getElementById('lbContent').style.display = 'block';
      renderTable(data.byLevel, 'rankLevelList', 'level', 0);
      renderTable(data.byHours, 'rankHoursList', 'hours', 0);
    })
    .catch(function() {
      document.getElementById('lbLoading').style.display = 'none';
      document.getElementById('lbError').style.display   = 'block';
    });
})();
</script>
