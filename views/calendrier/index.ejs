<!DOCTYPE html>
<html lang="fr">
<head>
  <style>
    :root {
      --bg0: #0e0e0e;
      --bg1: #121212;
      --bg2: #1f1f1f;
      --panel: #181818;
      --line: #222;
      --text: #fff;
      --muted: #bbb;
      --plex: #e5a00d;
      --plex2: #ffb800;
    }

    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      background: var(--bg1);
      color: var(--text);
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
      font-size: 13px;
      line-height: 1.5;
    }

    .cal-page {
      max-width: 1400px;
      margin: 0 auto;
      padding: 20px;
    }

    .cal-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 30px;
      flex-wrap: wrap;
      gap: 20px;
    }

    .cal-header h2 {
      font-size: 24px;
      font-weight: 700;
      flex: 1;
      min-width: 200px;
    }

    .cal-nav-buttons {
      display: flex;
      gap: 12px;
    }

    .cal-nav-buttons button {
      background: rgba(255, 255, 255, 0.08);
      border: 1px solid rgba(255, 255, 255, 0.15);
      color: var(--text);
      padding: 8px 14px;
      border-radius: 8px;
      cursor: pointer;
      font-size: 16px;
      font-weight: 600;
      transition: all 0.2s ease;
    }

    .cal-nav-buttons button:hover {
      background: rgba(255, 255, 255, 0.12);
      border-color: rgba(255, 255, 255, 0.25);
    }

    .cal-toolbar {
      display: flex;
      gap: 12px;
      flex-wrap: wrap;
      align-items: center;
    }

    .cal-toolbar-sep {
      width: 1px;
      height: 24px;
      background: rgba(255, 255, 255, 0.15);
    }

    .cal-toolbar button {
      background: transparent;
      border: 1px solid rgba(255, 255, 255, 0.2);
      color: var(--muted);
      padding: 6px 12px;
      border-radius: 6px;
      cursor: pointer;
      font-size: 12px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      transition: all 0.2s ease;
    }

    .cal-toolbar button:hover {
      background: rgba(255, 255, 255, 0.05);
      color: var(--text);
    }

    .cal-toolbar button.active {
      background: rgba(229, 160, 13, 0.15);
      border-color: var(--plex);
      color: var(--plex);
    }

    .cal-loading {
      text-align: center;
      padding: 40px 20px;
      color: var(--muted);
    }

    .cal-spinner {
      display: inline-block;
      width: 40px;
      height: 40px;
      border: 3px solid rgba(229, 160, 13, 0.3);
      border-top: 3px solid var(--plex);
      border-radius: 50%;
      animation: spin 0.8s linear infinite;
      margin-bottom: 12px;
    }

    @keyframes spin {
      from { transform: rotate(0deg); }
      to { transform: rotate(360deg); }
    }

    .cal-error {
      background: rgba(255, 69, 69, 0.1);
      border: 1px solid rgba(255, 69, 69, 0.3);
      border-radius: 12px;
      padding: 20px;
      color: #ff6b6b;
      margin-bottom: 20px;
    }

    .cal-empty {
      text-align: center;
      padding: 60px 20px;
      color: var(--muted);
      font-size: 16px;
    }

    /* ========== VUE SEMAINE ========== */
    .cal-grid-week {
      display: grid;
      grid-template-columns: repeat(7, 1fr);
      gap: 8px;
      margin-bottom: 20px;
    }

    .cal-day-col {
      background: linear-gradient(135deg, rgba(255, 255, 255, 0.04), rgba(255, 255, 255, 0.01));
      border: 1px solid var(--line);
      border-radius: 12px;
      padding: 8px;
      min-height: 420px;
      overflow-y: auto;
    }

    .cal-day-header {
      text-align: center;
      padding: 8px 0;
      font-size: 11px;
      color: var(--muted);
      border-bottom: 1px solid rgba(255, 255, 255, 0.1);
      margin-bottom: 8px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }

    .cal-day-header.today {
      color: var(--plex);
      font-weight: 700;
    }

    .cal-event {
      padding: 6px 8px;
      border-radius: 8px;
      margin-bottom: 5px;
      font-size: 11px;
      background: rgba(255, 255, 255, 0.04);
      border-left: 3px solid var(--plex);
      cursor: pointer;
      transition: all 0.2s ease;
    }

    .cal-event:hover {
      background: rgba(255, 255, 255, 0.08);
      border-left-width: 4px;
    }

    .cal-event--episode {
      border-left-color: #00D9FF;
    }

    .cal-event--episode:hover {
      background: rgba(0, 217, 255, 0.1);
    }

    .cal-event-time {
      font-size: 9px;
      color: var(--muted);
      display: block;
      margin-bottom: 2px;
    }

    .cal-event-title {
      font-weight: 600;
      color: var(--text);
      margin: 2px 0;
      line-height: 1.3;
      word-break: break-word;
    }

    .cal-event-sub {
      font-size: 9px;
      color: var(--muted);
      margin-top: 2px;
    }

    .cal-badge {
      display: inline-block;
      margin-top: 4px;
      border-radius: 4px;
      padding: 2px 6px;
      font-size: 9px;
      font-weight: 600;
    }

    .cal-badge--available {
      background: rgba(46, 204, 113, 0.18);
      color: #2ECC71;
      border: 1px solid rgba(46, 204, 113, 0.4);
    }

    .cal-badge--unreleased {
      background: rgba(255, 255, 255, 0.06);
      color: #888;
      border: 1px solid rgba(255, 255, 255, 0.12);
    }

    .cal-more {
      font-size: 10px;
      color: var(--plex);
      cursor: pointer;
      margin-top: 6px;
      font-weight: 600;
      padding: 4px 6px;
      border-radius: 4px;
      transition: all 0.2s ease;
    }

    .cal-more:hover {
      background: rgba(229, 160, 13, 0.15);
    }

    /* ========== VUE MOIS ========== */
    .cal-grid-month {
      display: grid;
      grid-template-columns: repeat(7, 1fr);
      gap: 8px;
      margin-bottom: 20px;
    }

    .cal-month-cell {
      background: linear-gradient(135deg, rgba(255, 255, 255, 0.04), rgba(255, 255, 255, 0.01));
      border: 1px solid var(--line);
      border-radius: 8px;
      padding: 6px;
      min-height: 80px;
      position: relative;
    }

    .cal-month-cell.other-month {
      opacity: 0.5;
    }

    .cal-month-cell.today {
      background: rgba(229, 160, 13, 0.08);
      border-color: rgba(229, 160, 13, 0.3);
    }

    .cal-month-day {
      font-size: 10px;
      font-weight: 700;
      color: var(--text);
      margin-bottom: 4px;
    }

    .cal-month-events {
      font-size: 9px;
      line-height: 1.2;
    }

    .cal-month-event-mini {
      color: var(--muted);
      margin-bottom: 2px;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }

    .cal-month-event-mini.available {
      color: #2ECC71;
    }

    /* ========== VUE JOUR ========== */
    .cal-day-detail {
      max-width: 600px;
    }

    .cal-day-detail-header {
      font-size: 18px;
      font-weight: 700;
      margin-bottom: 20px;
      padding-bottom: 12px;
      border-bottom: 1px solid var(--line);
    }

    .cal-event-card {
      background: linear-gradient(135deg, rgba(255, 255, 255, 0.04), rgba(255, 255, 255, 0.01));
      border: 1px solid var(--line);
      border-radius: 10px;
      padding: 12px;
      margin-bottom: 12px;
      display: flex;
      gap: 12px;
      transition: all 0.2s ease;
    }

    .cal-event-card:hover {
      background: linear-gradient(135deg, rgba(255, 255, 255, 0.06), rgba(255, 255, 255, 0.02));
      border-color: rgba(255, 255, 255, 0.2);
    }

    .cal-event-card-thumb {
      flex-shrink: 0;
      width: 50px;
      height: 75px;
      background: rgba(255, 255, 255, 0.05);
      border-radius: 6px;
      overflow: hidden;
    }

    .cal-event-card-thumb img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    .cal-event-card-content {
      flex: 1;
      min-width: 0;
    }

    .cal-event-card-title {
      font-weight: 600;
      font-size: 13px;
      color: var(--text);
      margin-bottom: 4px;
    }

    .cal-event-card-sub {
      font-size: 11px;
      color: var(--muted);
      margin-bottom: 6px;
    }

    .cal-event-card-meta {
      font-size: 10px;
      color: var(--muted);
      margin-bottom: 6px;
    }

    .cal-event-card-footer {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
    }

    /* ========== VUE LISTE ========== */
    .cal-table {
      width: 100%;
      border-collapse: collapse;
      background: rgba(255, 255, 255, 0.02);
      border: 1px solid var(--line);
      border-radius: 10px;
      overflow: hidden;
    }

    .cal-table thead {
      background: rgba(255, 255, 255, 0.05);
      border-bottom: 1px solid var(--line);
    }

    .cal-table th {
      padding: 10px;
      text-align: left;
      font-size: 11px;
      font-weight: 700;
      color: var(--muted);
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }

    .cal-table td {
      padding: 10px;
      border-bottom: 1px solid rgba(255, 255, 255, 0.05);
      font-size: 12px;
    }

    .cal-table tbody tr:hover {
      background: rgba(229, 160, 13, 0.05);
    }

    .cal-table-type {
      font-weight: 600;
      width: 60px;
    }

    .cal-table-available {
      width: 100px;
    }

    /* ========== RESPONSIVE ========== */
    @media (max-width: 1024px) {
      .cal-grid-week {
        grid-template-columns: repeat(4, 1fr);
      }
    }

    @media (max-width: 720px) {
      .cal-header {
        flex-direction: column;
        align-items: flex-start;
      }

      .cal-header h2 {
        width: 100%;
      }

      .cal-toolbar {
        width: 100%;
      }

      .cal-grid-week {
        grid-template-columns: 1fr;
      }

      .cal-grid-month {
        grid-template-columns: repeat(7, 1fr);
      }

      .cal-month-cell {
        min-height: 60px;
        padding: 4px;
      }

      .cal-month-day {
        font-size: 9px;
        margin-bottom: 2px;
      }

      .cal-month-event-mini {
        font-size: 8px;
      }

      .cal-table {
        font-size: 11px;
      }

      .cal-table th, .cal-table td {
        padding: 8px;
      }

      .cal-table-type {
        width: auto;
      }
    }
  </style>
</head>
<body data-user-id="<%= user.id %>">
<section class="cal-page">
  <div class="cal-header">
    <div class="cal-nav-buttons">
      <button id="calPrev">‹</button>
      <h2 id="calTitle">Chargement...</h2>
      <button id="calNext">›</button>
    </div>
    <div class="cal-toolbar">
      <button id="calBtnRefresh">REFRESH</button>
      <div class="cal-toolbar-sep"></div>
      <button id="calBtnMois" class="cal-view-btn">MOIS</button>
      <button id="calBtnSemaine" class="cal-view-btn active">SEMAINE</button>
      <button id="calBtnJour" class="cal-view-btn">JOUR</button>
      <button id="calBtnListe" class="cal-view-btn">LISTE</button>
    </div>
  </div>

  <div id="calView">
    <div class="cal-loading">
      <div class="cal-spinner"></div>
      <div>Chargement du calendrier...</div>
    </div>
  </div>
</section>

<script>
  const basePath = '<%= basePath || "" %>';
  const dateFormat = new Intl.DateTimeFormat('fr-FR', { month: 'short', day: 'numeric', year: 'numeric' });
  const dayFormat = new Intl.DateTimeFormat('fr-FR', { weekday: 'short', day: 'numeric', month: 'numeric' });
  const monthFormat = new Intl.DateTimeFormat('fr-FR', { month: 'long', year: 'numeric' });

  let currentDate = new Date();
  let currentView = 'semaine';
  let allEvents = [];
  let eventsByDate = {};

  const elPrev = document.getElementById('calPrev');
  const elNext = document.getElementById('calNext');
  const elTitle = document.getElementById('calTitle');
  const elView = document.getElementById('calView');
  const elBtnRefresh = document.getElementById('calBtnRefresh');
  const elBtnSemaine = document.getElementById('calBtnSemaine');
  const elBtnMois = document.getElementById('calBtnMois');
  const elBtnJour = document.getElementById('calBtnJour');
  const elBtnListe = document.getElementById('calBtnListe');

  // ========== HELPERS ==========

  function todayISO() {
    const d = new Date();
    return d.toISOString().slice(0, 10);
  }

  function dateToISO(d) {
    return d.toISOString().slice(0, 10);
  }

  function isoToDate(iso) {
    return new Date(iso + 'T00:00:00Z');
  }

  function getWeekStart(d) {
    const copy = new Date(d);
    const day = copy.getDay();
    const diff = copy.getDate() - day + (day === 0 ? -6 : 1);
    copy.setDate(diff);
    copy.setHours(0, 0, 0, 0);
    return copy;
  }

  function getWeekEnd(d) {
    const copy = new Date(d);
    const day = copy.getDay();
    const diff = copy.getDate() - day + (day === 0 ? 0 : 7);
    copy.setDate(diff);
    copy.setHours(23, 59, 59, 999);
    return copy;
  }

  function getMonthStart(d) {
    const copy = new Date(d.getFullYear(), d.getMonth(), 1);
    copy.setHours(0, 0, 0, 0);
    return copy;
  }

  function getMonthEnd(d) {
    const copy = new Date(d.getFullYear(), d.getMonth() + 1, 0);
    copy.setHours(23, 59, 59, 999);
    return copy;
  }

  function formatDateRange(start, end) {
    const s = dateFormat.format(start);
    const e = dateFormat.format(end);
    return `${s.toUpperCase()} – ${e.toUpperCase()}`;
  }

  function formatDay(iso) {
    const d = isoToDate(iso);
    const day = dayFormat.format(d);
    const isToday = iso === todayISO();
    return `${day[0].toUpperCase() + day.slice(1)}` + (isToday ? ' (aujourd\'hui)' : '');
  }

  // ========== FETCH & CACHE ==========

  async function loadCalendarData() {
    const start = dateToISO(getCalendarStart());
    const end = dateToISO(getCalendarEnd());

    try {
      const resp = await fetch(`${basePath}/api/calendar?start=${start}&end=${end}`);
      if (!resp.ok) throw new Error(`HTTP ${resp.status}`);

      const { events } = await resp.json();
      allEvents = events || [];
      buildEventsByDate();
      render();
    } catch (err) {
      console.error('Calendar fetch failed:', err);
      elView.innerHTML = `<div class="cal-error">❌ Erreur: ${err.message}</div>`;
    }
  }

  function buildEventsByDate() {
    eventsByDate = {};
    allEvents.forEach(evt => {
      if (!eventsByDate[evt.date]) eventsByDate[evt.date] = [];
      eventsByDate[evt.date].push(evt);
    });
  }

  function getCalendarStart() {
    return currentView === 'mois' ? getMonthStart(currentDate) : getWeekStart(currentDate);
  }

  function getCalendarEnd() {
    return currentView === 'mois' ? getMonthEnd(currentDate) : getWeekEnd(currentDate);
  }

  // ========== RENDER ==========

  function render() {
    switch (currentView) {
      case 'semaine': renderSemaine(); break;
      case 'mois': renderMois(); break;
      case 'jour': renderJour(); break;
      case 'liste': renderListe(); break;
    }
  }

  function renderSemaine() {
    const start = getWeekStart(currentDate);
    const end = getWeekEnd(currentDate);
    elTitle.textContent = formatDateRange(start, end);

    let html = '<div class="cal-grid-week">';
    for (let i = 0; i < 7; i++) {
      const d = new Date(start);
      d.setDate(d.getDate() + i);
      const iso = dateToISO(d);
      const isToday = iso === todayISO();
      const evts = eventsByDate[iso] || [];

      html += `<div class="cal-day-col">
        <div class="cal-day-header ${isToday ? 'today' : ''}">
          ${dayFormat.format(d).toUpperCase()}
        </div>`;

      evts.slice(0, 4).forEach(evt => {
        html += renderEventCard(evt);
      });

      if (evts.length > 4) {
        html += `<div class="cal-more">+${evts.length - 4} en plus</div>`;
      }

      html += '</div>';
    }
    html += '</div>';
    elView.innerHTML = html;
  }

  function renderMois() {
    const start = getMonthStart(currentDate);
    const end = getMonthEnd(currentDate);
    elTitle.textContent = monthFormat.format(currentDate).toUpperCase();

    const firstDay = start.getDay();
    const daysInMonth = new Date(start.getFullYear(), start.getMonth() + 1, 0).getDate();

    let html = '<div class="cal-grid-month">';

    // Headers jours
    const dayHeaders = ['LUN', 'MAR', 'MER', 'JEU', 'VEN', 'SAM', 'DIM'];
    dayHeaders.forEach(d => {
      html += `<div style="text-align:center; font-weight:700; color:var(--muted); padding:8px; font-size:11px;">${d}</div>`;
    });

    // Cellules vides avant le 1er
    for (let i = 1; i < firstDay; i++) {
      html += '<div class="cal-month-cell other-month"></div>';
    }

    // Jours du mois
    for (let day = 1; day <= daysInMonth; day++) {
      const d = new Date(start.getFullYear(), start.getMonth(), day);
      const iso = dateToISO(d);
      const isToday = iso === todayISO();
      const evts = eventsByDate[iso] || [];

      html += `<div class="cal-month-cell ${isToday ? 'today' : ''}">
        <div class="cal-month-day">${day}</div>
        <div class="cal-month-events">`;

      evts.slice(0, 3).forEach(evt => {
        const cls = evt.available ? 'available' : '';
        html += `<div class="cal-month-event-mini ${cls}">• ${evt.title}</div>`;
      });

      if (evts.length > 3) {
        html += `<div class="cal-month-event-mini">+${evts.length - 3}</div>`;
      }

      html += '</div></div>';
    }

    // Cellules vides après le dernier jour
    const totalCells = 42;
    const filledCells = (firstDay - 1) + daysInMonth;
    for (let i = filledCells; i < totalCells; i++) {
      html += '<div class="cal-month-cell other-month"></div>';
    }

    html += '</div>';
    elView.innerHTML = html;
  }

  function renderJour() {
    const iso = dateToISO(currentDate);
    const evts = eventsByDate[iso] || [];

    elTitle.textContent = formatDay(iso);

    if (evts.length === 0) {
      elView.innerHTML = '<div class="cal-empty">Aucun événement ce jour-là</div>';
      return;
    }

    let html = '<div class="cal-day-detail">';
    evts.forEach(evt => {
      html += `<div class="cal-event-card">
        ${evt.thumb ? `<div class="cal-event-card-thumb"><img src="${evt.thumb}" alt="${evt.title}"></div>` : ''}
        <div class="cal-event-card-content">
          <div class="cal-event-card-title">${evt.title}</div>
          ${evt.subtitle ? `<div class="cal-event-card-sub">${evt.subtitle}</div>` : ''}
          <div class="cal-event-card-meta">
            ${evt.runtime ? `${evt.runtime} min` : ''} • ${evt.source === 'radarr' ? '🎬 Film' : '📺 Série'}
          </div>
          <div class="cal-event-card-footer">
            <span class="cal-badge ${evt.available ? 'cal-badge--available' : 'cal-badge--unreleased'}">
              ${evt.available ? '✓ Disponible' : '○ Non dispo'}
            </span>
          </div>
        </div>
      </div>`;
    });
    html += '</div>';
    elView.innerHTML = html;
  }

  function renderListe() {
    elTitle.textContent = 'Liste des sorties';

    if (allEvents.length === 0) {
      elView.innerHTML = '<div class="cal-empty">Aucun événement trouvé</div>';
      return;
    }

    let html = `<table class="cal-table">
      <thead>
        <tr>
          <th>Date</th>
          <th class="cal-table-type">Type</th>
          <th>Titre</th>
          <th>Épisode</th>
          <th style="width:60px;">Durée</th>
          <th class="cal-table-available">Disponible</th>
        </tr>
      </thead>
      <tbody>`;

    allEvents.forEach(evt => {
      html += `<tr>
        <td>${dayFormat.format(isoToDate(evt.date))}</td>
        <td class="cal-table-type">${evt.type === 'movie' ? '🎬' : '📺'}</td>
        <td><strong>${evt.title}</strong></td>
        <td>${evt.subtitle || '—'}</td>
        <td>${evt.runtime || '—'}</td>
        <td>${evt.available ? '✓ Oui' : '○ Non'}</td>
      </tr>`;
    });

    html += '</tbody></table>';
    elView.innerHTML = html;
  }

  function renderEventCard(evt) {
    return `<div class="cal-event cal-event--${evt.type === 'movie' ? 'movie' : 'episode'}">
      <span class="cal-event-time">${evt.type === 'movie' ? '🎬' : '📺'}</span>
      <div class="cal-event-title">${evt.title}</div>
      ${evt.subtitle ? `<div class="cal-event-sub">${evt.subtitle}</div>` : ''}
      <span class="cal-badge ${evt.available ? 'cal-badge--available' : 'cal-badge--unreleased'}">
        ${evt.available ? '✓ Dispo' : '○ Non'}
      </span>
    </div>`;
  }

  // ========== EVENT LISTENERS ==========

  elPrev.addEventListener('click', () => {
    if (currentView === 'jour') {
      currentDate.setDate(currentDate.getDate() - 1);
    } else if (currentView === 'mois') {
      currentDate.setMonth(currentDate.getMonth() - 1);
    } else {
      currentDate.setDate(currentDate.getDate() - 7);
    }
    loadCalendarData();
  });

  elNext.addEventListener('click', () => {
    if (currentView === 'jour') {
      currentDate.setDate(currentDate.getDate() + 1);
    } else if (currentView === 'mois') {
      currentDate.setMonth(currentDate.getMonth() + 1);
    } else {
      currentDate.setDate(currentDate.getDate() + 7);
    }
    loadCalendarData();
  });

  elBtnRefresh.addEventListener('click', () => {
    loadCalendarData();
  });

  document.querySelectorAll('.cal-view-btn').forEach(btn => {
    btn.addEventListener('click', (e) => {
      document.querySelectorAll('.cal-view-btn').forEach(b => b.classList.remove('active'));
      e.target.classList.add('active');

      if (e.target === elBtnSemaine) currentView = 'semaine';
      else if (e.target === elBtnMois) currentView = 'mois';
      else if (e.target === elBtnJour) currentView = 'jour';
      else if (e.target === elBtnListe) currentView = 'liste';

      currentDate = new Date();
      loadCalendarData();
    });
  });

  // ========== INIT ==========
  loadCalendarData();
</script>
</body>
</html>
