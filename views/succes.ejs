<style>
  .badges-container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 24px 20px;
  }

  /* HEADER */
  .badges-header {
    margin-bottom: 24px;
  }

  .badges-header-top {
    display: flex;
    align-items: center;
    gap: 20px;
    margin-bottom: 15px;
  }

  .back-button {
    color: #a0a0a0;
    text-decoration: none;
    font-size: 14px;
    font-weight: 500;
    transition: all 0.3s ease;
    padding: 8px 16px;
    border-radius: 6px;
    border: 1px solid rgba(160, 160, 160, 0.3);
    display: inline-block;
  }
  <% if (typeof embed !== 'undefined' && embed) { %>
  /* ════ MODE EMBED — ID #badges-embed pour spécificité max ════ */
  #badges-embed {
    display: block !important;
    grid-template-columns: none !important;
    max-width: 100%;
    width: 100%;
    padding: 0 0 12px;
    box-sizing: border-box;
    overflow-x: hidden;
  }
  #badges-embed .badges-header-top { display: none; }
  #badges-embed .badges-header     { margin-bottom: 10px; }
  #badges-embed .badges-subtitle   { font-size: 11px; margin-bottom: 10px; }

  #badges-embed .badges-stats {
    display: flex;
    flex-direction: row;
    gap: 8px;
    margin-bottom: 14px;
  }
  #badges-embed .stat-box    { flex:1; padding: 9px 6px; }
  #badges-embed .stat-number { font-size: 17px; }
  #badges-embed .stat-label  { font-size: 9px; letter-spacing: 0.4px; }

  #badges-embed .achievements-section  { margin-bottom: 14px; }
  #badges-embed .category-header       { margin-bottom: 8px; padding-bottom: 6px; }
  #badges-embed .category-name         { font-size: 13px; }
  #badges-embed .category-icon         { font-size: 14px; }

  #badges-embed .achievements-grid {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 5px;
  }
  #badges-embed .achievement-card {
    border-radius: 10px;
  }
  #badges-embed .achievement-icon        { font-size: 20px; }
  #badges-embed .achievement-card:hover  { transform: none; }
  <% } %>

  .back-button:hover {
    color: #E5A00D;
    background: rgba(229, 160, 13, 0.1);
    border-color: rgba(229, 160, 13, 0.5);
  }

  .badges-title {
    font-size: 32px;
    font-weight: bold;
    color: #E5A00D;
    letter-spacing: 1px;
    margin: 0;
  }

  .badges-subtitle {
    font-size: 14px;
    color: #a0a0a0;
    margin: 0;
  }
  .badges-refresh-timer {
    margin-top: 8px;
    font-size: 12px;
    color: #7f8a98;
    font-style: italic;
  }

  /* STATS */
  .badges-stats {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
    gap: 12px;
    margin-bottom: 24px;
  }

  .stat-box {
    background: linear-gradient(135deg, rgba(139, 69, 19, 0.2), rgba(218, 165, 32, 0.1));
    border: 2px solid rgba(218, 165, 32, 0.3);
    border-radius: 10px;
    padding: 16px;
    text-align: center;
    backdrop-filter: blur(10px);
  }

  .stat-number {
    font-size: 28px;
    font-weight: bold;
    color: #E5A00D;
    display: block;
  }

  .stat-label {
    font-size: 11px;
    color: #a0a0a0;
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-top: 4px;
  }

  /* CATEGORIES */
  .achievements-section {
    margin-bottom: 32px;
    animation: fadeIn 0.5s ease;
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .category-header {
    display: flex;
    align-items: center;
    gap: 14px;
    margin-bottom: 14px;
    padding-bottom: 10px;
    border-bottom: 2px solid rgba(229, 160, 13, 0.2);
    transition: border-color 0.3s ease;
  }

  .category-header:hover {
    border-bottom-color: rgba(229, 160, 13, 0.4);
  }

  .category-icon {
    font-size: 24px;
    filter: drop-shadow(0 0 4px rgba(229, 160, 13, 0.3));
    transition: transform 0.3s ease;
  }

  .category-header:hover .category-icon {
    transform: scale(1.1);
  }

  .category-name {
    font-size: 18px;
    font-weight: 600;
    color: #fff;
    letter-spacing: 0.5px;
    text-transform: uppercase;
  }

  .achievements-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(64px, 1fr));
    gap: 10px;
    animation: gridSlideIn 0.4s ease;
  }

  @keyframes gridSlideIn {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }

  /* ACHIEVEMENT CARD — Glassmorphism design */
  .achievement-card {
    background: linear-gradient(135deg, rgba(255, 255, 255, 0.08), rgba(255, 255, 255, 0.02));
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border: 1.5px solid rgba(255, 255, 255, 0.15);
    border-radius: 16px;
    width: 100%;
    aspect-ratio: 1 / 1;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    position: relative;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    overflow: hidden;
  }

  .achievement-card:hover {
    transform: translateY(-6px) scale(1.08);
    border-color: rgba(255, 255, 255, 0.4);
    background: linear-gradient(135deg, rgba(255, 255, 255, 0.12), rgba(255, 255, 255, 0.05));
    box-shadow: 0 12px 30px rgba(0, 0, 0, 0.5), inset 0 1px 1px rgba(255, 255, 255, 0.2);
  }

  .achievement-card.locked {
    opacity: 0.5;
    border-color: rgba(255, 255, 255, 0.08);
  }

  .achievement-card.locked:hover {
    opacity: 0.65;
    transform: translateY(-3px) scale(1.04);
  }

  .achievement-card.locked .achievement-icon {
    filter: grayscale(100%) brightness(0.8);
  }

  /* Couleurs de bordure par catégorie avec gradients au survol */
  .achievement-card.unlocked.temporels  { border-color: #E67E22; }
  .achievement-card.unlocked.temporels:hover  { box-shadow: 0 0 20px #E67E22AA, 0 12px 30px rgba(0, 0, 0, 0.5); }

  .achievement-card.unlocked.activites  { border-color: #E74C3C; }
  .achievement-card.unlocked.activites:hover  { box-shadow: 0 0 20px #E74C3CAA, 0 12px 30px rgba(0, 0, 0, 0.5); }

  .achievement-card.unlocked.films      { border-color: #E67E22; }
  .achievement-card.unlocked.films:hover      { box-shadow: 0 0 20px #E67E22AA, 0 12px 30px rgba(0, 0, 0, 0.5); }

  .achievement-card.unlocked.series     { border-color: #3498DB; }
  .achievement-card.unlocked.series:hover     { box-shadow: 0 0 20px #3498DBAA, 0 12px 30px rgba(0, 0, 0, 0.5); }

  .achievement-card.unlocked.mensuels   { border-color: #F39C12; }
  .achievement-card.unlocked.mensuels:hover   { box-shadow: 0 0 20px #F39C12AA, 0 12px 30px rgba(0, 0, 0, 0.5); }

  .achievement-card.unlocked.secrets    { border-color: #9B59B6; }
  .achievement-card.unlocked.secrets:hover    { box-shadow: 0 0 20px #9B59B6AA, 0 12px 30px rgba(0, 0, 0, 0.5); }

  .achievement-card.unlocked.collections { border-color: #E5A00D; }
  .achievement-card.unlocked.collections:hover { box-shadow: 0 0 20px #E5A00DAA, 0 12px 30px rgba(0, 0, 0, 0.5); }

  /* Checkmark débloqué avec animation */
  .achievement-card.unlocked::after {
    content: '✓';
    position: absolute;
    bottom: 5px;
    left: 6px;
    font-size: 11px;
    color: #8BC34A;
    font-weight: 700;
    line-height: 1;
    z-index: 5;
    opacity: 0.8;
    transition: opacity 0.3s ease;
  }

  .achievement-card.unlocked:hover::after {
    opacity: 1;
  }

  /* Icon avec meilleure présentation */
  .achievement-icon {
    font-size: 28px;
    display: block;
    line-height: 1;
    pointer-events: none;
    transition: transform 0.3s ease;
  }

  .achievement-card:hover .achievement-icon {
    transform: scale(1.15);
  }

  /* XP Badge - Desktop: elegant et discret */
  .achievement-xp-badge {
    position: absolute;
    top: 6px;
    right: 6px;
    font-size: 10px;
    font-weight: 700;
    color: #E5A00D;
    background: rgba(229, 160, 13, 0.15);
    backdrop-filter: blur(8px);
    border: 1px solid rgba(229, 160, 13, 0.5);
    border-radius: 6px;
    padding: 3px 5px;
    line-height: 1.2;
    pointer-events: none;
    z-index: 10;
    transition: all 0.3s ease;
    letter-spacing: 0.3px;
  }

  .achievement-card:hover .achievement-xp-badge {
    background: rgba(229, 160, 13, 0.25);
    border-color: rgba(229, 160, 13, 0.7);
  }

  .achievement-card.locked .achievement-xp-badge {
    color: #888;
    background: rgba(255, 255, 255, 0.05);
    border-color: rgba(255, 255, 255, 0.15);
    opacity: 0.7;
  }

  /* XP Label - affiché sous la carte sur mobile */
  .ach-card-xp-label {
    display: none;
    width: 100%;
    text-align: center;
    font-size: 9px;
    font-weight: 600;
    color: #E5A00D;
    margin-top: 4px;
    pointer-events: none;
  }

  /* Tooltip - affiche le nom du succès au survol (desktop) */
  .achievement-tooltip {
    position: absolute;
    top: -38px;
    left: 50%;
    transform: translateX(-50%);
    background: rgba(20, 20, 25, 0.98);
    backdrop-filter: blur(10px);
    color: #fff;
    padding: 6px 10px;
    border-radius: 6px;
    font-size: 11px;
    font-weight: 500;
    white-space: nowrap;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.2s ease, top 0.2s ease;
    border: 1px solid rgba(255, 255, 255, 0.2);
    z-index: 100;
    letter-spacing: 0.3px;
  }

  .achievement-card:hover .achievement-tooltip {
    opacity: 1;
    top: -33px;
  }

  /* Éléments cachés utilisés uniquement pour les mises à jour JS */
  .achievement-hidden-data { display: none; }

  /* Mini progression dans la carte (locked only) */
  .ach-card-wrap {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0;
  }

  .ach-card-mini-bar {
    position: absolute;
    bottom: 0; left: 0; right: 0;
    height: 3px;
    background: rgba(255,255,255,0.06);
    border-radius: 0 0 14px 14px;
    overflow: hidden;
  }
  .ach-card-mini-fill {
    height: 100%;
    background: linear-gradient(90deg, #E5A00D99, #E5A00D);
    border-radius: 0 0 14px 14px;
    transition: width 0.6s ease;
  }
  .ach-card-pct {
    display: block;
    width: 100%;
    text-align: center;
    font-size: 10px;
    font-weight: 600;
    color: rgba(255,255,255,0.35);
    line-height: 1;
    margin-top: 5px;
    pointer-events: none;
    letter-spacing: 0.3px;
  }

  /* PROGRESS BAR (dans modal uniquement) */
  .achievement-progress {
    margin-top: 6px;
    font-size: 11px;
    color: #a0a0a0;
  }

  .achievement-progress-bar {
    width: 100%;
    height: 5px;
    background: rgba(255, 255, 255, 0.1);
    border-radius: 3px;
    overflow: hidden;
    margin-top: 5px;
  }

  .achievement-progress-fill {
    height: 100%;
    background: linear-gradient(90deg, #E5A00D, #DAA520);
    border-radius: 3px;
    transition: width 0.5s ease;
  }

  /* ── MODAL ── */
  .ach-modal-overlay {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 9000;
    background: rgba(0,0,0,0.65);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    align-items: center;
    justify-content: center;
    padding: 20px;
  }
  .ach-modal-overlay.open { display: flex; }

  .ach-modal {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    background: linear-gradient(140deg, rgba(28, 34, 46, 0.32), rgba(22, 28, 39, 0.22));
    border: 1px solid rgba(226, 246, 255, 0.42);
    border-radius: 20px;
    padding: 28px 28px 24px;
    max-width: 380px;
    width: 100%;
    text-align: center;
    box-shadow:
      0 14px 34px rgba(0,0,0,.18),
      0 0 0 1px rgba(232, 248, 255, 0.20) inset,
      0 4px 10px rgba(98, 178, 255, 0.04);
    backdrop-filter: blur(8px) saturate(116%) contrast(1.02) brightness(1.03);
    -webkit-backdrop-filter: blur(8px) saturate(116%) contrast(1.02) brightness(1.03);
    animation: ach-modal-in 0.2s ease;
  }

  .ach-modal::before {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: linear-gradient(150deg, rgba(255,255,255,0.08), rgba(255,255,255,0.02) 26%, rgba(255,255,255,0.00) 64%);
    z-index: 0;
  }

  .ach-modal::after {
    content: "";
    position: absolute;
    inset: -35%;
    pointer-events: none;
    background:
      radial-gradient(circle at 18% 12%, rgba(255,255,255,0.08), rgba(255,255,255,0.014) 24%, rgba(255,255,255,0) 50%),
      radial-gradient(circle at 82% 78%, rgba(86, 186, 255, 0.05), rgba(86, 186, 255, 0) 48%);
    filter: blur(3px);
    transform: rotate(-8deg);
    z-index: 0;
  }

  .ach-modal > * {
    position: relative;
    z-index: 1;
  }

  @keyframes ach-modal-in {
    from { opacity: 0; transform: scale(0.92) translateY(8px); }
    to   { opacity: 1; transform: scale(1) translateY(0); }
  }

  .ach-modal-close {
    position: absolute;
    top: 12px; right: 14px;
    background: none; border: none;
    color: #666; font-size: 20px;
    cursor: pointer; line-height: 1;
    padding: 4px 6px; border-radius: 6px;
    transition: color 0.15s, background 0.15s;
  }
  .ach-modal-close:hover { color: #fff; background: rgba(255,255,255,0.08); }

  .ach-modal-icon { font-size: 52px; line-height: 1; margin-bottom: 14px; display: block; }
  .ach-modal-name { font-size: 17px; font-weight: 800; color: #fff; margin-bottom: 8px; }
  .ach-modal-desc { font-size: 13px; color: #a0a0a0; line-height: 1.5; margin-bottom: 12px; }
  .ach-modal-date { font-size: 12px; color: #8BC34A; font-weight: 600; }
  .ach-modal-date.secret { color: #9B59B6; }
  .ach-modal-date.locked-txt { color: #666; }

  .ach-modal-progress { margin-top: 10px; font-size: 11px; color: #a0a0a0; }
  .ach-modal-progress-bar {
    width: 100%; height: 5px;
    background: rgba(255,255,255,0.1);
    border-radius: 3px; overflow: hidden; margin-top: 6px;
  }
  .ach-modal-progress-fill {
    height: 100%;
    background: linear-gradient(90deg, #E5A00D, #DAA520);
    border-radius: 3px;
    transition: width 0.5s ease;
  }

  .ach-modal-border--temporels  { border-color: #E67E22; }
  .ach-modal-border--activites  { border-color: #E74C3C; }
  .ach-modal-border--films      { border-color: #E67E22; }
  .ach-modal-border--series     { border-color: #3498DB; }
  .ach-modal-border--mensuels   { border-color: #F39C12; }
  .ach-modal-border--secrets    { border-color: #9B59B6; }
  .ach-modal-border--collections { border-color: #E5A00D; }

  /* Loading state */
  .loading {
    text-align: center;
    padding: 60px 20px;
    color: #a0a0a0;
  }

  .spinner {
    display: inline-block;
    width: 40px;
    height: 40px;
    border: 3px solid rgba(229, 160, 13, 0.3);
    border-top: 3px solid #E5A00D;
    border-radius: 50%;
    animation: spin 0.8s linear infinite;
  }

  @keyframes spin {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }

  @media (max-width: 768px) {
    .badges-title {
      font-size: 28px;
    }

    .achievements-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 10px;
    }

    /* Carte carrée, emoji centré comme les débloqués */
    .achievement-card {
      flex-direction: row;
      justify-content: center;
      align-items: center;
      padding: 0;
    }

    .achievement-icon {
      font-size: 34px;
    }

    /* Cacher le badge XP qui chevauche sur mobile */
    .achievement-xp-badge {
      display: none;
    }

    /* Afficher le label XP sous la carte sur mobile */
    .ach-card-xp-label {
      display: block;
    }

    .ach-card-pct {
      font-size: 10px;
      color: rgba(255,255,255,0.45);
    }

    .ach-card-mini-bar {
      height: 4px;
    }
  }

  @media (max-width: 480px) {
    .achievements-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 12px;
    }

    .achievement-icon {
      font-size: 40px;
    }

    .ach-card-xp-label {
      font-size: 10px;
      color: #E5A00D;
      font-weight: 600;
    }
  }
</style>

<div class="badges-container"<% if (typeof embed !== 'undefined' && embed) { %> id="badges-embed"<% } %>>
  <!-- HEADER WITH BACK BUTTON -->
  <div class="badges-header">
    <div class="badges-header-top">
      <a href="<%= basePath %>/profil" class="back-button"><%= t("success.backProfile") %></a>
      <h1 class="badges-title"><%= t("success.title") %></h1>
    </div>
    <p class="badges-subtitle"><%= t("success.subtitle", { serverName: siteTitle }) %></p>
    <div class="badges-refresh-timer" id="successRefreshTimer"></div>
  </div>

  <!-- STATS -->
  <div class="badges-stats">
    <div class="stat-box">
      <span class="stat-number" id="unlockedCount"><%= stats.unlocked %></span>
      <span class="stat-label"><%= t("success.unlocked") %></span>
    </div>
    <div class="stat-box">
      <span class="stat-number" id="lockedCount"><%= stats.locked %></span>
      <span class="stat-label"><%= t("success.remaining") %></span>
    </div>
    <div class="stat-box">
      <span class="stat-number" id="progressPercent"><%= stats.progress %>%</span>
      <span class="stat-label"><%= t("success.progress") %></span>
    </div>
  </div>

  <!-- ACHIEVEMENTS BY CATEGORY -->
  <% const categories = ['temporels', 'activites', 'films', 'series', 'mensuels', 'collections', 'secrets']; %>
  <% const successUnlockedOnTemplate = t("success.unlockedOn", { date: "__DATE__" }); %>
  <% const successUnlockedShort = t("success.unlockedShort"); %>
  <% const successSecretBadge = t("success.secretBadge"); %>
  
  <% categories.forEach(categoryKey => {
    const category = ACHIEVEMENTS[categoryKey];
    if (!category || !category.achievements || category.achievements.length === 0) return;
  %>
    <div class="achievements-section">
      <div class="category-header">
        <span class="category-icon"><%= category.icon %></span>
        <span class="category-name"><%= category.name %></span>
      </div>

      <div class="achievements-grid">
        <% category.achievements.forEach(achievement => {
          const isSecret   = !!(achievement.isSecret || achievement.category === 'secrets');
          const isRevocable = !!achievement.revocable;
          let descText = '';
          let dateText = '';
          let progressTotal = 0;
          const progressEntry = typeof progressMap !== 'undefined' && progressMap && progressMap[achievement.id];
          const explicitSecretText = achievement.conditionText || achievement.description || '';
          const emptyData = { daysSince: 0, sessionCount: 0, totalHours: 0, movieCount: 0, episodeCount: 0 };
          if (achievement.unlocked) {
            descText = isSecret ? explicitSecretText : (achievement.description || '');
            dateText = achievement.unlockedDate
              ? successUnlockedOnTemplate.replace('__DATE__', achievement.unlockedDate)
              : successUnlockedShort;
          } else if (isSecret && !isRevocable) {
            descText = '';
            dateText = successSecretBadge;
            if (progressEntry && progressEntry.total > 0) {
              progressTotal = progressEntry.total;
            } else {
              const progInfo = achievement.getProgress ? achievement.getProgress(emptyData) : { total: 0 };
              progressTotal = progInfo.total || 0;
            }
          } else if (isRevocable) {
            descText = achievement.description || '';
            if (progressEntry && progressEntry.total > 0) {
              progressTotal = progressEntry.total;
            } else {
              // Fallback pour revocable: afficher une progression de base
              // seulement si le total est informatif (>1).
              const progInfo = achievement.getProgress ? achievement.getProgress(emptyData) : { total: 0 };
              const fallbackTotal = progInfo.total || 0;
              if (fallbackTotal > 1) progressTotal = fallbackTotal;
            }
          } else {
            descText = achievement.conditionText || achievement.description || '';
            const progInfo = achievement.getProgress ? achievement.getProgress(emptyData) : { total: 100 };
            progressTotal = progInfo.total || 0;
          }
        %>
          <%
            let _pctDisplay = null;
            if (progressTotal > 0) {
              if (progressEntry && progressEntry.total > 0) {
                _pctDisplay = Math.min(100, Math.round((progressEntry.current / progressEntry.total) * 100)) + '%';
              } else {
                _pctDisplay = '0%';
              }
            }
          %>
          <% const showXpForCard = !!achievement.xp && (!isSecret || achievement.unlocked || isRevocable); %>
          <div class="ach-card-wrap">
          <div class="achievement-card <%= achievement.category %> <%= achievement.unlocked ? 'unlocked' : 'locked' %>"
               data-badge-id="<%= achievement.id %>"
               data-name="<%- achievement.name.replace(/"/g,'&quot;') %>"
               data-icon="<%= achievement.icon %>"
               data-desc="<%- descText.replace(/"/g,'&quot;') %>"
               data-desc-unlocked="<%- (isSecret ? explicitSecretText : (achievement.description || '')).replace(/"/g,'&quot;') %>"
               data-date="<%- dateText.replace(/"/g,'&quot;') %>"
               data-secret="<%= isSecret && !isRevocable ? 'true' : 'false' %>"
               data-category="<%= achievement.category %>"
               data-has-progress="<%= progressTotal > 0 ? 'true' : 'false' %>">
            <span class="achievement-tooltip"><%= achievement.name %></span>
            <span class="achievement-icon"><%= achievement.icon %></span>
            <% if (showXpForCard) { %>
              <span class="achievement-xp-badge">+<%= achievement.xp %> XP</span>
            <% } %>
            <% if (progressTotal > 0) { %>
              <% const progressCurrent = progressEntry && progressEntry.total > 0 ? Math.min(progressEntry.current, progressEntry.total) : 0; %>
              <% const progressPercent = progressTotal > 0 ? Math.min(100, Math.round((progressCurrent / progressTotal) * 100)) : 0; %>
              <div class="achievement-hidden-data">
                <div id="progress-<%= achievement.id %>">
                  <span class="current"><%= progressCurrent %></span> / <span class="total"><%= progressTotal %></span> (<span class="percent"><%= progressPercent %></span>%)
                </div>
              </div>
              <div class="ach-card-mini-bar"><div class="ach-card-mini-fill" id="card-fill-<%= achievement.id %>" style="width:<%= progressPercent %>%"></div></div>
            <% } %>
          </div>
          <% if (_pctDisplay !== null) { %>
            <span class="ach-card-pct" id="card-pct-<%= achievement.id %>"><%= _pctDisplay %></span>
          <% } else if (showXpForCard) { %>
            <span class="ach-card-xp-label">+<%= achievement.xp %> XP</span>
          <% } %>
          </div>
        <% }); %>
      </div>
    </div>
  <% }); %>
</div>

<!-- MODAL SUCCÈS -->
<div class="ach-modal-overlay" id="achModalOverlay" role="dialog" aria-modal="true">
  <div class="ach-modal" id="achModal">
    <button class="ach-modal-close" id="achModalClose" aria-label="<%= t("success.close") %>">&times;</button>
    <span class="ach-modal-icon" id="achModalIcon"></span>
    <div class="ach-modal-name" id="achModalName"></div>
    <div class="ach-modal-desc" id="achModalDesc"></div>
    <div class="ach-modal-date" id="achModalDate"></div>
    <div class="ach-modal-progress" id="achModalProgress" style="display:none">
      <span id="achModalProgText"></span>
      <div class="ach-modal-progress-bar">
        <div class="ach-modal-progress-fill" id="achModalProgFill"></div>
      </div>
    </div>
  </div>
</div>

<script>
  (function initSucces() {
    <% if (typeof embed !== 'undefined' && embed) { %>
    // Mode embed : DOM déjà chargé, exécution immédiate
    Promise.resolve().then(run);
    <% } else { %>
    document.addEventListener("DOMContentLoaded", run);
    <% } %>

    function run() {
    console.log("🏆 Page Badges chargée!");

    // ── Modal ──────────────────────────────────────────────────────────────
    const overlay  = document.getElementById('achModalOverlay');
    const modal    = document.getElementById('achModal');
    const btnClose = document.getElementById('achModalClose');
    const hostScrollEl = document.getElementById('succesModalContent') || document.scrollingElement || document.documentElement;
    let savedScrollTop = 0;
    let savedScrollLeft = 0;
    const overlayHomeParent = overlay ? overlay.parentNode : null;
    const overlayHomeNext = overlay ? overlay.nextSibling : null;

    function mountOverlayToBody() {
      if (!overlay || overlay.parentNode === document.body) return;
      document.body.appendChild(overlay);
    }

    function restoreOverlayHome() {
      if (!overlay || !overlayHomeParent || overlay.parentNode === overlayHomeParent) return;
      if (overlayHomeNext && overlayHomeNext.parentNode === overlayHomeParent) {
        overlayHomeParent.insertBefore(overlay, overlayHomeNext);
      } else {
        overlayHomeParent.appendChild(overlay);
      }
    }

    function openModal(card) {
      savedScrollTop = hostScrollEl ? hostScrollEl.scrollTop : 0;
      savedScrollLeft = hostScrollEl ? hostScrollEl.scrollLeft : 0;

      const icon     = card.dataset.icon     || '';
      const name     = card.dataset.name     || '';
      const desc     = card.dataset.desc     || '';
      const date     = card.dataset.date     || '';
      const isSecret = card.dataset.secret   === 'true';
      const cat      = card.dataset.category || '';
      const hasProg  = card.dataset.hasProgress === 'true';
      const isUnlocked = card.classList.contains('unlocked');

      document.getElementById('achModalIcon').textContent = icon;
      document.getElementById('achModalName').textContent = name;
      document.getElementById('achModalDesc').textContent = desc || (isSecret && !isUnlocked ? '' : '');

      const dateEl = document.getElementById('achModalDate');
      dateEl.textContent = date;
      dateEl.className = 'ach-modal-date' + (isSecret && !isUnlocked ? ' secret' : '') + (!isUnlocked && !date ? ' locked-txt' : '');

      // Barre de progression
      const progSection = document.getElementById('achModalProgress');
      if (hasProg || (!isUnlocked && !isSecret)) {
        const progressEl = card.querySelector('[id^="progress-"]');
        if (progressEl) {
          const cur = progressEl.querySelector('.current')?.textContent || '0';
          const tot = progressEl.querySelector('.total')?.textContent  || '0';
          const pct = progressEl.querySelector('.percent')?.textContent || '0';
          document.getElementById('achModalProgText').textContent = cur + ' / ' + tot + ' (' + pct + '%)';
          const fill = document.getElementById('achModalProgFill');
          if (fill) fill.style.width = pct + '%';
          progSection.style.display = 'block';
        } else {
          progSection.style.display = 'none';
        }
      } else {
        progSection.style.display = 'none';
      }

      // Couleur bordure du modal selon catégorie
      modal.className = 'ach-modal' + (cat ? ' ach-modal-border--' + cat : '');

      mountOverlayToBody();
      overlay.classList.add('open');
      try {
        btnClose.focus({ preventScroll: true });
      } catch (_) {
        btnClose.focus();
      }
    }

    function closeModal() {
      overlay.classList.remove('open');
      restoreOverlayHome();
      requestAnimationFrame(function() {
        if (!hostScrollEl) return;
        hostScrollEl.scrollTop = savedScrollTop;
        hostScrollEl.scrollLeft = savedScrollLeft;
      });
    }

    btnClose.addEventListener('click', closeModal);
    overlay.addEventListener('click', function(e) { if (e.target === overlay) closeModal(); });
    document.addEventListener('keydown', function(e) { if (e.key === 'Escape') closeModal(); });

    // Attacher le click sur toutes les cartes
    document.querySelectorAll('.achievement-card').forEach(function(card) {
      card.addEventListener('click', function() { openModal(card); });
    });
    var successRefreshMeta = {
      updatedAt: <%- JSON.stringify(successRefreshMeta?.updatedAt || null) %>,
      ttlMs: <%= Number(successRefreshMeta?.ttlMs || 0) %>,
      needsRefresh: <%= successRefreshMeta?.needsRefresh ? 'true' : 'false' %>
    };
    var successBasePath = '<%= basePath %>';
    var successIsEmbed = <%= (typeof embed !== 'undefined' && embed) ? 'true' : 'false' %>;
    var successRefreshTimerEl = document.getElementById('successRefreshTimer');
    var successAutoRefreshPending = false;
    var successAutoRefreshCooldownKey = 'portall.success.autoRefreshAt';
    var successRefreshTimerHandle = null;
    var successRefreshInstanceId = 'success-' + Date.now() + '-' + Math.random().toString(36).slice(2);
    var successLastAutoRefreshAt = 0;
    try {
      successLastAutoRefreshAt = Number(sessionStorage.getItem(successAutoRefreshCooldownKey) || '0');
    } catch (_) {
      successLastAutoRefreshAt = 0;
    }
    if (window.__portallSuccessRefreshTimerHandle) {
      clearInterval(window.__portallSuccessRefreshTimerHandle);
      window.__portallSuccessRefreshTimerHandle = null;
    }
    window.__portallSuccessRefreshInstanceId = successRefreshInstanceId;

    function formatRefreshDuration(totalSeconds) {
      if (totalSeconds < 60) return totalSeconds + 's';
      var minutes = Math.floor(totalSeconds / 60);
      var seconds = totalSeconds % 60;
      if (minutes < 60) return minutes + 'm' + (seconds ? ' ' + seconds + 's' : '');
      var hours = Math.floor(minutes / 60);
      var remainingMinutes = minutes % 60;
      return hours + 'h' + (remainingMinutes ? ' ' + remainingMinutes + 'm' : '');
    }

    function isCurrentSuccessRefreshInstance() {
      return window.__portallSuccessRefreshInstanceId === successRefreshInstanceId;
    }

    function isSuccessEmbedVisible() {
      if (!successIsEmbed) return true;
      var modal = document.getElementById('succesModal');
      return !!(modal && modal.classList.contains('active'));
    }

    function updateSuccessRefreshTimer() {
      if (!successRefreshTimerEl || !successRefreshMeta.updatedAt) return;

      var updatedAtMs = new Date(successRefreshMeta.updatedAt).getTime();
      if (!updatedAtMs) return;

      var now = Date.now();
      var ageSeconds = Math.max(0, Math.floor((now - updatedAtMs) / 1000));
      var remainingSeconds = successRefreshMeta.ttlMs > 0
        ? Math.max(0, Math.ceil((updatedAtMs + successRefreshMeta.ttlMs - now) / 1000))
        : 0;

      var text = 'Succès actualisés il y a ' + formatRefreshDuration(ageSeconds);
      if (successRefreshMeta.ttlMs > 0) {
        text += remainingSeconds > 0
          ? ' • frais pour encore ' + formatRefreshDuration(remainingSeconds)
          : ' • refresh recommandé';
      }
      successRefreshTimerEl.textContent = text;
    }

    function updateSuccessRefreshTimer() {
      if (!successRefreshTimerEl || !successRefreshMeta.updatedAt) return;

      var updatedAtMs = new Date(successRefreshMeta.updatedAt).getTime();
      if (!updatedAtMs) return;

      var now = Date.now();
      var remainingSeconds = successRefreshMeta.ttlMs > 0
        ? Math.max(0, Math.ceil((updatedAtMs + successRefreshMeta.ttlMs - now) / 1000))
        : 0;

      successRefreshTimerEl.textContent = successRefreshMeta.ttlMs > 0
        ? (remainingSeconds > 0
          ? 'Prochaine actualisation : ' + formatRefreshDuration(remainingSeconds)
          : 'Prochaine actualisation : recommandée')
        : 'Données succès à jour';
    }

    function updateSuccessRefreshTimer() {
      if (!successRefreshTimerEl) return;
      if (!successRefreshMeta.updatedAt && !successRefreshMeta.needsRefresh) return;

      var updatedAtMs = successRefreshMeta.updatedAt ? new Date(successRefreshMeta.updatedAt).getTime() : 0;
      if (!updatedAtMs && !successRefreshMeta.needsRefresh) return;

      var now = Date.now();
      var remainingSeconds = successRefreshMeta.ttlMs > 0
        ? Math.max(0, Math.ceil((updatedAtMs + successRefreshMeta.ttlMs - now) / 1000))
        : 0;

      successRefreshTimerEl.textContent = successRefreshMeta.ttlMs > 0
        ? ((remainingSeconds > 0 && !successRefreshMeta.needsRefresh)
          ? 'Prochaine actualisation : ' + formatRefreshDuration(remainingSeconds)
          : 'Prochaine actualisation : imminente')
        : 'Données succès à jour';

      var autoRefreshCooldownActive = successLastAutoRefreshAt > 0 && (now - successLastAutoRefreshAt) < 30000;

      if (successRefreshMeta.ttlMs > 0 && remainingSeconds <= 0 && autoRefreshCooldownActive) {
        successRefreshTimerEl.textContent = 'Actualisation récente, synchronisation en attente...';
        return;
      }

      if (successRefreshMeta.ttlMs > 0 && remainingSeconds <= 0 && !successAutoRefreshPending) {
        successAutoRefreshPending = true;
        successRefreshMeta.needsRefresh = false;
        successLastAutoRefreshAt = now;
        try {
          sessionStorage.setItem(successAutoRefreshCooldownKey, String(now));
        } catch (_) {}
        successRefreshTimerEl.textContent = 'Actualisation en cours...';
        fetch(successBasePath + '/api/badges-eval')
          .then(function() {
            if (!successIsEmbed) {
              window.location.reload();
              return;
            }

            var modalBody = document.getElementById('succesModalBody');
            if (!modalBody) {
              window.location.reload();
              return;
            }

            return fetch(successBasePath + '/succes?embed=1')
              .then(function(r) { return r.text(); })
              .then(function(html) {
                modalBody.innerHTML = html;
                modalBody.removeAttribute('style');
                modalBody.style.overflowX = 'hidden';
                modalBody.dataset.loaded = '1';
                modalBody.querySelectorAll('script').forEach(function(s) {
                  var ns = document.createElement('script');
                  ns.textContent = s.textContent;
                  s.replaceWith(ns);
                });
              });
          })
          .catch(function() {
            successAutoRefreshPending = false;
            successRefreshTimerEl.textContent = 'Actualisation au prochain chargement';
          });
      }
    }

    function renderSuccessRefreshTimer() {
      if (!isCurrentSuccessRefreshInstance()) return;
      if (!successRefreshTimerEl) return;
      if (!successRefreshMeta.updatedAt && !successRefreshMeta.needsRefresh) return;

      var updatedAtMs = successRefreshMeta.updatedAt ? new Date(successRefreshMeta.updatedAt).getTime() : 0;
      if (!updatedAtMs && !successRefreshMeta.needsRefresh) return;

      var now = Date.now();
      var remainingSeconds = successRefreshMeta.ttlMs > 0
        ? Math.max(0, Math.ceil((updatedAtMs + successRefreshMeta.ttlMs - now) / 1000))
        : 0;
      var autoRefreshCooldownActive = successLastAutoRefreshAt > 0 && (now - successLastAutoRefreshAt) < 30000;

      if (successRefreshMeta.ttlMs > 0 && remainingSeconds <= 0 && autoRefreshCooldownActive) {
        successRefreshTimerEl.textContent = 'Actualisation automatique récente...';
        return;
      }

      successRefreshTimerEl.textContent = successRefreshMeta.ttlMs > 0
        ? ((remainingSeconds > 0 && !successRefreshMeta.needsRefresh)
          ? 'Prochaine actualisation : ' + formatRefreshDuration(remainingSeconds)
          : 'Prochaine actualisation : imminente')
        : 'Données succès à jour';

      if (successRefreshMeta.ttlMs > 0 && remainingSeconds <= 0 && !successAutoRefreshPending && isSuccessEmbedVisible()) {
        successAutoRefreshPending = true;
        successRefreshMeta.needsRefresh = false;
        successLastAutoRefreshAt = now;
        try {
          sessionStorage.setItem(successAutoRefreshCooldownKey, String(now));
        } catch (_) {}
        successRefreshTimerEl.textContent = 'Actualisation en cours...';
        fetch(successBasePath + '/api/badges-eval')
          .then(function() {
            if (!successIsEmbed) {
              window.location.reload();
              return;
            }

            var modalBody = document.getElementById('succesModalBody');
            if (!modalBody) {
              window.location.reload();
              return;
            }

            return fetch(successBasePath + '/succes?embed=1')
              .then(function(r) { return r.text(); })
              .then(function(html) {
                modalBody.innerHTML = html;
                modalBody.removeAttribute('style');
                modalBody.style.overflowX = 'hidden';
                modalBody.dataset.loaded = '1';
                modalBody.querySelectorAll('script').forEach(function(s) {
                  var ns = document.createElement('script');
                  ns.textContent = s.textContent;
                  s.replaceWith(ns);
                });
              });
          })
          .catch(function() {
            successAutoRefreshPending = false;
            successRefreshTimerEl.textContent = 'Actualisation au prochain chargement';
          });
      }
    }

    renderSuccessRefreshTimer();
    if (successRefreshTimerEl && (successRefreshMeta.updatedAt || successRefreshMeta.needsRefresh)) {
      successRefreshTimerHandle = setInterval(renderSuccessRefreshTimer, 1000);
      window.__portallSuccessRefreshTimerHandle = successRefreshTimerHandle;
    }
    // L'affichage est préparé côté serveur à partir de l'état persisté en DB.
    // On coupe ici l'ancien recalcul navigateur pour garder une seule source de vérité.
    return;
    // ──────────────────────────────────────────────────────────────────────

    const BASE = '<%= basePath %>';
    const JOINED_AT_MS = (() => {
      const ts = <%= user.joinedAtTimestamp || 0 %>;
      return ts > 0 ? ts * 1000 : 0;
    })();

    let retryCount = 0;
    const MAX_RETRIES = 10;
    const RETRY_DELAY = 2000; // ms entre chaque tentative

    // Indicateur visuel discret pendant le chargement
    const loadingBanner = document.createElement('div');
    loadingBanner.id = 'badgesLoading';
    loadingBanner.style.cssText = [
      'position:fixed', 'bottom:18px', 'right:18px', 'z-index:9999',
      'background:rgba(30,30,30,.92)', 'border:1px solid rgba(229,160,13,.35)',
      'border-radius:8px', 'padding:10px 18px', 'font-size:13px',
      'color:#E5A00D', 'display:flex', 'align-items:center', 'gap:8px',
      'box-shadow:0 4px 20px rgba(0,0,0,.5)', 'transition:opacity .4s ease'
    ].join(';');
    loadingBanner.innerHTML = '<span style="animation:spin 1s linear infinite;display:inline-block">⟳</span> <%= t("success.loadingProgress") %>';
    document.body.appendChild(loadingBanner);

    function hideBanner() {
      loadingBanner.style.opacity = '0';
      setTimeout(() => loadingBanner.remove(), 500);
    }

    function fetchAndApply() {
      fetch(BASE + '/api/stats')
        .then(res => { if (!res.ok) throw new Error('HTTP ' + res.status); return res.json(); })
        .then(stats => {
          const sessionCount = stats.sessionCount || 0;
          const totalHours   = stats.watchStats?.totalHours || 0;
          const movieCount   = stats.watchStats?.movieCount || 0;
          const episodeCount = stats.watchStats?.episodeCount || 0;

          // Données encore vides → Tautulli n'a pas encore répondu, on réessaie
          const isEmpty = sessionCount === 0 && totalHours === 0 && movieCount === 0 && episodeCount === 0;
          if (isEmpty && retryCount < MAX_RETRIES) {
            retryCount++;
            console.log('[BADGES-JS] Données vides, retry ' + retryCount + '/' + MAX_RETRIES + '…');
            setTimeout(fetchAndApply, RETRY_DELAY);
            return;
          }

          hideBanner();

          const joinedAtMs = stats.joinedAt
            ? new Date(stats.joinedAt).getTime()
            : JOINED_AT_MS;

          const data = {
            totalHours,
            movieCount,
            episodeCount,
            sessionCount,
            monthlyHours: stats.monthlyHours || 0,
            nightCount:   stats.nightCount   || 0,
            morningCount: stats.morningCount || 0,
            daysSince: joinedAtMs > 0
              ? Math.floor((Date.now() - joinedAtMs) / (1000 * 60 * 60 * 24))
              : 0
          };

          console.log('[BADGES-JS] ✅ Data reçue (retry=' + retryCount + '):', data);
          applyAll(data);
        })
        .catch(err => {
          console.error('[BADGES-JS] Erreur fetch:', err);
          if (retryCount < MAX_RETRIES) {
            retryCount++;
            setTimeout(fetchAndApply, RETRY_DELAY);
          } else {
            hideBanner();
          }
        });
    }

    function applyAll(data) {
      // Temporels
      updateProgress('first-anniversary', Math.min(data.daysSince, 365),  365);
      updateProgress('veteran',           Math.min(data.daysSince, 730),   730);
      updateProgress('old-timer',         Math.min(data.daysSince, 1825), 1825);

      // Activités
      updateProgress('first-watch',  Math.min(data.sessionCount, 1),   1);
      updateProgress('regular',      Math.min(data.sessionCount, 7),   7);
      updateProgress('night-owl',    Math.min(data.nightCount,   30),  30);
      updateProgress('early-bird',   Math.min(data.morningCount, 50),  50);
      updateProgress('centurion',    Math.min(Math.round(data.totalHours), 100),  100);
      updateProgress('marathoner',   Math.min(Math.round(data.totalHours), 500),  500);

      // Films
      updateProgress('cinema-marathon',   Math.min(data.movieCount, 5),    5);
      updateProgress('cinephile',         Math.min(data.movieCount, 50),   50);
      updateProgress('film-critic',       Math.min(data.movieCount, 100),  100);
      updateProgress('hollywood-legend',  Math.min(data.movieCount, 500),  500);
      updateProgress('cinema-god',        Math.min(data.movieCount, 1000), 1000);
      updateProgress('cinema-universe',   Math.min(data.movieCount, 2000), 2000);

      // Séries
      updateProgress('binge-watcher',        Math.min(data.episodeCount, 10),   10);
      updateProgress('series-addict',        Math.min(data.episodeCount, 100),  100);
      updateProgress('series-master',        Math.min(data.episodeCount, 500),  500);
      updateProgress('serial-killer-legend', Math.min(data.episodeCount, 1000), 1000);
      updateProgress('series-overlord',      Math.min(data.episodeCount, 2000), 2000);
      updateProgress('series-titan',         Math.min(data.episodeCount, 5000), 5000);

      // Mensuels
      updateProgress('busy-month',    Math.min(data.monthlyHours, 50),  50);
      updateProgress('intense-month', Math.min(data.monthlyHours, 100), 100);
    }

    function updateProgress(achievementId, current, total) {
      const progressEl = document.getElementById('progress-' + achievementId);
      if (!progressEl) return;

      const percent = Math.min(Math.round((current / total) * 100), 100);
      progressEl.querySelector('.current').textContent = current;
      progressEl.querySelector('.total').textContent   = total;
      progressEl.querySelector('.percent').textContent = percent;

      // Mini barre in-card
      const cardFill = document.getElementById('card-fill-' + achievementId);
      const cardPct  = document.getElementById('card-pct-'  + achievementId);
      if (cardFill) { cardFill.style.transition = 'width .6s ease'; cardFill.style.width = percent + '%'; }
      if (cardPct)  { cardPct.textContent = percent + '%'; }
    }

    // Lancer immédiatement
    fetchAndApply();

    // ── Évaluation arrière-plan : unlock/révoquer badges via Tautulli ──
    fetch(BASE + '/api/badges-eval')
      .then(r => r.ok ? r.json() : null)
      .then(result => {
        if (!result) return;
        const { unlocked, progress, revoked, data } = result;
        let unlockedDelta = 0;

        // Appliquer les nouveaux unlocks
        for (const [id, date] of Object.entries(unlocked || {})) {
          const card = document.querySelector('[data-badge-id="' + id + '"]');
          if (!card || card.classList.contains('unlocked')) continue;
          card.classList.remove('locked');
          card.classList.add('unlocked');
          // Mettre à jour les data attributes pour le modal
          const dateLabel = <%- JSON.stringify(t("success.unlockedOn", { date: "__DATE__" })) %>.replace('__DATE__', date);
          const unlockedDesc = card.dataset.descUnlocked || card.dataset.desc || '';
          card.dataset.desc = unlockedDesc;
          card.dataset.date = dateLabel;
          card.dataset.hasProgress = 'false';
          unlockedDelta++;
        }

        // Appliquer les révocations (badges collection perdus)
        for (const id of (revoked || [])) {
          const card = document.querySelector('[data-badge-id="' + id + '"]');
          if (!card || card.classList.contains('locked')) continue;
          card.classList.remove('unlocked');
          card.classList.add('locked');
          card.dataset.date = '';
          unlockedDelta--;
        }

        // Mettre à jour les barres de progression des collections
        for (const [id, prog] of Object.entries(progress || {})) {
          if (prog && prog.total > 0) updateProgress(id, Math.min(prog.current, prog.total), prog.total);
        }

        // Mettre à jour les compteurs stats si des changements ont eu lieu
        if (unlockedDelta !== 0) {
          const ulEl = document.getElementById('unlockedCount');
          const lkEl = document.getElementById('lockedCount');
          const prEl = document.getElementById('progressPercent');
          if (ulEl) { const n = (parseInt(ulEl.textContent)||0) + unlockedDelta; ulEl.textContent = n; }
          if (lkEl) { const n = (parseInt(lkEl.textContent)||0) - unlockedDelta; lkEl.textContent = Math.max(0, n); }
          if (prEl && ulEl && lkEl) {
            const total = (parseInt(ulEl.textContent)||0) + (parseInt(lkEl.textContent)||0);
            prEl.textContent = (total > 0 ? Math.round((parseInt(ulEl.textContent)/total)*100) : 0) + '%';
          }
        }

        // Relancer fetchAndApply avec les vraies données si Tautulli a répondu
        if (data && (data.sessionCount > 0 || data.totalHours > 0)) applyAll(data);
      })
      .catch(() => {});
    } // end run()
  })(); // end initSucces
</script>
