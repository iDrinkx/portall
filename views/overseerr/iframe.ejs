<!doctype html>
<html lang="fr">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>Seerr – Demandes</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bar-height: 48px;
      --bar-bg: #0d1117;
      --bar-border: #1e2536;
      --accent: #6366f1;
      --text: #e2e8f0;
      --muted: #64748b;
    }

    html, body {
      height: 100%;
      background: #0f1117;
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      overflow: hidden;
    }

    /* ── BARRE DU HAUT ── */
    .portal-bar {
      position: fixed;
      top: 0; left: 0; right: 0;
      height: var(--bar-height);
      background: var(--bar-bg);
      border-bottom: 1px solid var(--bar-border);
      display: flex;
      align-items: center;
      padding: 0 16px;
      gap: 12px;
      z-index: 9999;
    }

    .portal-bar-back {
      display: flex;
      align-items: center;
      gap: 7px;
      text-decoration: none;
      color: var(--muted);
      font-size: 13px;
      font-weight: 500;
      padding: 6px 10px;
      border-radius: 7px;
      transition: background 0.15s, color 0.15s;
      border: 1px solid transparent;
    }
    .portal-bar-back:hover {
      background: rgba(255,255,255,0.05);
      color: var(--text);
      border-color: var(--bar-border);
    }
    .portal-bar-back-icon { font-size: 15px; }

    .portal-bar-separator {
      width: 1px;
      height: 20px;
      background: var(--bar-border);
    }

    .portal-bar-brand {
      display: flex;
      align-items: center;
      gap: 8px;
      font-size: 15px;
      font-weight: 700;
      color: var(--text);
    }
    .portal-bar-brand-dot {
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: var(--accent);
      box-shadow: 0 0 6px var(--accent);
    }

    .portal-bar-right {
      margin-left: auto;
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .portal-bar-user {
      display: flex;
      align-items: center;
      gap: 8px;
      font-size: 13px;
      color: var(--muted);
    }

    .portal-bar-avatar {
      width: 26px;
      height: 26px;
      border-radius: 50%;
      object-fit: cover;
      background: #1e2536;
    }

    .portal-bar-avatar-placeholder {
      width: 26px;
      height: 26px;
      border-radius: 50%;
      background: linear-gradient(135deg, #6366f1, #8b5cf6);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 11px;
      font-weight: 700;
      color: white;
      flex-shrink: 0;
    }

    .portal-bar-reload {
      background: none;
      border: 1px solid var(--bar-border);
      color: var(--muted);
      width: 30px;
      height: 30px;
      border-radius: 7px;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 14px;
      transition: all 0.15s;
    }
    .portal-bar-reload:hover {
      background: rgba(255,255,255,0.05);
      color: var(--text);
    }
    .portal-bar-reload.spinning { animation: spin 0.6s linear infinite; }
    @keyframes spin { to { transform: rotate(360deg); } }

    /* ── IFRAME ── */
    .seerr-frame-wrap {
      position: fixed;
      top: var(--bar-height);
      left: 0;
      right: 0;
      bottom: 0;
    }

    #seerrFrame {
      width: 100%;
      height: 100%;
      border: none;
      display: block;
      background: #0f1117;
    }

    /* ── LOADING OVERLAY (montré pendant que l'iframe charge) ── */
    .frame-loader {
      position: absolute;
      inset: 0;
      background: #0f1117;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 16px;
      color: #94a3b8;
      font-size: 14px;
      transition: opacity 0.3s;
      z-index: 10;
    }
    .frame-loader.hidden {
      opacity: 0;
      pointer-events: none;
    }

    .loader-spinner {
      width: 36px;
      height: 36px;
      border: 3px solid #1e2536;
      border-top-color: #6366f1;
      border-radius: 50%;
      animation: spin 0.7s linear infinite;
    }

    .loader-logo {
      display: flex;
      align-items: center;
      gap: 10px;
      font-size: 22px;
      font-weight: 800;
      color: #e2e8f0;
      margin-bottom: 8px;
    }
    .loader-logo-icon {
      width: 38px;
      height: 38px;
      background: linear-gradient(135deg, #6366f1, #8b5cf6);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 18px;
    }

    /* ── ERREUR ── */
    .frame-error {
      display: none;
      position: absolute;
      inset: 0;
      background: #0f1117;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 12px;
      color: #94a3b8;
      font-size: 14px;
      z-index: 11;
    }
    .frame-error.visible { display: flex; }
    .frame-error-icon { font-size: 48px; }
    .frame-error-title { font-size: 18px; font-weight: 700; color: #e2e8f0; }
    .frame-error-btn {
      margin-top: 8px;
      padding: 9px 20px;
      background: #6366f1;
      color: white;
      border: none;
      border-radius: 8px;
      font-size: 14px;
      font-weight: 600;
      cursor: pointer;
    }
    .frame-error-btn:hover { background: #818cf8; }
  </style>
</head>
<body>

  <!-- ── BARRE PORTAIL ── -->
  <div class="portal-bar">
    <a href="<%= basePath %>/dashboard" class="portal-bar-back">
      <span class="portal-bar-back-icon">←</span>
      Dashboard
    </a>
    <div class="portal-bar-separator"></div>
    <div class="portal-bar-brand">
      <div class="portal-bar-brand-dot"></div>
      seerr
    </div>

    <div class="portal-bar-right">
      <button class="portal-bar-reload" id="reloadBtn" title="Recharger">↻</button>
      <div class="portal-bar-user">
        <% if (user && user.thumb) { %>
          <img class="portal-bar-avatar" src="<%= user.thumb %>" alt="">
        <% } else { %>
          <div class="portal-bar-avatar-placeholder">
            <%= (user && user.username) ? user.username[0].toUpperCase() : '?' %>
          </div>
        <% } %>
        <span><%= (user && user.username) ? user.username : '' %></span>
      </div>
    </div>
  </div>

  <!-- ── IFRAME ── -->
  <div class="seerr-frame-wrap">

    <div class="frame-loader" id="frameLoader">
      <div class="loader-logo">
        <div class="loader-logo-icon">🎬</div>
        seerr
      </div>
      <div class="loader-spinner"></div>
      <span>Connexion à Seerr...</span>
    </div>

    <div class="frame-error" id="frameError">
      <div class="frame-error-icon">⚠️</div>
      <div class="frame-error-title">Seerr inaccessible</div>
      <p>Vérifiez que Seerr est démarré et que<br><code>BASE_URL=/overseerr-frame</code> est configuré.</p>
      <button class="frame-error-btn" onclick="reloadFrame()">Réessayer</button>
    </div>

    <iframe
      id="seerrFrame"
      src="<%= basePath %>/overseerr-frame/"
      title="Seerr"
      sandbox="allow-scripts allow-same-origin allow-forms allow-popups allow-popups-to-escape-sandbox"
    ></iframe>

  </div>

  <script>
    const frame   = document.getElementById("seerrFrame");
    const loader  = document.getElementById("frameLoader");
    const errorEl = document.getElementById("frameError");
    const reloadBtn = document.getElementById("reloadBtn");

    let loadTimeout;

    function reloadFrame() {
      errorEl.classList.remove("visible");
      loader.classList.remove("hidden");
      reloadBtn.classList.add("spinning");
      clearTimeout(loadTimeout);
      frame.src = frame.src; // recharge

      // Timeout 20s : si l'iframe ne charge pas, afficher erreur
      loadTimeout = setTimeout(() => {
        loader.classList.add("hidden");
        errorEl.classList.add("visible");
        reloadBtn.classList.remove("spinning");
      }, 20000);
    }

    // L'iframe a fini de charger
    frame.addEventListener("load", () => {
      clearTimeout(loadTimeout);
      loader.classList.add("hidden");
      reloadBtn.classList.remove("spinning");

      // Vérifier si la page chargée est une page d'erreur de notre proxy
      try {
        const iBody = frame.contentDocument?.body?.innerText || "";
        if (iBody.includes("Seerr inaccessible") || iBody.includes("502")) {
          errorEl.classList.add("visible");
        }
      } catch (_) {
        // Cross-origin rare si Seerr a une config inhabituelle
      }
    });

    // Erreur de chargement de l'iframe
    frame.addEventListener("error", () => {
      clearTimeout(loadTimeout);
      loader.classList.add("hidden");
      errorEl.classList.add("visible");
      reloadBtn.classList.remove("spinning");
    });

    // Bouton recharger
    reloadBtn.addEventListener("click", () => {
      reloadBtn.classList.add("spinning");
      frame.src = frame.src;
      setTimeout(() => reloadBtn.classList.remove("spinning"), 1000);
    });

    // Démarrer le timeout au chargement initial
    loadTimeout = setTimeout(() => {
      loader.classList.add("hidden");
      errorEl.classList.add("visible");
    }, 20000);
  </script>

</body>
</html>
