<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Overseerr — Plex Portal</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html, body {
      height: 100%;
      overflow: hidden;
      background: #0f1117;
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    }

    /* ── Barre de navigation ── */
    #topbar {
      display: flex;
      align-items: center;
      gap: 12px;
      height: 44px;
      padding: 0 16px;
      background: #161b22;
      border-bottom: 1px solid #30363d;
      flex-shrink: 0;
    }

    #topbar a {
      display: inline-flex;
      align-items: center;
      gap: 7px;
      color: #c9d1d9;
      text-decoration: none;
      font-size: 0.85rem;
      font-weight: 500;
      padding: 5px 12px;
      border-radius: 6px;
      border: 1px solid #30363d;
      background: #21262d;
      transition: background 0.15s, border-color 0.15s;
    }
    #topbar a:hover {
      background: #30363d;
      border-color: #8b949e;
      color: #f0f6fc;
    }
    #topbar a svg {
      flex-shrink: 0;
    }

    #topbar .title {
      color: #8b949e;
      font-size: 0.82rem;
      margin-left: 4px;
      letter-spacing: 0.02em;
    }

    /* ── Iframe ── */
    #seerr-frame {
      display: block;
      width: 100%;
      height: calc(100vh - 44px);
      border: none;
    }
  </style>
</head>
<body>

  <div id="topbar">
    <a href="/dashboard">
      <!-- flèche gauche -->
      <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor">
        <path fill-rule="evenodd" d="M9.78 12.78a.75.75 0 0 1-1.06 0L4.47 8.53a.75.75 0 0 1 0-1.06l4.25-4.25a.75.75 0 0 1 1.06 1.06L6.06 8l3.72 3.72a.75.75 0 0 1 0 1.06z"/>
      </svg>
      Retour au portail
    </a>
    <span class="title">Overseerr</span>
  </div>

  <iframe
    id="seerr-frame"
    src="<%= overseerrPublicUrl %>"
    allow="fullscreen"
    title="Overseerr"
  ></iframe>

</body>
</html>
