<!DOCTYPE html>
<html lang="<%= locale || 'fr' %>">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/png" href="<%= basePath %>/logo.png" />
  <link rel="apple-touch-icon" href="<%= basePath %>/logo.png" />
  <title><%= title %> - <%= siteTitle || "Plex-Portal" %></title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html, body {
      height: 100%;
      overflow: hidden;
      background: #0f1117;
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    }
    #page-wrap {
      display: flex;
      flex-direction: column;
      height: 100vh;
      height: 100dvh;
    }
    #topbar {
      display: flex;
      align-items: center;
      gap: 12px;
      height: 44px;
      padding: 0 16px;
      background: #161b22;
      border-bottom: 1px solid #30363d;
      flex-shrink: 0;
    }
    #topbar a {
      display: inline-flex;
      align-items: center;
      gap: 7px;
      color: #c9d1d9;
      text-decoration: none;
      font-size: 0.85rem;
      font-weight: 500;
      padding: 5px 12px;
      border-radius: 6px;
      border: 1px solid #30363d;
      background: #21262d;
      transition: background 0.15s, border-color 0.15s;
    }
    #topbar a:hover {
      background: #30363d;
      border-color: #8b949e;
      color: #f0f6fc;
    }
    #topbar .title {
      color: #8b949e;
      font-size: 0.82rem;
      margin-left: 4px;
      letter-spacing: 0.02em;
    }
    #app-frame {
      display: block;
      width: 100%;
      flex: 1 1 0;
      min-height: 0;
      border: none;
    }
    @media (max-width: 768px) {
      #topbar { height: 36px; padding: 0 10px; }
      #topbar a { font-size: 0.78rem; padding: 4px 9px; }
      #topbar .title { font-size: 0.75rem; }
    }
  </style>
</head>
<body>
<div id="page-wrap">
  <div id="topbar">
    <a href="<%= basePath %>/dashboard">
      <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor">
        <path fill-rule="evenodd" d="M9.78 12.78a.75.75 0 0 1-1.06 0L4.47 8.53a.75.75 0 0 1 0-1.06l4.25-4.25a.75.75 0 0 1 1.06 1.06L6.06 8l3.72 3.72a.75.75 0 0 1 0 1.06z"/>
      </svg>
      <%= locale === "en" ? "Back to portal 🏠" : "Retour au portail 🏠" %>
    </a>
    <span class="title"><%= title %></span>
  </div>

  <iframe id="app-frame" src="<%= srcUrl %>" allow="fullscreen" title="<%= title %>"></iframe>
</div>
</body>
</html>
