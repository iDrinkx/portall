<div class="dashboard-header">
  <% if (user.thumb) { %>
    <img src="<%= user.thumb %>" alt="<%= user.username %>" class="user-avatar" />
  <% } %>
  <div class="header-text">
    <h1 class="dashboard-title">Bienvenue <%= user.username %></h1>
  </div>
</div>

<div class="cards-grid">

  <%- include("_subscription") %>
  <%- include("_stats") %>

</div>

<script src="<%= basePath %>/js/dashboard.js"></script>
