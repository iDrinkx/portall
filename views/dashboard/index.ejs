<!-- DASHBOARD HEADER -->
<div class="dashboard-header">
  <div class="header-text">
    <p class="dashboard-greeting">Bon retour,</p>
    <h1 class="dashboard-title">Bienvenue</h1>
  </div>
</div>

<!-- HERO CARDS -->
<div class="hero-cards">

  <!-- Carte Profil -->
  <a href="<%= basePath %>/profil" class="hero-card hero-card-profil">
    <div class="hero-card-content">
      <div class="hero-card-icon-wrap">
        <% if (user.thumb) { %>
          <img src="<%= user.thumb %>" class="hero-avatar" alt="<%= user.username %>" />
        <% } else { %>
          <div class="hero-avatar-placeholder">👤</div>
        <% } %>
      </div>
      <div class="hero-card-info">
        <p class="hero-card-label">Mon Profil</p>
        <h2 class="hero-card-title"><%= user.username %></h2>
        <p class="hero-card-desc">Statistiques · Badges · Historique</p>
      </div>
      <div class="hero-card-arrow">→</div>
    </div>
  </a>

  <!-- Carte Demandes de Contenu -->
  <a href="<%= basePath %>/seerr" class="hero-card hero-card-demandes">
    <div class="hero-card-content">
      <div class="hero-card-icon-wrap">
        <div class="hero-icon">🎬</div>
      </div>
      <div class="hero-card-info">
        <p class="hero-card-label">Demandes de Contenu</p>
        <h2 class="hero-card-title">Seerr</h2>
        <p class="hero-card-desc">Demander films &amp; séries</p>
      </div>
      <div class="hero-card-arrow">→</div>
    </div>
  </a>

</div>

<!-- SERVER STATS BAR -->
<div class="server-stats-bar" id="serverStatsBar">
  <div class="ssb-item" id="ssb-movies">
    <span class="ssb-icon">🎬</span>
    <span class="ssb-num" id="ssb-movies-num">—</span>
    <span class="ssb-label">Films</span>
  </div>
  <div class="ssb-divider"></div>
  <div class="ssb-item" id="ssb-shows">
    <span class="ssb-icon">📺</span>
    <span class="ssb-num" id="ssb-shows-num">—</span>
    <span class="ssb-label">Séries</span>
    <span class="ssb-sub" id="ssb-episodes"></span>
  </div>
  <div class="ssb-divider"></div>
  <div class="ssb-item" id="ssb-music">
    <span class="ssb-icon">🎵</span>
    <span class="ssb-num" id="ssb-music-num">—</span>
    <span class="ssb-label">Titres</span>
  </div>
  <div class="ssb-divider" id="ssb-div-audio"></div>
  <div class="ssb-item" id="ssb-audio">
    <span class="ssb-icon">🎧</span>
    <span class="ssb-num" id="ssb-audio-num">—</span>
    <span class="ssb-label">Livres audio</span>
  </div>
</div>

<script src="<%= basePath %>/js/dashboard.js"></script>
<script>
(function () {
  const bp = '<%= basePath %>';
  const fmt = n => n.toLocaleString('fr-FR');

  fetch(bp + '/api/server-stats')
    .then(r => r.json())
    .then(d => {
      if (!d.available) return;
      const bar = document.getElementById('serverStatsBar');
      if (bar) bar.classList.add('loaded');

      const set = (id, val) => { const el = document.getElementById(id); if (el) el.textContent = val; };

      set('ssb-movies-num', fmt(d.movies));
      set('ssb-shows-num',  fmt(d.shows));
      set('ssb-music-num',  fmt(d.musicTracks));
      set('ssb-audio-num',  fmt(d.audiobookCount));

      if (d.episodes > 0) set('ssb-episodes', fmt(d.episodes) + ' épisodes');

      if (d.audiobookCount === 0) {
        const div  = document.getElementById('ssb-div-audio');
        const item = document.getElementById('ssb-audio');
        if (div)  div.style.display  = 'none';
        if (item) item.style.display = 'none';
      }
    })
    .catch(() => {});
})();
</script>
