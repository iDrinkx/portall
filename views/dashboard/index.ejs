<!-- DASHBOARD HEADER -->
<div class="dashboard-header">
  <div class="header-text">
    <h1 class="dashboard-title"><%= t("dashboard.welcome") %></h1>
  </div>
</div>

<%
  const dashboardHtmlAboveBlocks = (dashboardCustomHtmlBlocks || []).filter(function(block) {
    return block && block.position === "above";
  });
  const dashboardHtmlBelowBlocks = (dashboardCustomHtmlBlocks || []).filter(function(block) {
    return !block || block.position !== "above";
  });
%>

<% if (dashboardHtmlAboveBlocks.length) { %>
  <% dashboardHtmlAboveBlocks.forEach(function(block) { %>
  <div class="dashboard-custom-html">
    <%- block.rendered %>
  </div>
  <% }) %>
<% } %>

<!-- HERO CARDS -->
<div class="hero-cards">

  <% (dashboardBuiltinCards || []).forEach(function(card) { %>
    <a href="<%= card.href %>" class="hero-card <%= card.className %>">
      <div class="hero-card-content">
        <div class="hero-card-icon-wrap">
          <% if (card.kind === "profile") { %>
            <% if (user.thumb) { %>
              <div class="hero-avatar-ring" id="heroAvatarRing">
                <div class="rank-ring" id="heroRankRing"></div>
                <img src="<%= user.thumb %>" class="hero-avatar" id="heroAvatar" alt="<%= user.username %>" />
              </div>
            <% } else { %>
              <div class="hero-avatar-placeholder">👤</div>
            <% } %>
          <% } else if (card.kind === "image") { %>
            <div class="hero-icon <%= card.iconClass %>">
              <img src="<%= card.iconSrc %>" alt="<%= card.iconAlt %>" class="hero-icon-logo">
            </div>
          <% } else { %>
            <div class="hero-icon <%= card.iconClass %>"><%= card.icon %></div>
          <% } %>
        </div>
        <div class="hero-card-info">
          <p class="hero-card-label"><%= card.label %></p>
          <h2 class="hero-card-title"><%= card.title %></h2>
          <p class="hero-card-desc"><%= card.description %></p>
        </div>
        <div class="hero-card-arrow">→</div>
      </div>
    </a>
  <% }) %>

  <% (dashboardCustomCards || []).forEach(function(card) { %>
    <a
      href="<%= card.href %>"
      class="hero-card hero-card-custom"
      <% if (card.external) { %>target="_blank" rel="noopener noreferrer"<% } %>
      style="
        --custom-bg-start: <%= card.color.bgStart %>;
        --custom-bg-end: <%= card.color.bgEnd %>;
        --custom-border: <%= card.color.border %>;
        --custom-border-hover: <%= card.color.borderHover %>;
        --custom-glow: <%= card.color.glow %>;
        --custom-accent-a: <%= card.color.accentA %>;
        --custom-accent-b: <%= card.color.accentB %>;
        --custom-label: <%= card.color.label %>;
        --custom-arrow: <%= card.color.arrow %>;
        --custom-icon-border: <%= card.color.iconBorder %>;
        --custom-icon-glow: <%= card.color.iconGlow %>;
      "
    >
      <div class="hero-card-content">
        <div class="hero-card-icon-wrap">
          <div class="hero-icon hero-icon--custom <% if ((card.integrationKey || "") === "komga_auto" || (card.integrationKey || "") === "jellyfin_auto" || (card.integrationKey || "") === "romm_auto") { %>hero-icon--logo-mode<% } %>">
            <% if ((card.integrationKey || "") === "komga_auto") { %>
              <img src="<%= basePath %>/img/komga-icon.svg" alt="Komga" class="hero-icon-custom-logo">
            <% } else if ((card.integrationKey || "") === "jellyfin_auto") { %>
              <img src="<%= basePath %>/img/jellyfin-icon.svg" alt="Jellyfin" class="hero-icon-custom-logo hero-icon-custom-logo--jellyfin">
            <% } else if ((card.integrationKey || "") === "romm_auto") { %>
              <img src="<%= basePath %>/img/romm-icon.svg" alt="RomM" class="hero-icon-custom-logo">
            <% } else { %>
              <span class="hero-icon-custom-char"><%= card.icon || "✨" %></span>
            <% } %>
          </div>
        </div>
        <div class="hero-card-info">
          <p class="hero-card-label"><%= card.label %></p>
          <h2 class="hero-card-title"><%= card.title %></h2>
          <p class="hero-card-desc"><%= card.description %></p>
        </div>
        <div class="hero-card-arrow">→</div>
      </div>
    </a>
  <% }); %>

</div>

<% if (dashboardHtmlBelowBlocks.length) { %>
  <% dashboardHtmlBelowBlocks.forEach(function(block) { %>
  <div class="dashboard-custom-html">
    <%- block.rendered %>
  </div>
  <% }) %>
<% } else if (!(dashboardCustomHtmlBlocks || []).length && dashboardCustomHtml) { %>
  <div class="dashboard-custom-html">
    <%- dashboardCustomHtml %>
  </div>
<% } %>

<% if (dashboardServerStatsEnabled) { %>
  <!-- SERVER STATS BAR -->
  <div class="server-stats-bar" id="serverStatsBar">
    <div class="ssb-item" id="ssb-movies">
      <span class="ssb-icon">🎬</span>
      <span class="ssb-num skel" id="ssb-movies-num"></span>
      <span class="ssb-label"><%= t("dashboard.serverStats.movies") %></span>
      <span class="ssb-sub"></span>
    </div>
    <div class="ssb-divider"></div>
    <div class="ssb-item" id="ssb-shows">
      <span class="ssb-icon">📺</span>
      <span class="ssb-num skel" id="ssb-shows-num"></span>
      <span class="ssb-label"><%= t("dashboard.serverStats.shows") %></span>
      <span class="ssb-sub" id="ssb-episodes"></span>
    </div>
    <div class="ssb-divider"></div>
    <div class="ssb-item" id="ssb-music">
      <span class="ssb-icon">🎵</span>
      <span class="ssb-num skel" id="ssb-music-num"></span>
      <span class="ssb-label"><%= t("dashboard.serverStats.music") %></span>
      <span class="ssb-sub"></span>
    </div>
    <div class="ssb-divider" id="ssb-div-audio"></div>
    <div class="ssb-item" id="ssb-audio">
      <span class="ssb-icon">🎧</span>
      <span class="ssb-num skel" id="ssb-audio-num"></span>
      <span class="ssb-label"><%- t("dashboard.serverStats.audio").replace(" ", "<br>") %></span>
      <span class="ssb-sub"></span>
    </div>
</div>
<% } %>

<script src="<%= basePath %>/js/dashboard.js"></script>
<script>
  window.DASHBOARD_SERVER_STATS_ENABLED = <%= dashboardServerStatsEnabled ? "true" : "false" %>;
</script>
<% if (dashboardServerStatsEnabled) { %>
<script>
(function () {
  const bp      = '<%= basePath %>';
  const userId  = document.body.getAttribute('data-user-id') || 'guest';
  const SSB_KEY = 'ssb_snap:' + userId;
  const SSB_TTL = 10 * 60 * 1000; // 10 min (aligné avec le cache serveur)
  const fmt     = n => n.toLocaleString('<%= locale === "en" ? "en-US" : "fr-FR" %>');

  function applyStats(d) {
    if (!d.available) return;
    const bar = document.getElementById('serverStatsBar');
    if (bar) bar.classList.add('loaded');

    const set = (id, val) => {
      const el = document.getElementById(id);
      if (el) { el.textContent = val; el.classList.remove('skel'); }
    };
    set('ssb-movies-num', fmt(d.movies));
    set('ssb-shows-num',  fmt(d.shows));
    set('ssb-music-num',  fmt(d.musicTracks));
    set('ssb-audio-num',  fmt(d.audiobookCount));
    if (d.episodes > 0) set('ssb-episodes', '<%= t("dashboard.serverStats.episodes", { count: "__COUNT__" }) %>'.replace('__COUNT__', fmt(d.episodes)));
    if (d.audiobookCount === 0) {
      const div  = document.getElementById('ssb-div-audio');
      const item = document.getElementById('ssb-audio');
      if (div)  div.style.display  = 'none';
      if (item) item.style.display = 'none';
    }
  }

  // ⚡ Restaurer instantanément
  try {
    const raw = localStorage.getItem(SSB_KEY);
    if (raw) {
      const snap = JSON.parse(raw);
      if (snap.savedAt && Date.now() - snap.savedAt < SSB_TTL) applyStats(snap);
    }
  } catch (_) {}

  // Rafraîchir en arrière-plan
  fetch(bp + '/api/server-stats')
    .then(r => r.json())
    .then(d => {
      applyStats(d);
      if (d.available) {
        try { localStorage.setItem(SSB_KEY, JSON.stringify({ ...d, savedAt: Date.now() })); } catch (_) {}
      }
    })
    .catch(() => {});
})();
</script>
<% } %>

<script>
// ─── XP Rank Ring (même logique que la page profil) ───────────────────
(function () {
  const userId = document.body.getAttribute('data-user-id') || 'guest';
  if (!userId || userId === 'guest') return;

  const XP_KEY = 'xp_snapshot_' + userId;
  const XP_TTL = 5 * 60 * 1000; // 5 min (synchro avec refresh classement)

  function _rankGrad(c) {
    return `conic-gradient(from -90deg, ${c}2e 0deg, ${c} 90deg, ${c}cc 180deg, ${c} 270deg, ${c}2e 360deg)`;
  }

  function applyRing(color) {
    const ring    = document.getElementById('heroRankRing');
    const wrapper = document.getElementById('heroAvatarRing');
    if (!ring) return;
    ring.style.background = _rankGrad(color);
    if (wrapper) wrapper.style.filter = `drop-shadow(0 0 7px ${color}cc) drop-shadow(0 0 16px ${color}66)`;
  }

  // ⚡ Appliquer instantanément depuis le cache (même clé que le profil)
  try {
    const raw = localStorage.getItem(XP_KEY);
    if (raw) {
      const snap = JSON.parse(raw);
      if (snap.savedAt && Date.now() - snap.savedAt < XP_TTL && snap.rank && snap.rank.color) {
        applyRing(snap.rank.color);
      }
    }
  } catch (_) {}

  // Toujours rafraîchir en arrière-plan pour être à jour
  fetch((window.APP_BASE_PATH || '') + '/api/xp-snapshot')
    .then(r => r.ok ? r.json() : null)
    .then(data => {
      if (!data || !data.rank || !data.rank.color) return;
      applyRing(data.rank.color);
      try {
        localStorage.setItem(XP_KEY, JSON.stringify({
          rank: data.rank, level: data.level, totalXp: data.totalXp,
          progressPercent: data.progressPercent, xpNeeded: data.xpNeeded,
          savedAt: Date.now()
        }));
      } catch (_) {}
    })
    .catch(() => {});
})();
</script>

<script>
// ─── Prefetch post-login (safe, non bloquant, une fois par session) ───
(function () {
  const bp = window.APP_BASE_PATH || '';
  const userId = document.body.getAttribute('data-user-id') || 'guest';
  if (!userId || userId === 'guest') return;

  const PREFETCH_KEY = 'post_login_prefetch_v1:' + userId;
  if (sessionStorage.getItem(PREFETCH_KEY) === 'done') return;

  const endpoints = [
    '/api/subscription',
    '/api/seerr',
    '/api/xp-snapshot'
  ];

  function prefetchOne(path, timeoutMs) {
    return new Promise((resolve) => {
      const ctrl = new AbortController();
      const timer = setTimeout(() => ctrl.abort(), timeoutMs);

      fetch(bp + path, {
        method: 'GET',
        credentials: 'same-origin',
        signal: ctrl.signal
      })
        .then(() => resolve())
        .catch(() => resolve())
        .finally(() => clearTimeout(timer));
    });
  }

  async function runPrefetch() {
    // Marquer immédiatement pour éviter les doubles runs en cas de scripts multiples
    sessionStorage.setItem(PREFETCH_KEY, 'done');

    // Timeout court pour rester transparent côté UX
    const timeoutMs = 4500;
    await Promise.allSettled(endpoints.map((ep) => prefetchOne(ep, timeoutMs)));
  }

  const schedule = window.requestIdleCallback
    ? (fn) => window.requestIdleCallback(fn, { timeout: 1200 })
    : (fn) => setTimeout(fn, 250);

  schedule(runPrefetch);
})();
</script>

<!-- Version Footer & Changelog Modal (Dashboard only) -->
<footer class="version-footer" id="versionFooter">
  <span class="version-number" id="versionNumber">v--</span>
</footer>

<!-- Changelog Modal -->
<div class="changelog-modal" id="changelogModal">
  <div class="changelog-modal-content">
    <div class="changelog-header">
      <h2><%= t("dashboard.html.footer.title") %><span id="changelogVersion">--</span></h2>
      <button class="changelog-close" id="changelogClose">✕</button>
    </div>
    <div class="changelog-body" id="changelogBody">
      <p style="text-align: center; color: #888;" data-loading="1"><%= t("dashboard.html.footer.loading") %></p>
    </div>
  </div>
</div>

<script>
  // Version Footer & Changelog Management (Dashboard only)
  (function() {
    const versionNumber = document.getElementById('versionNumber');
    const versionFooter = document.getElementById('versionFooter');
    const changelogModal = document.getElementById('changelogModal');
    const changelogClose = document.getElementById('changelogClose');
    const changelogBody = document.getElementById('changelogBody');
    const changelogVersion = document.getElementById('changelogVersion');

    // Fetch version from API
    async function loadVersion() {
      try {
        const response = await fetch((window.APP_BASE_PATH || '') + '/api/version');
        if (!response.ok) throw new Error('Failed to fetch version');
        const { version } = await response.json();
        versionNumber.textContent = 'v' + version;
        changelogVersion.textContent = version;
      } catch (err) {
        versionNumber.textContent = 'v?.?.?';
      }
    }

    // Load changelog from API
    async function loadChangelog() {
      try {
        const response = await fetch((window.APP_BASE_PATH || '') + '/api/changelog');
        if (!response.ok) throw new Error('Failed to fetch changelog');
        const markdown = await response.text();
        changelogBody.innerHTML = '<pre style="white-space: pre-wrap; word-wrap: break-word; font-size: 0.9em; line-height: 1.6;">' +
                                  markdown.replace(/</g, '&lt;').replace(/>/g, '&gt;') +
                                  '</pre>';
      } catch (err) {
        changelogBody.innerHTML = '<p style="color: #e74c3c;"><%= t("dashboard.html.footer.error") %></p>';
      }
    }

    // Open modal on footer click
    versionFooter.addEventListener('click', () => {
      if (!changelogBody.querySelector('[data-loading="1"]')) {
        // Already loaded, just show
        changelogModal.classList.add('active');
      } else {
        // First load
        loadChangelog().then(() => {
          changelogModal.classList.add('active');
        });
      }
    });

    // Close modal
    changelogClose.addEventListener('click', () => {
      changelogModal.classList.remove('active');
    });

    changelogModal.addEventListener('click', (e) => {
      if (e.target === changelogModal) {
        changelogModal.classList.remove('active');
      }
    });

    // Load version on page load
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', loadVersion);
    } else {
      loadVersion();
    }
  })();
</script>
