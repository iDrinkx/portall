<div class="profil-container">
  <div class="profil-refresh-timer" id="profilRefreshTimer"></div>
  <!-- HEADER AVEC AVATAR ET XP -->
  <div class="profil-header">
    <% 
      // Calculer les stats XP - données seront chargées via API
      const estimatedXp = (user.sessionCount || 0) * 2;
    %>
    <div class="avatar-wrapper" id="avatarWrapper">
      <div class="rank-ring" id="profilRankRing"></div>
      <% if (user.thumb) { %>
        <img src="<%= user.thumb %>" alt="<%= user.username %>" class="profile-avatar" id="profileAvatar" />
      <% } %>
    </div>

    <div class="profile-info">
      <h1><%= user.username %></h1>
      <p class="profile-email"><%= user.email %></p>
      
      <div class="xp-status" id="xpStatus">
        <span class="xp-badge xp-skel" id="xpBadge"></span>
        <span class="xp-amount xp-skel" id="xpAmount"></span>
      </div>
    </div>

    <!-- LECTURE EN COURS -->
    <div class="now-playing-widget" id="nowPlayingWidget" style="display:none">
      <!-- Fond flou = affiche agrandie -->
      <div class="np-bg" id="npBg"></div>
      <!-- Overlay gradient -->
      <div class="np-overlay"></div>

      <div class="np-inner">
        <!-- Affiche -->
        <div class="np-poster-wrap">
          <img class="np-poster" id="npThumb" src="" alt="" />
        </div>

        <!-- Infos + barre -->
        <div class="np-body">
          <div class="np-top">
            <div class="np-state-row">
              <span class="np-dot" id="npDot"></span>
              <span class="np-label" id="npLabel">EN COURS</span>
            </div>
            <div class="np-titles">
              <span class="np-grand" id="npGrand"></span>
              <span class="np-title" id="npTitle"></span>
            </div>
            <div class="np-meta">
              <span class="np-player" id="npPlayer"></span>
              <span class="np-pct" id="npPct"></span>
            </div>
          </div>
          <!-- Barre de progression -->
          <div class="np-bar-track">
            <div class="np-bar-fill" id="npBarFill" style="width:0%"></div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- XP ROW : carte succès + barre progression -->
  <div class="xp-row-layout">

    <!-- GAUCHE : succès -->
    <div class="xp-left-card">
      <div class="xp-left-icon">🏆</div>
      <div class="xp-left-label">Succès</div>
      <div class="xp-left-count"><span id="xpUnlockedCount"><%= unlockedBadgesCount || 0 %>&nbsp;/&nbsp;<%= totalBadgesCount || 0 %></span></div>
      <button class="action-pill action-pill--gold" onclick="openSuccesModal()">Voir mes succès →</button>
    </div>

    <!-- DROITE : barre XP -->
    <div class="xp-progress-section">
      <div class="progress-header">
        <span>Progression vers le niveau suivant</span>
        <span class="xp-needed" id="xpNeeded">-</span>
      </div>
      <div class="xp-bar-wrapper">
        <div class="xp-bar-fill" id="xpBarFill"></div>
      </div>
    </div>

  </div>

  <!-- GRID DE CARTES -->
  <div class="profil-grid">
    <!-- CARTE PROFIL -->
    <div class="profil-card">
      <h2>👤 Profil</h2>
      <div class="card-content">
        <div class="stat-row">
          <span class="stat-label">Inscrit depuis</span>
          <span class="stat-value skel" id="joinedDate"></span>
        </div>
        <div class="stat-row">
          <span class="stat-label">Dernière activité</span>
          <span class="stat-value skel" id="lastActivity"></span>
        </div>
      </div>
    </div>

    <!-- CARTE ABONNEMENT -->
    <div class="profil-card profil-sub-card" id="profilSubCard">
      <h2>📅 Abonnement</h2>
      <div class="card-content">
        <div class="subscription-row">
          <span class="label">Statut</span>
          <span class="status-badge skel" id="profilSubStatus"></span>
        </div>
        <div class="subscription-row">
          <span class="label">Jours restants</span>
          <span class="value skel" id="profilSubDays"></span>
        </div>
        <div class="subscription-row">
          <span class="label">Expire le</span>
          <span class="value skel" id="profilSubExpire"></span>
        </div>
        <div class="progress-wrapper">
          <div class="progress-bar">
            <div class="progress" id="profilSubProgress" style="width:0%"></div>
          </div>
        </div>
      </div>
    </div>

    <!-- CARTE REQUÊTES -->
    <div class="profil-card">
      <h2><img src="<%= basePath %>/img/seerr-icon.png" alt="Seerr" class="card-header-logo"> Demandes</h2>
      <div class="card-content">
        <div class="stat-row">
          <span class="stat-label">Total demandes</span>
          <span class="stat-value skel" id="totalRequests"></span>
        </div>
        <div class="stat-row">
          <span class="stat-label">Approuvées</span>
          <span class="stat-value approved skel" id="approvedRequests"></span>
        </div>
        <div class="stat-row">
          <span class="stat-label">En attente</span>
          <span class="stat-value pending skel" id="pendingRequests"></span>
        </div>
        <div class="stat-row">
          <span class="stat-label">Disponibles</span>
          <span class="stat-value available skel" id="availableRequests"></span>
        </div>
      </div>
    </div>
  </div>

  <!-- 📊 SECTION STATISTIQUES DE VISIONNAGE -->
  <div class="watch-stats-section">
    <div class="stats-header">
      <h2>📊 Statistiques de Visionnage</h2>
      <p class="stats-subtitle">Votre historique complet</p>
    </div>
    
    <div class="stats-grid">
      <!-- Carte : Lectures Totales -->
      <div class="stat-card">
        <div class="stat-icon">📊</div>
        <div class="stat-content">
          <p class="stat-label">Lectures Totales</p>
          <div class="stat-value counter skel" id="counterSessions" data-target="0"></div>
          <p class="stat-sub skel" id="statTotalHours"></p>
        </div>
      </div>

      <!-- Carte : Films Regardés -->
      <div class="stat-card">
        <div class="stat-icon">🎬</div>
        <div class="stat-content">
          <p class="stat-label">Films Regardés</p>
          <div class="stat-value counter skel" id="counterMovies" data-target="0"></div>
          <p class="stat-sub skel" id="statMovieHours"></p>
        </div>
      </div>

      <!-- Carte : Épisodes Regardés -->
      <div class="stat-card">
        <div class="stat-icon">📺</div>
        <div class="stat-content">
          <p class="stat-label">Épisodes Regardés</p>
          <div class="stat-value counter skel" id="counterEpisodes" data-target="0"></div>
          <p class="stat-sub skel" id="statEpisodeHours"></p>
        </div>
      </div>

      <!-- Carte : Musique & Livres audio -->
      <div class="stat-card">
        <div class="stat-icon">🎵</div>
        <div class="stat-content">
          <p class="stat-label">Musique & Livres audio</p>
          <div class="stat-value counter skel" id="counterMusic" data-target="0"></div>
          <p class="stat-sub skel" id="statMusicHours"></p>
        </div>
      </div>
    </div>
  </div>

  <!-- SECTION SUCCÈS -->
  <div class="badges-section">
    <div class="badges-header-with-link">
      <h2>🏆 Progression des Badges</h2>
      <button class="action-pill" onclick="openXpModal()">⚡ Répartition XP →</button>
    </div>
    <div class="badges-container" id="badgesContainer"></div>
  </div>

  <!-- MODAL SUCCÈS (chargé via fetch embed) -->
  <div id="succesModal" class="xp-modal" onclick="if(event.target===this)closeSuccesModal()">
    <div class="xp-modal-content xp-modal-content--wide" id="succesModalContent">
      <div class="xp-modal-header">
        <h3>🏆 Mes Succès</h3>
        <button class="xp-modal-close" onclick="closeSuccesModal()">✕</button>
      </div>
      <div id="succesModalBody" style="min-height:120px;display:flex;align-items:center;justify-content:center;color:#aaa">
        Chargement...
      </div>
    </div>
  </div>

  <!-- MODAL RÉPARTITION XP -->
  <div id="xpModal" class="xp-modal" onclick="if(event.target===this)closeXpModal()">
    <div class="xp-modal-content">
      <div class="xp-modal-header">
        <h3>⚡ Répartition de mon XP</h3>
        <button class="xp-modal-close" onclick="closeXpModal()">✕</button>
      </div>
  <div class="xp-breakdown">
    
    <div class="xp-breakdown-grid">
      <!-- SOURCES D'XP -->
      <div class="xp-sources">
        <h4>Sources d'XP</h4>
        
        <div class="xp-source">
          <div class="source-header">
            <span class="source-name">⏱️ Heures visionnées</span>
            <span class="source-value" id="xpHoursValue">0</span>
          </div>
          <div class="source-bar">
            <div class="source-bar-fill hours" id="xpHoursBar" style="width: 0%"></div>
          </div>
          <div class="source-percent">
            <span id="xpHoursPercent">0%</span>
          </div>
        </div>

        <div class="xp-source">
          <div class="source-header">
            <span class="source-name">🏅 Succès débloqués</span>
            <span class="source-value" id="xpBadgesValue">0</span>
          </div>
          <div class="source-bar">
            <div class="source-bar-fill badges" id="xpBadgesBar" style="width: 0%"></div>
          </div>
          <div class="source-percent">
            <span id="xpBadgesPercent">0%</span>
          </div>
        </div>

        <div class="xp-source">
          <div class="source-header">
            <span class="source-name">📅 Ancienneté</span>
            <span class="source-value" id="xpAncienneteValue">0</span>
          </div>
          <div class="source-bar">
            <div class="source-bar-fill anciennete" id="xpAncienneteBar" style="width: 0%"></div>
          </div>
          <div class="source-percent">
            <span id="xpAnciennetePercent">0%</span>
          </div>
        </div>

        <div class="xp-multipliers" id="xpMultipliersHint">
          Multiplicateurs: Heures = x10 XP/h • Ancienneté = x1.5 XP/jour
        </div>
      </div>

      <!-- DÉTAILS PAR CATÉGORIE -->
      <div class="xp-details">
        <h4>Détails par catégorie</h4>
        
        <div class="detail-card hours-card">
          <div class="detail-icon">⏱️</div>
          <div class="detail-info">
            <div class="detail-label">Heures visionnées</div>
            <div class="detail-value" id="detailProfilHours">0h</div>
          </div>
        </div>

        <div class="detail-card badges-card">
          <div class="detail-icon">🏅</div>
          <div class="detail-info">
            <div class="detail-label">Succès débloqués</div>
            <div class="detail-value" id="detailProfilBadges"><%= unlockedBadgesCount %><%= totalBadgesCount ? '/' + totalBadgesCount : '' %></div>
          </div>
        </div>

        <div class="detail-card anciennete-card">
          <div class="detail-icon">📅</div>
          <div class="detail-info">
            <div class="detail-label">Jours depuis inscription</div>
            <div class="detail-value" id="detailProfilAnciennete">0 j</div>
          </div>
        </div>
      </div>
    </div>
  </div>
    </div>
  </div>
</div>

<style>
  .profil-container {
    max-width: 1000px;
    margin: 0 auto;
  }

  /* HEADER */
  .profil-header {
    display: flex;
    align-items: center;
    gap: 30px;
    margin-bottom: 40px;
    padding: 30px;
    background: rgba(14, 22, 34, 0.008);
    border-radius: 16px;
    border: 1px solid rgba(226, 246, 255, 0.42);
    box-shadow:
      0 14px 34px rgba(0,0,0,.18),
      0 0 0 1px rgba(232, 248, 255, 0.20) inset,
      0 4px 10px rgba(98, 178, 255, 0.04);
    backdrop-filter: blur(7px) saturate(120%) contrast(1.01) brightness(1.02);
    -webkit-backdrop-filter: blur(7px) saturate(120%) contrast(1.01) brightness(1.02);
    position: relative;
    overflow: hidden;
    isolation: isolate;
  }

  .profil-header::before {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    background:
      linear-gradient(150deg, rgba(255,255,255,0.05), rgba(255,255,255,0.010) 28%, rgba(255,255,255,0.00) 64%);
    z-index: 0;
  }

  .profil-header::after {
    content: "";
    position: absolute;
    inset: -35%;
    pointer-events: none;
    background:
      radial-gradient(circle at 18% 12%, rgba(255,255,255,0.07), rgba(255,255,255,0.012) 24%, rgba(255,255,255,0) 50%),
      radial-gradient(circle at 82% 78%, rgba(86, 186, 255, 0.05), rgba(86, 186, 255, 0) 48%);
    filter: blur(2px);
    transform: rotate(-8deg);
    z-index: 0;
  }

  .profil-header > * {
    position: relative;
    z-index: 1;
  }

  /* =====================
     NOW PLAYING — redesign
  ===================== */
  .now-playing-widget {
    margin-left: auto;
    position: relative;
    width: 300px;
    height: 90px;
    border-radius: 14px;
    overflow: hidden;
    flex-shrink: 0;
    box-shadow: 0 8px 32px rgba(0,0,0,0.5);
    animation: npFadeIn 0.5s cubic-bezier(.22,.68,0,1.2);
    border: 1px solid rgba(255,255,255,0.08);
  }
  @keyframes npFadeIn {
    from { opacity:0; transform:translateX(20px) scale(.97); }
    to   { opacity:1; transform:translateX(0)   scale(1); }
  }

  /* Fond = affiche floutée */
  .np-bg {
    position: absolute;
    inset: -10px;
    background-size: cover;
    background-position: center;
    filter: blur(18px) brightness(0.35) saturate(1.4);
    transform: scale(1.1);
    transition: background-image 0.6s ease;
  }
  .np-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(90deg,
      rgba(0,0,0,0.15) 0%,
      rgba(0,0,0,0.05) 40%,
      rgba(0,0,0,0.45) 100%);
  }

  /* Contenu par-dessus */
  .np-inner {
    position: relative;
    z-index: 2;
    display: flex;
    align-items: stretch;
    height: 100%;
  }

  /* Affiche */
  .np-poster-wrap {
    flex-shrink: 0;
    width: 62px;
    height: 90px;
    overflow: hidden;
  }
  .np-poster {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* Corps texte */
  .np-body {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding: 10px 14px 0 12px;
    min-width: 0;
  }
  .np-top { display: flex; flex-direction: column; gap: 3px; min-width: 0; }

  /* Ligne état */
  .np-state-row {
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .np-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: #e5a00d;
    box-shadow: 0 0 6px #e5a00d;
    flex-shrink: 0;
    animation: npPulse 1.8s ease-in-out infinite;
  }
  @keyframes npPulse {
    0%,100% { opacity: 1; box-shadow: 0 0 6px #e5a00d; }
    50%      { opacity: 0.5; box-shadow: 0 0 12px #e5a00d; }
  }
  .np-label {
    font-size: 0.58rem;
    font-weight: 800;
    letter-spacing: 0.12em;
    color: #e5a00d;
    text-transform: uppercase;
  }

  /* Titres */
  .np-titles { display: flex; flex-direction: column; gap: 1px; min-width: 0; }
  .np-grand {
    font-size: 0.7rem;
    color: rgba(255,255,255,0.6);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .np-title {
    font-size: 0.92rem;
    font-weight: 700;
    color: #fff;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    text-shadow: 0 1px 4px rgba(0,0,0,0.8);
  }

  /* Méta (device + %) */
  .np-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    min-width: 0;
  }
  .np-player {
    font-size: 0.62rem;
    color: rgba(255,255,255,0.45);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .np-pct {
    font-size: 0.62rem;
    color: rgba(255,255,255,0.4);
    flex-shrink: 0;
    margin-left: 6px;
  }

  /* Barre de progression */
  .np-bar-track {
    height: 3px;
    background: rgba(255,255,255,0.15);
    border-radius: 0 0 0 0;
    overflow: hidden;
    margin: 0 -14px 0 -12px;
  }
  .np-bar-fill {
    height: 100%;
    background: linear-gradient(90deg, #e5a00d, #f59e0b);
    border-radius: 0;
    transition: width 1s linear;
  }

  /* Pause — tout grisé */
  .np-paused .np-dot  { background:#94a3b8; box-shadow:0 0 4px #94a3b8; animation:none; opacity:.7; }
  .np-paused .np-label { color:#94a3b8; }
  .np-paused .np-bar-fill { background: #94a3b8; }

  /* Dernière lecture — grisé discret */
  .np-last-played .np-dot  { background:#4a5568; box-shadow:none; animation:none; opacity:.5; }
  .np-last-played .np-label { color:#718096; }
  .np-last-played .np-bar-track { display:none; }

  .avatar-wrapper {
    position: relative;
    flex-shrink: 0;
    width: 100px;
    height: 100px;
  }

  /* Profil : anneau de 4px autour de 100px = inset -5px → 110px */
  .avatar-wrapper .rank-ring {
    inset: -5px;
    -webkit-mask: radial-gradient(farthest-side, transparent calc(100% - 4px), #fff calc(100% - 4px));
    mask: radial-gradient(farthest-side, transparent calc(100% - 4px), #fff calc(100% - 4px));
  }

  .profile-avatar {
    width: 100px;
    height: 100px;
    border-radius: 50%;
    object-fit: cover;
    display: block;
    position: relative;
    z-index: 1;
  }

  .profile-info {
    flex: 1;
  }

  .profile-info h1 {
    font-size: 24px;
    font-weight: 700;
    margin: 0 0 8px 0;
    color: #fff;
  }

  .profile-email {
    color: #aaa;
    margin: 0 0 15px 0;
  }

  .xp-status {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .xp-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 6px 14px;
    background: rgba(91, 155, 213, 0.2);
    color: #5B9BD5;
    border-radius: 20px;
    font-size: 13px;
    font-weight: 600;
    border: 1px solid rgba(91, 155, 213, 0.5);
    transition: background 0.4s ease, border-color 0.4s ease, box-shadow 0.4s ease;
    white-space: nowrap;
  }
  .xp-level-num {
    font-weight: 700;
    letter-spacing: 0.5px;
  }
  .xp-rank-sep {
    opacity: 0.45;
    font-size: 11px;
    padding: 0 1px;
  }
  .xp-rank-name {
    font-size: 12px;
  }

  .xp-amount {
    font-size: 14px;
    color: #00d9ff;
  }

  /* XP PROGRESS */
  /* XP ROW LAYOUT */
  .xp-row-layout {
    display: flex;
    gap: 16px;
    margin-bottom: 24px;
    align-items: stretch;
  }

  /* CARTE GAUCHE SUCCÈS */
  .xp-left-card {
    flex: 0 0 140px;
    background: rgba(14, 22, 34, 0.012);
    border: 1px solid rgba(226, 246, 255, 0.42);
    border-radius: 12px;
    padding: 14px 12px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 6px;
    text-align: center;
  }

  .xp-left-icon {
    font-size: 22px;
    line-height: 1;
  }

  .xp-left-label {
    font-size: 12px;
    font-weight: 700;
    color: #fff;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .xp-left-count {
    font-size: 11px;
    color: #aaa;
    min-height: 14px;
  }

  /* BARRE XP DROITE */
  .xp-progress-section {
    flex: 1;
    background: rgba(14, 22, 34, 0.012);
    padding: 14px 18px;
    border-radius: 12px;
    border: 1px solid rgba(226, 246, 255, 0.42);
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  /* Preset glass cohérent avec la carte login */
  .profil-card,
  .xp-left-card,
  .xp-progress-section,
  .watch-stats-section,
  .badges-section,
  .detail-card,
  .watch-stats-section .stat-card {
    background: rgba(14, 22, 34, 0.012);
    border: 1px solid rgba(226, 246, 255, 0.42);
    box-shadow:
      0 14px 34px rgba(0,0,0,.18),
      0 0 0 1px rgba(232, 248, 255, 0.20) inset,
      0 4px 10px rgba(98, 178, 255, 0.04);
    backdrop-filter: blur(3px) saturate(112%) contrast(1.01) brightness(1.02);
    -webkit-backdrop-filter: blur(3px) saturate(112%) contrast(1.01) brightness(1.02);
    position: relative;
    overflow: hidden;
    isolation: isolate;
  }

  .profil-card::before,
  .xp-left-card::before,
  .xp-progress-section::before,
  .watch-stats-section::before,
  .badges-section::before,
  .detail-card::before,
  .watch-stats-section .stat-card::before {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    background:
      linear-gradient(150deg, rgba(255,255,255,0.06), rgba(255,255,255,0.012) 28%, rgba(255,255,255,0.00) 64%);
    z-index: 0;
  }

  .profil-card::after,
  .xp-left-card::after,
  .xp-progress-section::after,
  .watch-stats-section::after,
  .badges-section::after,
  .detail-card::after,
  .watch-stats-section .stat-card::after {
    content: "";
    position: absolute;
    inset: -35%;
    pointer-events: none;
    background:
      radial-gradient(circle at 18% 12%, rgba(255,255,255,0.08), rgba(255,255,255,0.014) 24%, rgba(255,255,255,0) 50%),
      radial-gradient(circle at 82% 78%, rgba(86, 186, 255, 0.05), rgba(86, 186, 255, 0) 48%);
    filter: blur(3px);
    transform: rotate(-8deg);
    z-index: 0;
