            <span class="stat-label">Jours restants</span>
            <span class="stat-value">${subscriptionData.daysLeft}</span>
          </div>
          ` : ''}
          ${subscriptionData.expiresAt ? `
          <div class="stat-row">
            <span class="stat-label">Expire le</span>
            <span class="stat-value">${subscriptionData.expiresAt}</span>
          </div>
          ` : ''}
        `;
        if (subCardEl) {
          subCardEl.innerHTML = subHtml;
          console.log("[PROFIL] ✅ Abonnement affiché");
        }
      } else if (subCardEl) {
        subCardEl.innerHTML = `<p style="color: #aaa;">Aucune donnée d'abonnement disponible</p>`;
      }
      
      // ÉTAPE 3: Charger Tautulli en PARALLÈLE (peut prendre du temps)
      console.log("[PROFIL] Chargement Tautulli en arrière-plan (avec polling)...");
      const tautulliRes = await Promise.allSettled([loadTautulliStats()]);
      
      // Extraire les données Tautulli du promise
      const tautulliData = tautulliRes[0].status === 'fulfilled' ? tautulliRes[0].value || {} : {};
      const stats = tautulliData;
      const overseerr = overseerrData;
      const subscription = subscriptionData;

      console.log("[PROFIL] ✅ Données chargées - Tautulli:", tautulliData);

      // ===== AFFICHER LES STATS DE VISIONNAGE (Watch Stats) =====
      if (tautulliData && tautulliData.watchStats) {
        const watchStats = tautulliData.watchStats;
        console.log("[WATCH-STATS] 📊 Mise à jour des compteurs:", watchStats);
        
        // Heures
        const hoursEl = document.getElementById('counterHours');
        if (hoursEl) {
          const hours = Math.round(watchStats.totalHours * 10) / 10;
          hoursEl.textContent = hours;
          hoursEl.setAttribute('data-target', hours);
          console.log("[WATCH-STATS] ✅ Heures:", hours);
        }
        
        // Films
        const moviesEl = document.getElementById('counterMovies');
        if (moviesEl) {
          moviesEl.textContent = watchStats.movieCount || 0;
          moviesEl.setAttribute('data-target', watchStats.movieCount || 0);
          console.log("[WATCH-STATS] ✅ Films:", watchStats.movieCount);
        }
        
        // Épisodes
        const episodesEl = document.getElementById('counterEpisodes');
        if (episodesEl) {
          episodesEl.textContent = watchStats.episodeCount || 0;
          episodesEl.setAttribute('data-target', watchStats.episodeCount || 0);
          console.log("[WATCH-STATS] ✅ Épisodes:", watchStats.episodeCount);
        }
        
        // Sessions (Lectures Totales)
        const sessionsEl = document.getElementById('counterSessions');
        if (sessionsEl) {
          sessionsEl.textContent = tautulliData.sessionCount || 0;
          sessionsEl.setAttribute('data-target', tautulliData.sessionCount || 0);
          console.log("[WATCH-STATS] ✅ Sessions:", tautulliData.sessionCount);
        }
        
        console.log("[WATCH-STATS] 🎉 Compteurs mis à jour");
      }

      // Afficher les stats Tautulli
      const joinedEl = document.getElementById("joinedDate");
      const activityEl = document.getElementById("lastActivity");
      console.log("[DOM] joinedDate element:", joinedEl);
      console.log("[DOM] lastActivity element:", activityEl);
      
      // Déclarer les variables que nous utiliserons partout
      let tautulliSessionCount = 0;
      
      // Vérifier si les données sont en cours de calcul
      if (stats.status === "computing") {
        console.log("[DOM] Stats en cours de calcul - afficher message");
        if (joinedEl) joinedEl.textContent = "En cours...";
        if (activityEl) activityEl.textContent = "En cours...";
        const sessionEl = document.getElementById("sessionCount");
        const sessionEl2 = document.getElementById("sessionCount2");
        if (sessionEl) sessionEl.textContent = "Calcul en cours...";
        if (sessionEl2) sessionEl2.textContent = "Calcul en cours...";
        tautulliSessionCount = 0;
      } else {
        if (joinedEl) joinedEl.textContent = stats.joinedAt ? formatFullDate(stats.joinedAt) : "N/A";
        if (activityEl) activityEl.textContent = stats.lastActivity ? formatRelativeTime(stats.lastActivity) : "Aucune";

        tautulliSessionCount = stats.sessionCount || 0;
        const sessionEl = document.getElementById("sessionCount");
        const sessionEl2 = document.getElementById("sessionCount2");
        console.log("[DOM] sessionCount element:", sessionEl, "value:", tautulliSessionCount);
        
        if (sessionEl) sessionEl.textContent = tautulliSessionCount;
        if (sessionEl2) sessionEl2.textContent = tautulliSessionCount + " sessions";
      }

      // Calculer l'XP (basé sur les heures de visionnage)
      const totalHours = tautulliData?.watchStats?.totalHours || 0;
      const totalXp = Math.round(totalHours);
      console.log("[XP] Calcul: " + Math.round(totalHours * 10) / 10 + " heures × 1 = " + totalXp + " XP");
      
      const badge = XP_SYSTEM.getBadgeByXp(totalXp);
      const progress = XP_SYSTEM.getProgressToNextBadge(totalXp);
      console.log("[BADGE] Badge calculé:", badge.name);

      // Couleur avatar selon badge
      const avatarEl = document.getElementById("profileAvatar");
      const badgeRing = document.getElementById("badgeRing");
      console.log("[DOM] avatarEl:", !!avatarEl, "badgeRing:", !!badgeRing);
      
      if (avatarEl) {
        avatarEl.style.borderColor = badge.borderColor;
        console.log("[AVATAR] Couleur appliquée:", badge.borderColor);
      }
      if (badgeRing) {
        badgeRing.style.borderColor = badge.borderColor;
      }

      // Afficher badge et XP
      const xpBadgeEl = document.getElementById("xpBadge");
      const xpAmountEl = document.getElementById("xpAmount");
      console.log("[DOM] xpBadge:", !!xpBadgeEl, "xpAmount:", !!xpAmountEl);
      
      if (xpBadgeEl) {
        xpBadgeEl.textContent = `${badge.icon} ${badge.name}`;
        xpBadgeEl.style.background = badge.bgColor;
        xpBadgeEl.style.color = badge.color;
        xpBadgeEl.style.borderColor = badge.borderColor;
      }
      if (xpAmountEl) {
        xpAmountEl.textContent = `${totalXp} XP`;
      }

      // Barre de progression
      const xpBarFill = document.getElementById("xpBarFill");
      const xpNeeded = document.getElementById("xpNeeded");
      console.log("[XP-PROGRESS] Sélecteurs - xpBarFill:", !!xpBarFill, "xpNeeded:", !!xpNeeded);
      console.log("[XP-PROGRESS] Total XP:", totalXp, "Progress:", progress);
      
      if (xpBarFill) {
        const percent = progress.progressPercent || 0;
        xpBarFill.style.width = percent + "%";
        console.log("[XP-PROGRESS] ✅ Barre mise à jour - width:", percent + "%");
      } else {
        console.error("[XP-PROGRESS] ❌ xpBarFill non trouvé!");
      }
      
      if (xpNeeded) {
        xpNeeded.textContent = progress.xpNeeded > 0 ? `${progress.xpNeeded} XP avant ${progress.next?.name || "max"}` : "Max atteint!";
      }

      // CALCUL XP BREAKDOWN avec 3 sources
      const XP_MULTIPLIERS = {
        HOURS: 8,
        BADGE: 140,
        ANCIENNETE: 5,
        LEVEL: 100
      };

      const hoursXp = Math.round(totalHours * XP_MULTIPLIERS.HOURS);
      const badgesXp = 0; // À améliorer avec nombre de badges réels
      const daysJoined = Math.floor((Date.now() - (joinedAtObj.getTime())) / (1000 * 60 * 60 * 24));
      const ancienneteXp = daysJoined * XP_MULTIPLIERS.ANCIENNETE;

      const totalXpBreakdown = hoursXp + badgesXp + ancienneteXp;
      
      // Calculer les pourcentages
      const hoursPercent = totalXpBreakdown > 0 ? Math.round((hoursXp / totalXpBreakdown) * 100) : 0;
      const badgesPercent = totalXpBreakdown > 0 ? Math.round((badgesXp / totalXpBreakdown) * 100) : 0;
      const anciennetePercent = totalXpBreakdown > 0 ? Math.round((ancienneteXp / totalXpBreakdown) * 100) : 0;

      // Mettre à jour les sources d'XP
      const xpHoursValue = document.getElementById("xpHoursValue");
      const xpHoursBar = document.getElementById("xpHoursBar");
      const xpHoursPercent = document.getElementById("xpHoursPercent");
      
      if (xpHoursValue) xpHoursValue.textContent = hoursXp.toLocaleString() + " XP";
      if (xpHoursBar) xpHoursBar.style.width = hoursPercent + "%";
      if (xpHoursPercent) xpHoursPercent.textContent = hoursPercent + "%";

      const xpBadgesValue = document.getElementById("xpBadgesValue");
      const xpBadgesBar = document.getElementById("xpBadgesBar");
      const xpBadgesPercent = document.getElementById("xpBadgesPercent");
      
      if (xpBadgesValue) xpBadgesValue.textContent = badgesXp.toLocaleString() + " XP";
      if (xpBadgesBar) xpBadgesBar.style.width = badgesPercent + "%";
      if (xpBadgesPercent) xpBadgesPercent.textContent = badgesPercent + "%";

      const xpAncienneteValue = document.getElementById("xpAncienneteValue");
      const xpAncienneteBar = document.getElementById("xpAncienneteBar");
      const xpAnciennetePercent = document.getElementById("xpAnciennetePercent");
      
      if (xpAncienneteValue) xpAncienneteValue.textContent = ancienneteXp.toLocaleString() + " XP";
      if (xpAncienneteBar) xpAncienneteBar.style.width = anciennetePercent + "%";
      if (xpAnciennetePercent) xpAnciennetePercent.textContent = anciennetePercent + "%";

      // Mettre à jour les détails par catégorie
      const detailProfilHours = document.getElementById("detailProfilHours");
      const detailProfilBadges = document.getElementById("detailProfilBadges");
      const detailProfilAnciennete = document.getElementById("detailProfilAnciennete");
      
      if (detailProfilHours) detailProfilHours.textContent = Math.round(totalHours * 10) / 10 + "h";
      if (detailProfilBadges) detailProfilBadges.textContent = "0/46"; // À mettre à jour
      if (detailProfilAnciennete) detailProfilAnciennete.textContent = daysJoined + " j";

      // Formules XP (anciens éléments - les cacher)
      const formulaSessionEl = document.getElementById("sessionFormulaXp");
      const formulaTotalEl = document.getElementById("totalXpFormula");
      console.log("[DOM] FormulaSessions:", !!formulaSessionEl);
      
      if (formulaSessionEl) formulaSessionEl.style.display = "none";
      if (formulaTotalEl) formulaTotalEl.style.display = "none";

      // Activer les badges débloqués
      const badgeItems = document.querySelectorAll(".badge-item");
      console.log("[BADGES] Nombre de badges trouvés:", badgeItems.length, "Total XP:", totalXp);
      
      badgeItems.forEach(item => {
        const level = parseInt(item.dataset.level);
        const badgeData = XP_SYSTEM.badges[level - 1];
        if (totalXp >= badgeData.minXp) {
          item.classList.add("unlocked");
          console.log("[BADGES] Débloqué - Level", level, '(', badgeData.minXp, 'XP)');
        }
      });

      // Rafraîchissement automatique si calcul en cours
      if (stats.status === "computing") {
        console.log("[PROFIL] � Calcul en cours - Attente SMART (au lieu de 30 polls)...");
        
        // Attendre que le scan finisse (via long-poll)
        // Puis mettre à jour les éléments DOM sans reload
        (async () => {
          try {
            console.log("[PROFIL-UPDATE] Attente du scan Tautulli...");
            const waitRes = await fetch(basePath ? `${basePath}/api/stats-wait` : "/api/stats-wait");
            
            if (!waitRes.ok) throw new Error("Wait API error");
            
            const readyStats = await waitRes.json();
            console.log("[PROFIL-UPDATE] ✅ Scan terminé! Mise à jour dynamique...", readyStats);
            
            // Update sessionCount
            const sessionEl = document.getElementById("sessionCount");
            if (sessionEl && readyStats.sessionCount !== undefined) {
              sessionEl.textContent = readyStats.sessionCount;
            }
            
            // Update xpAmount (recalcul XP basé sur les heures)
            const newTotalHours = readyStats?.watchStats?.totalHours || 0;
            const newTotalXp = Math.round(newTotalHours);
            const xpAmountEl = document.getElementById("xpAmount");
            if (xpAmountEl) {
              xpAmountEl.textContent = newTotalXp;
            }
            
            // Update badges
            const badgeItems = document.querySelectorAll(".badge-item");
            badgeItems.forEach(item => {
              item.classList.remove("unlocked");
              const level = parseInt(item.dataset.level);
              const badgeData = XP_SYSTEM.badges[level - 1];
              if (newTotalXp >= badgeData.minXp) {
                item.classList.add("unlocked");
              }
            });
            
            // Update formules / sources d'XP
            const newHoursXp = Math.round(newTotalHours * 8);
            const newDaysJoined = Math.floor((Date.now() - (new Date(readyStats.joinedAt).getTime())) / (1000 * 60 * 60 * 24));
            const newAncienneteXp = newDaysJoined * 5;
            const newTotalXpBreakdown = newHoursXp + 0 + newAncienneteXp;
            
            const newHoursPercent = newTotalXpBreakdown > 0 ? Math.round((newHoursXp / newTotalXpBreakdown) * 100) : 0;
            const newAnciennetePercent = newTotalXpBreakdown > 0 ? Math.round((newAncienneteXp / newTotalXpBreakdown) * 100) : 0;
            
            const xpHoursValue = document.getElementById("xpHoursValue");
            const xpHoursBar = document.getElementById("xpHoursBar");
            const xpHoursPercent = document.getElementById("xpHoursPercent");
            
            if (xpHoursValue) xpHoursValue.textContent = newHoursXp.toLocaleString() + " XP";
            if (xpHoursBar) xpHoursBar.style.width = newHoursPercent + "%";
            if (xpHoursPercent) xpHoursPercent.textContent = newHoursPercent + "%";
            
            const xpAncienneteValue = document.getElementById("xpAncienneteValue");
            const xpAncienneteBar = document.getElementById("xpAncienneteBar");
            const xpAnciennetePercent = document.getElementById("xpAnciennetePercent");
            
            if (xpAncienneteValue) xpAncienneteValue.textContent = newAncienneteXp.toLocaleString() + " XP";
            if (xpAncienneteBar) xpAncienneteBar.style.width = newAnciennetePercent + "%";
            if (xpAnciennetePercent) xpAnciennetePercent.textContent = newAnciennetePercent + "%";
            
            const detailProfilHours = document.getElementById("detailProfilHours");
            const detailProfilAnciennete = document.getElementById("detailProfilAnciennete");
            
            if (detailProfilHours) detailProfilHours.textContent = Math.round(newTotalHours * 10) / 10 + "h";
            if (detailProfilAnciennete) detailProfilAnciennete.textContent = newDaysJoined + " j";
            
            // Old formulas (hide)
            const formulaSessionEl = document.getElementById("sessionFormulaXp");
            const formulaTotalEl = document.getElementById("totalXpFormula");
            
            if (formulaSessionEl) formulaSessionEl.style.display = "none";
            if (formulaTotalEl) formulaTotalEl.style.display = "none";
            
            // Update badge and avatar color
            const newBadge = XP_SYSTEM.getBadgeByXp(newTotalXp);
            const avatarEl = document.getElementById("profileAvatar");
            const badgeRing = document.getElementById("badgeRing");
            const xpBadgeEl = document.getElementById("xpBadge");
            
            if (avatarEl) avatarEl.style.borderColor = newBadge.borderColor;
            if (badgeRing) badgeRing.style.borderColor = newBadge.borderColor;
            if (xpBadgeEl) {
              xpBadgeEl.textContent = `${newBadge.icon} ${newBadge.name}`;
              xpBadgeEl.style.background = newBadge.bgColor;
              xpBadgeEl.style.color = newBadge.color;
              xpBadgeEl.style.borderColor = newBadge.borderColor;
            }
            
            // Update progress bar
            const newProgress = XP_SYSTEM.getProgressToNextBadge(newTotalXp);
            const xpBarFill = document.getElementById("xpBarFill");
            const xpNeeded = document.getElementById("xpNeeded");
            
            if (xpBarFill) {
              xpBarFill.style.width = newProgress.progressPercent + "%";
            }
            if (xpNeeded) {
              xpNeeded.textContent = newProgress.xpNeeded > 0 ? `${newProgress.xpNeeded} XP avant ${newProgress.next?.name || "max"}` : "Max atteint!";
            }
            
            console.log("[PROFIL-UPDATE] ✅ Tous les éléments mis à jour!");
          } catch (err) {
            console.error("[PROFIL-UPDATE] ❌ Erreur:", err.message);
            setTimeout(() => window.location.reload(), 5000);
          }
        })();
      }

      console.log("[PROFIL] ✅ Chargement terminé!");
    } catch(err) {
      console.error("[PROFIL] ❌ Erreur:", err);
    }
  });
</script>
