    animation: xp-shimmer 1.5s ease-in-out infinite;
    color: transparent !important;
    border-color: transparent !important;
    pointer-events: none;
  }
  @keyframes xp-shimmer {
    0%   { background-position: 200% 0; }
    100% { background-position: -200% 0; }
  }
</style>

<script>
  // ─── Système de rangs et niveaux ───────────────────────────────────
  const XP_PAR_NIVEAU = 1000;
  const XP_SYSTEM = <%- JSON.stringify({ranks: XP_SYSTEM.ranks}) %>;
  XP_SYSTEM.badges = XP_SYSTEM.ranks; // backward-compat
  XP_SYSTEM.getLevel          = function(xp) { return Math.floor((xp || 0) / XP_PAR_NIVEAU) + 1; };
  XP_SYSTEM.getRankByLevel    = function(lvl) { return this.ranks.find(r => lvl >= r.minLevel && lvl <= r.maxLevel) || this.ranks[this.ranks.length - 1]; };
  XP_SYSTEM.getRankByXp       = function(xp)  { return this.getRankByLevel(this.getLevel(xp)); };
  XP_SYSTEM.getBadgeByXp      = function(xp)  { return this.getRankByXp(xp); };
  XP_SYSTEM.getProgressToNextLevel = function(xp) {
    xp = xp || 0;
    const level     = this.getLevel(xp);
    const rank      = this.getRankByLevel(level);
    const xpInLevel = xp % XP_PAR_NIVEAU;
    return {
      current: rank, next: this.getRankByLevel(level + 1),
      level, nextLevel: level + 1, currentXp: xp,
      progressPercent: Math.floor((xpInLevel / XP_PAR_NIVEAU) * 100),
      xpNeeded: XP_PAR_NIVEAU - xpInLevel
    };
  };
  XP_SYSTEM.getProgressToNextBadge = function(xp) { return this.getProgressToNextLevel(xp); };

  /* ===============================
     💾 XP SNAPSHOT — stale-while-revalidate
     Stocke le dernier XP calculé en localStorage pour un affichage
     instantané (sans flash "Bronze / 0 XP") à la prochaine visite.
  =============================== */

  // Clé unique par utilisateur, max 5 min de validité (synchro avec le refresh classement)
  const _XP_CACHE_KEY = () => `xp_snapshot_${document.body.getAttribute("data-user-id") || "guest"}`;
  const _XP_CACHE_TTL  = 5 * 60 * 1000;

  // ─── Applique le rang coloré sur avatar ring + barre XP ──────────────
  function _rankGrad(c) {
    return `conic-gradient(from -90deg, ${c}2e 0deg, ${c} 90deg, ${c}cc 180deg, ${c} 270deg, ${c}2e 360deg)`;
  }
  function applyRankGlow(color) {
    const ringEl    = document.getElementById("profilRankRing");
    const wrapperEl = document.getElementById("avatarWrapper");
    const xpBarFill = document.getElementById("xpBarFill");
    if (ringEl) {
      ringEl.style.background = _rankGrad(color);
      // Pas de boxShadow ici : le mask coupe l'ombre portée
    }
    // Halo sur le wrapper NON masqué → drop-shadow suit la forme du ring et respire avec l'animation
    if (wrapperEl) wrapperEl.style.filter = `drop-shadow(0 0 9px ${color}cc) drop-shadow(0 0 20px ${color}66)`;
    if (xpBarFill) {
      xpBarFill.style.background = `linear-gradient(90deg, ${color}88, ${color})`;
      xpBarFill.style.boxShadow  = `0 0 12px ${color}88`;
    }
  }

  function applyXpDisplay(snap) {
    if (!snap || !snap.level) return; // invalider ancien format sans level
    const r         = snap.rank;
    const xpBadgeEl = document.getElementById("xpBadge");
    const xpAmountEl= document.getElementById("xpAmount");
    const xpBarFill = document.getElementById("xpBarFill");
    const xpNeededEl= document.getElementById("xpNeeded");

    if (xpBadgeEl) {
      xpBadgeEl.innerHTML = `<span class="xp-level-num">Niv.\u00a0${snap.level}</span><span class="xp-rank-sep">•</span><span class="xp-rank-name">${r.icon} ${r.name}</span>`;
      xpBadgeEl.style.background  = r.bgColor;
      xpBadgeEl.style.color       = r.color;
      xpBadgeEl.style.borderColor = r.borderColor;
      xpBadgeEl.style.boxShadow   = `0 0 10px ${r.color}55`;
      xpBadgeEl.classList.remove("xp-skel");
    }
    if (xpAmountEl) {
      xpAmountEl.textContent = `${(snap.totalXp || 0).toLocaleString("fr-FR")} XP`;
      xpAmountEl.classList.remove("xp-skel");
    }
    applyRankGlow(r.color);
    if (xpBarFill)  xpBarFill.style.width = (snap.progressPercent || 0) + "%";
    if (xpNeededEl) xpNeededEl.textContent = `${(snap.xpNeeded || 0).toLocaleString("fr-FR")} XP \u2192 Niv.\u00a0${snap.level + 1}`;
    const snapBadgeCount = Number(snap.badgeCount);
    if (Number.isFinite(snapBadgeCount)) {
      setUnlockedBadgesCount(snapBadgeCount);
    }
  }

  function saveXpSnapshot(totalXp, rank, progress, badgeCount = null) {
    try {
      localStorage.setItem(_XP_CACHE_KEY(), JSON.stringify({
        totalXp,
        level: progress.level,
        rank: { icon: rank.icon, name: rank.name, color: rank.color, bgColor: rank.bgColor, borderColor: rank.borderColor },
        progressPercent: progress.progressPercent,
        xpNeeded: progress.xpNeeded,
        badgeCount: Number.isFinite(badgeCount) ? Math.max(0, Math.floor(badgeCount)) : undefined,
        savedAt: Date.now()
      }));
    } catch (_) {}
  }

  function loadXpSnapshot() {
    try {
      const raw  = localStorage.getItem(_XP_CACHE_KEY());
      if (!raw) return null;
      const snap = JSON.parse(raw);
      if (!snap.savedAt || Date.now() - snap.savedAt > _XP_CACHE_TTL) {
        localStorage.removeItem(_XP_CACHE_KEY());
        return null;
      }
      return snap;
    } catch (_) { return null; }
  }

  async function loadXpSnapshotFromApi() {
    try {
      const res = await fetch((basePath || "") + "/api/xp-snapshot");
      if (!res.ok) return null;
      const data = await res.json();
      if (!data || !data.level || !data.rank) return null;
      return {
        totalXp: data.totalXp || 0,
        level: data.level,
        rank: data.rank,
        badgeCount: Number.isFinite(Number(data.badgeCount)) ? Number(data.badgeCount) : null,
        progressPercent: data.progressPercent || 0,
        xpNeeded: data.xpNeeded || 0
      };
    } catch (_) {
      return null;
    }
  }

  /* ===============================
     💾 PROFIL SNAPSHOT — stale-while-revalidate
     Stocke toutes les valeurs dynamiques lentes (Tautulli, Wizarr, Seerr)
     pour affichage instantané sans flash de valeurs fausses.
  =============================== */

  const _PROFIL_CACHE_KEY = () => `profil_snap_${document.body.getAttribute("data-user-id") || "guest"}`;
  const _PROFIL_CACHE_TTL = 24 * 60 * 60 * 1000; // 24h

  function saveProfilSnapshot() {
    try {
      const g = id => document.getElementById(id);
      const t = id => { const el = g(id); return el ? el.textContent.trim() : ""; };
      localStorage.setItem(_PROFIL_CACHE_KEY(), JSON.stringify({
        // Profil dates (Tautulli)
        joinedDate:       t("joinedDate"),
        lastActivity:     t("lastActivity"),
        // Abonnement (Wizarr)
        subStatusText:    t("profilSubStatus"),
        subStatusClass:   g("profilSubStatus")?.className  || "",
        subCardClass:     g("profilSubCard")?.className    || "",
        subDays:          t("profilSubDays"),
        subExpire:        t("profilSubExpire"),
        subProgress:      g("profilSubProgress")?.style.width || "0%",
        // Demandes (Seerr)
        totalRequests:    t("totalRequests"),
        approvedRequests: t("approvedRequests"),
        pendingRequests:  t("pendingRequests"),
        availableRequests:t("availableRequests"),
        // Visionnage (Tautulli)
        sessionCount:     t("counterSessions"),
        totalHours:       t("statTotalHours"),
        movieCount:       t("counterMovies"),
        movieHours:       t("statMovieHours"),
        episodeCount:     t("counterEpisodes"),
        episodeHours:     t("statEpisodeHours"),
        musicCount:       t("counterMusic"),
        musicHours:       t("statMusicHours"),
        savedAt: Date.now()
      }));
    } catch (_) {}
  }

  function loadProfilSnapshot() {
    try {
      const raw = localStorage.getItem(_PROFIL_CACHE_KEY());
      if (!raw) return null;
      const snap = JSON.parse(raw);
      if (!snap.savedAt || Date.now() - snap.savedAt > _PROFIL_CACHE_TTL) {
        localStorage.removeItem(_PROFIL_CACHE_KEY());
        return null;
      }
      return snap;
    } catch (_) { return null; }
  }

  function applyProfilSnapshot(snap) {
    try {
      const g  = id => document.getElementById(id);
      // Set value and remove skeleton shimmer
      const s  = (id, val) => {
        const el = g(id);
        if (el && val) { el.textContent = val; el.classList.remove("skel"); }
      };
      // Profil dates
      s("joinedDate",        snap.joinedDate);
      s("lastActivity",      snap.lastActivity);
