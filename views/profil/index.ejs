<div class="profil-container">
  <!-- HEADER AVEC AVATAR ET XP -->
  <div class="profil-header">
    <% 
      // Calculer les stats XP - données seront chargées via API
      const estimatedXp = (user.sessionCount || 0) * 2;
    %>
    <div class="avatar-wrapper" id="avatarWrapper">
      <% if (user.thumb) { %>
        <img src="<%= user.thumb %>" alt="<%= user.username %>" class="profile-avatar" id="profileAvatar" />
      <% } %>
      <div class="badge-ring" id="badgeRing"></div>
    </div>

    <div class="profile-info">
      <h1><%= user.username %></h1>
      <p class="profile-email"><%= user.email %></p>
      
      <div class="xp-status" id="xpStatus">
        <span class="xp-badge xp-skel" id="xpBadge"></span>
        <span class="xp-amount xp-skel" id="xpAmount"></span>
      </div>
    </div>

    <!-- LECTURE EN COURS -->
    <div class="now-playing-widget" id="nowPlayingWidget" style="display:none">
      <!-- Fond flou = affiche agrandie -->
      <div class="np-bg" id="npBg"></div>
      <!-- Overlay gradient -->
      <div class="np-overlay"></div>

      <div class="np-inner">
        <!-- Affiche -->
        <div class="np-poster-wrap">
          <img class="np-poster" id="npThumb" src="" alt="" />
        </div>

        <!-- Infos + barre -->
        <div class="np-body">
          <div class="np-top">
            <div class="np-state-row">
              <span class="np-dot" id="npDot"></span>
              <span class="np-label" id="npLabel">EN COURS</span>
            </div>
            <div class="np-titles">
              <span class="np-grand" id="npGrand"></span>
              <span class="np-title" id="npTitle"></span>
            </div>
            <div class="np-meta">
              <span class="np-player" id="npPlayer"></span>
              <span class="np-pct" id="npPct"></span>
            </div>
          </div>
          <!-- Barre de progression -->
          <div class="np-bar-track">
            <div class="np-bar-fill" id="npBarFill" style="width:0%"></div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- PROGRESS BAR XP -->
  <div class="xp-progress-section">
    <div class="progress-header">
      <span>Progression vers le prochain badge</span>
      <span class="xp-needed" id="xpNeeded">-</span>
    </div>
    <div class="xp-bar-wrapper">
      <div class="xp-bar-fill" id="xpBarFill"></div>
    </div>
  </div>

  <!-- GRID DE CARTES -->
  <div class="profil-grid">
    <!-- CARTE PROFIL -->
    <div class="profil-card">
      <h2>👤 Profil</h2>
      <div class="card-content">
        <div class="stat-row">
          <span class="stat-label">Inscrit depuis</span>
          <span class="stat-value" id="joinedDate">Chargement...</span>
        </div>
        <div class="stat-row">
          <span class="stat-label">Dernière activité</span>
          <span class="stat-value" id="lastActivity">Chargement...</span>
        </div>
      </div>
    </div>

    <!-- CARTE ABONNEMENT -->
    <div class="profil-card profil-sub-card" id="profilSubCard">
      <h2>📅 Abonnement</h2>
      <div class="card-content">
        <div class="subscription-row">
          <span class="label">Statut</span>
          <span class="status-badge loading" id="profilSubStatus">Chargement...</span>
        </div>
        <div class="subscription-row">
          <span class="label">Jours restants</span>
          <span class="value" id="profilSubDays">—</span>
        </div>
        <div class="subscription-row">
          <span class="label">Expire le</span>
          <span class="value" id="profilSubExpire">—</span>
        </div>
        <div class="progress-wrapper">
          <div class="progress-bar">
            <div class="progress" id="profilSubProgress" style="width:0%"></div>
          </div>
        </div>
      </div>
    </div>

    <!-- CARTE REQUÊTES -->
    <div class="profil-card">
      <h2>🎬 Demandes</h2>
      <div class="card-content">
        <div class="stat-row">
          <span class="stat-label">Total demandes</span>
          <span class="stat-value" id="totalRequests">0</span>
        </div>
        <div class="stat-row">
          <span class="stat-label">Approuvées</span>
          <span class="stat-value approved" id="approvedRequests">0</span>
        </div>
        <div class="stat-row">
          <span class="stat-label">En attente</span>
          <span class="stat-value pending" id="pendingRequests">0</span>
        </div>
        <div class="stat-row">
          <span class="stat-label">Disponibles</span>
          <span class="stat-value available" id="availableRequests">0</span>
        </div>
      </div>
    </div>
  </div>

  <!-- 📊 SECTION STATISTIQUES DE VISIONNAGE -->
  <div class="watch-stats-section">
    <div class="stats-header">
      <h2>📊 Statistiques de Visionnage</h2>
      <p class="stats-subtitle">Votre historique complet</p>
    </div>
    
    <div class="stats-grid">
      <!-- Carte : Lectures Totales -->
      <div class="stat-card">
        <div class="stat-icon">📊</div>
        <div class="stat-content">
          <p class="stat-label">Lectures Totales</p>
          <div class="stat-value counter" id="counterSessions" data-target="0">
            0
          </div>
          <p class="stat-unit">lectures</p>
          <p class="stat-sub" id="statTotalHours">0h visionnées</p>
        </div>
      </div>

      <!-- Carte : Films Regardés -->
      <div class="stat-card">
        <div class="stat-icon">🎬</div>
        <div class="stat-content">
          <p class="stat-label">Films Regardés</p>
          <div class="stat-value counter" id="counterMovies" data-target="0">
            0
          </div>
          <p class="stat-unit">films</p>
          <p class="stat-sub" id="statMovieHours">0h de films</p>
        </div>
      </div>

      <!-- Carte : Épisodes Regardés -->
      <div class="stat-card">
        <div class="stat-icon">📺</div>
        <div class="stat-content">
          <p class="stat-label">Épisodes Regardés</p>
          <div class="stat-value counter" id="counterEpisodes" data-target="0">
            0
          </div>
          <p class="stat-unit">épisodes</p>
          <p class="stat-sub" id="statEpisodeHours">0h de séries</p>
        </div>
      </div>
    </div>
  </div>

  <!-- SECTION SUCCÈS -->
  <div class="badges-section">
    <div class="badges-header-with-link">
      <h2>🏆 Progression des Succès</h2>
      <a href="<%= basePath %>/badges" class="view-more-link">Voir plus →</a>
    </div>
    <div class="badges-container" id="badgesContainer"></div>
  </div>

  <!-- BREAKDOWN XP -->
  <div class="xp-breakdown">
    <h3>⚡ Répartition de mon XP</h3>
    
    <div class="xp-breakdown-grid">
      <!-- SOURCES D'XP -->
      <div class="xp-sources">
        <h4>Sources d'XP</h4>
        
        <div class="xp-source">
          <div class="source-header">
            <span class="source-name">⏱️ Heures visionnées</span>
            <span class="source-value" id="xpHoursValue">0</span>
          </div>
          <div class="source-bar">
            <div class="source-bar-fill hours" id="xpHoursBar" style="width: 0%"></div>
          </div>
          <div class="source-percent">
            <span id="xpHoursPercent">0%</span>
          </div>
        </div>

        <div class="xp-source">
          <div class="source-header">
            <span class="source-name">🏅 Succès débloqués</span>
            <span class="source-value" id="xpBadgesValue">0</span>
          </div>
          <div class="source-bar">
            <div class="source-bar-fill badges" id="xpBadgesBar" style="width: 0%"></div>
          </div>
          <div class="source-percent">
            <span id="xpBadgesPercent">0%</span>
          </div>
        </div>

        <div class="xp-source">
          <div class="source-header">
            <span class="source-name">📅 Ancienneté</span>
            <span class="source-value" id="xpAncienneteValue">0</span>
          </div>
          <div class="source-bar">
            <div class="source-bar-fill anciennete" id="xpAncienneteBar" style="width: 0%"></div>
          </div>
          <div class="source-percent">
            <span id="xpAnciennetePercent">0%</span>
          </div>
        </div>
      </div>

      <!-- DÉTAILS PAR CATÉGORIE -->
      <div class="xp-details">
        <h4>Détails par catégorie</h4>
        
        <div class="detail-card hours-card">
          <div class="detail-icon">⏱️</div>
          <div class="detail-info">
            <div class="detail-label">Heures visionnées</div>
            <div class="detail-value" id="detailProfilHours">0h</div>
          </div>
        </div>

        <div class="detail-card badges-card">
          <div class="detail-icon">🏅</div>
          <div class="detail-info">
            <div class="detail-label">Succès débloqués</div>
            <div class="detail-value" id="detailProfilBadges"><%= unlockedBadgesCount %><%= totalBadgesCount ? '/' + totalBadgesCount : '' %></div>
          </div>
        </div>

        <div class="detail-card anciennete-card">
          <div class="detail-icon">📅</div>
          <div class="detail-info">
            <div class="detail-label">Jours depuis inscription</div>
            <div class="detail-value" id="detailProfilAnciennete">0 j</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .profil-container {
    max-width: 1000px;
    margin: 0 auto;
  }

  /* HEADER */
  .profil-header {
    display: flex;
    align-items: center;
    gap: 30px;
    margin-bottom: 40px;
    padding: 30px;
    background: linear-gradient(135deg, rgba(102, 126, 234, 0.1) 0%, rgba(229, 160, 13, 0.05) 100%);
    border-radius: 16px;
    border: 1px solid rgba(255, 255, 255, 0.1);
  }

  /* =====================
     NOW PLAYING — redesign
  ===================== */
  .now-playing-widget {
    margin-left: auto;
    position: relative;
    width: 300px;
    height: 90px;
    border-radius: 14px;
    overflow: hidden;
    flex-shrink: 0;
    box-shadow: 0 8px 32px rgba(0,0,0,0.5);
    animation: npFadeIn 0.5s cubic-bezier(.22,.68,0,1.2);
    border: 1px solid rgba(255,255,255,0.08);
  }
  @keyframes npFadeIn {
    from { opacity:0; transform:translateX(20px) scale(.97); }
    to   { opacity:1; transform:translateX(0)   scale(1); }
  }

  /* Fond = affiche floutée */
  .np-bg {
    position: absolute;
    inset: -10px;
    background-size: cover;
    background-position: center;
    filter: blur(18px) brightness(0.35) saturate(1.4);
    transform: scale(1.1);
    transition: background-image 0.6s ease;
  }
  .np-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(90deg,
      rgba(0,0,0,0.15) 0%,
      rgba(0,0,0,0.05) 40%,
      rgba(0,0,0,0.45) 100%);
  }

  /* Contenu par-dessus */
  .np-inner {
    position: relative;
    z-index: 2;
    display: flex;
    align-items: stretch;
    height: 100%;
  }

  /* Affiche */
  .np-poster-wrap {
    flex-shrink: 0;
    width: 62px;
    height: 90px;
    overflow: hidden;
  }
  .np-poster {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* Corps texte */
  .np-body {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding: 10px 14px 0 12px;
    min-width: 0;
  }
  .np-top { display: flex; flex-direction: column; gap: 3px; min-width: 0; }

  /* Ligne état */
  .np-state-row {
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .np-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: #e5a00d;
    box-shadow: 0 0 6px #e5a00d;
    flex-shrink: 0;
    animation: npPulse 1.8s ease-in-out infinite;
  }
  @keyframes npPulse {
    0%,100% { opacity: 1; box-shadow: 0 0 6px #e5a00d; }
    50%      { opacity: 0.5; box-shadow: 0 0 12px #e5a00d; }
  }
  .np-label {
    font-size: 0.58rem;
    font-weight: 800;
    letter-spacing: 0.12em;
    color: #e5a00d;
    text-transform: uppercase;
  }

  /* Titres */
  .np-titles { display: flex; flex-direction: column; gap: 1px; min-width: 0; }
  .np-grand {
    font-size: 0.7rem;
    color: rgba(255,255,255,0.6);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .np-title {
    font-size: 0.92rem;
    font-weight: 700;
    color: #fff;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    text-shadow: 0 1px 4px rgba(0,0,0,0.8);
  }

  /* Méta (device + %) */
  .np-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    min-width: 0;
  }
  .np-player {
    font-size: 0.62rem;
    color: rgba(255,255,255,0.45);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .np-pct {
    font-size: 0.62rem;
    color: rgba(255,255,255,0.4);
    flex-shrink: 0;
    margin-left: 6px;
  }

  /* Barre de progression */
  .np-bar-track {
    height: 3px;
    background: rgba(255,255,255,0.15);
    border-radius: 0 0 0 0;
    overflow: hidden;
    margin: 0 -14px 0 -12px;
  }
  .np-bar-fill {
    height: 100%;
    background: linear-gradient(90deg, #e5a00d, #f59e0b);
    border-radius: 0;
    transition: width 1s linear;
  }

  /* Pause — tout grisé */
  .np-paused .np-dot  { background:#94a3b8; box-shadow:0 0 4px #94a3b8; animation:none; opacity:.7; }
  .np-paused .np-label { color:#94a3b8; }
  .np-paused .np-bar-fill { background: #94a3b8; }

  .avatar-wrapper {
    position: relative;
    flex-shrink: 0;
  }

  .profile-avatar {
    width: 100px;
    height: 100px;
    border-radius: 50%;
    object-fit: cover;
    border: 3px solid #5B9BD5;
    transition: border-color 0.3s ease;
    position: relative;
    z-index: 2;
  }

  .badge-ring {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 110px;
    height: 110px;
    border-radius: 50%;
    border: 3px solid #5B9BD5;
    opacity: 0.3;
    animation: ring-pulse 2s ease-in-out infinite;
    z-index: 1;
  }

  @keyframes ring-pulse {
    0%, 100% { opacity: 0.3; transform: translate(-50%, -50%) scale(1); }
    50% { opacity: 0.1; transform: translate(-50%, -50%) scale(1.15); }
  }

  .profile-info {
    flex: 1;
  }

  .profile-info h1 {
    font-size: 24px;
    font-weight: 700;
    margin: 0 0 8px 0;
    color: #fff;
  }

  .profile-email {
    color: #aaa;
    margin: 0 0 15px 0;
  }

  .xp-status {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .xp-badge {
    display: inline-block;
    padding: 6px 14px;
    background: rgba(91, 155, 213, 0.2);
    color: #5B9BD5;
    border-radius: 20px;
    font-size: 13px;
    font-weight: 600;
    border: 1px solid rgba(91, 155, 213, 0.5);
  }

  .xp-amount {
    font-size: 14px;
    color: #bbb;
  }

  /* XP PROGRESS */
  .xp-progress-section {
    background: rgba(255, 255, 255, 0.03);
    padding: 20px;
    border-radius: 12px;
    margin-bottom: 30px;
    border: 1px solid rgba(255, 255, 255, 0.05);
  }

  .progress-header {
    display: flex;
    justify-content: space-between;
    font-size: 13px;
    color: #aaa;
    margin-bottom: 12px;
  }

  .xp-needed {
    font-weight: 600;
    color: #667eea;
  }

  /* XP Bar */
  .xp-bar-wrapper {
    width: 100%;
    height: 18px;
    background: rgba(255, 255, 255, 0.1);
    border-radius: 10px;
    overflow: hidden;
    border: 1px solid rgba(102, 126, 234, 0.25);
    box-shadow: inset 0 1px 3px rgba(0, 0, 0, 0.3);
  }

  .xp-bar-fill {
    height: 100%;
    width: 0%;
    background: linear-gradient(90deg, #667eea 0%, #764ba2 50%, #ff1493 100%);
    border-radius: 10px;
    transition: width 0.6s ease-out;
    box-shadow: 0 0 15px rgba(102, 126, 234, 0.7);
  }

  /* GRID */
  .profil-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 20px;
    margin-bottom: 40px;
  }

  .profil-card {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 12px;
    padding: 24px;
    transition: all 0.3s ease;
  }

  .profil-card:hover {
    background: rgba(255, 255, 255, 0.05);
    border-color: rgba(255, 255, 255, 0.2);
  }

  .profil-card h2 {
    font-size: 18px;
    margin-bottom: 16px;
    color: #fff;
  }

  .card-content {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .stat-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-bottom: 10px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
  }

  .stat-row:last-child {
    border-bottom: none;
  }

  .stat-label {
    color: #aaa;
    font-size: 13px;
  }

  .stat-value {
    font-weight: 600;
    color: #fff;
    font-size: 16px;
  }

  .stat-value.approved {
    color: #4caf50;
  }

  .stat-value.pending {
    color: #ff9800;
  }

  .stat-value.available {
    color: #2196f3;
  }

  /* BADGES */
  .badges-section {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 12px;
    padding: 24px;
    margin-bottom: 40px;
  }

  .badges-section h2 {
    margin-top: 0;
    margin-bottom: 20px;
    color: #fff;
  }

  .badges-header-with-link {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 20px;
  }

  .badges-header-with-link h2 {
    margin: 0;
  }

  .view-more-link {
    color: #DAA520;
    text-decoration: none;
    font-size: 14px;
    font-weight: 500;
    transition: all 0.3s ease;
    padding: 8px 16px;
    border-radius: 6px;
    border: 1px solid rgba(218, 165, 32, 0.3);
  }

  .view-more-link:hover {
    background: rgba(218, 165, 32, 0.2);
    border-color: rgba(218, 165, 32, 0.6);
  }

  .badges-container {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(120px, 1fr));
    gap: 15px;
  }

  .badge-item {
    background: rgba(255, 255, 255, 0.05);
    border: 2px solid rgba(255, 255, 255, 0.1);
    border-radius: 12px;
    padding: 20px;
    text-align: center;
    transition: all 0.3s ease;
    opacity: 0.5;
  }

  .badge-item.unlocked {
    opacity: 1;
    border-color: currentColor;
    background: rgba(255, 255, 255, 0.08);
  }

  .badge-icon {
    font-size: 32px;
    margin-bottom: 8px;
  }

  .badge-name {
    font-weight: 600;
    color: #fff;
    margin-bottom: 4px;
    font-size: 14px;
  }

  .badge-range {
    color: #aaa;
    font-size: 11px;
  }

  /* XP BREAKDOWN */
  .xp-breakdown {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 12px;
    padding: 24px;
    margin-top: 40px;
  }

  .xp-breakdown h3 {
    margin-top: 0;
    margin-bottom: 30px;
    color: #E5A00D;
    font-size: 18px;
    font-weight: 600;
  }

  .xp-breakdown-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 40px;
  }

  /* SOURCES D'XP */
  .xp-sources h4 {
    font-size: 14px;
    color: #fff;
    margin: 0 0 20px 0;
    font-weight: 600;
  }

  .xp-source {
    margin-bottom: 20px;
  }

  .source-header {
    display: flex;
    justify-content: space-between;
    margin-bottom: 8px;
  }

  .source-name {
    font-size: 13px;
    font-weight: 500;
    color: #fff;
  }

  .source-value {
    font-size: 13px;
    font-weight: 600;
    color: #fff;
  }

  .source-bar {
    width: 100%;
    height: 12px;
    background: rgba(255, 255, 255, 0.08);
    border-radius: 6px;
    overflow: hidden;
    margin-bottom: 6px;
  }

  .source-bar-fill {
    height: 100%;
    border-radius: 6px;
    transition: width 0.3s ease;
  }

  .source-bar-fill.hours {
    background: linear-gradient(90deg, #3498db, #2980b9);
  }

  .source-bar-fill.badges {
    background: linear-gradient(90deg, #e67e22, #d35400);
  }

  .source-bar-fill.anciennete {
    background: linear-gradient(90deg, #1abc9c, #16a085);
  }

  .source-percent {
    font-size: 11px;
    color: #a0a0a0;
  }

  /* DÉTAILS PAR CATÉGORIE */
  .xp-details h4 {
    font-size: 14px;
    color: #fff;
    margin: 0 0 20px 0;
    font-weight: 600;
  }

  .detail-card {
    padding: 16px;
    border-radius: 10px;
    border-left: 4px solid;
    display: flex;
    align-items: center;
    gap: 15px;
    margin-bottom: 12px;
    background: rgba(255, 255, 255, 0.02);
  }

  .detail-icon {
