<script>
  // XP System Definition
  const XP_SYSTEM = <%- JSON.stringify({badges: XP_SYSTEM.badges}) %>;

  XP_SYSTEM.getBadgeByXp = function(totalXp) {
    return this.badges.find(b => totalXp >= b.minXp && totalXp < b.maxXp) || this.badges[this.badges.length - 1];
  };

  XP_SYSTEM.getProgressToNextBadge = function(totalXp) {
    const currentBadge = this.getBadgeByXp(totalXp);
    const nextBadge = this.badges.find(b => b.level === currentBadge.level + 1);
    if (!nextBadge) {
      return {
        current: currentBadge,
        next: null,
        currentXp: totalXp,
        nextXpThreshold: null,
        progressPercent: 100,
        xpNeeded: 0
      };
    }
    const xpInCurrentBadge = totalXp - currentBadge.minXp;
    const xpNeededForNextBadge = nextBadge.minXp - currentBadge.minXp;
    const progressPercent = Math.floor((xpInCurrentBadge / xpNeededForNextBadge) * 100);
    return {
      current: currentBadge,
      next: nextBadge,
      currentXp: totalXp,
      nextXpThreshold: nextBadge.minXp,
      progressPercent: Math.min(progressPercent, 100),
      xpNeeded: Math.max(nextBadge.minXp - totalXp, 0)
    };
  };

  const basePath = window.APP_BASE_PATH || "";
  const CACHE_DURATION = 30000; // 30 secondes
  const userId = document.body.getAttribute("data-user-id") || "guest";

  /* ===============================
     DATE UTILITIES
  =============================== */

  function formatRelativeTime(dateString) {
    const date = new Date(dateString);
    const now = new Date();
    const diffMs = now - date;
    const diffSec = Math.floor(diffMs / 1000);
    const diffMin = Math.floor(diffSec / 60);
    const diffHour = Math.floor(diffMin / 60);
    const diffDay = Math.floor(diffHour / 24);
    const diffWeek = Math.floor(diffDay / 7);
    const diffMonth = Math.floor(diffDay / 30);
    const diffYear = Math.floor(diffDay / 365);

    if (diffYear > 0) return `il y a ${diffYear} an${diffYear > 1 ? 's' : ''}`;
    if (diffMonth > 0) return `il y a ${diffMonth} mois`;
    if (diffWeek > 0) return `il y a ${diffWeek} semaine${diffWeek > 1 ? 's' : ''}`;
    if (diffDay > 0) return `il y a ${diffDay} jour${diffDay > 1 ? 's' : ''}`;
    if (diffHour > 0) return `il y a ${diffHour}h`;
    if (diffMin > 0) return `il y a ${diffMin}min`;
    return 'À l\'instant';
  }

  function formatFullDate(dateString) {
    if (!dateString) return "";
    const date = new Date(dateString);
    return date.toLocaleDateString("fr-FR", {
      year: "numeric",
      month: "long",
      day: "numeric"
    });
  }

  /* ===============================
     💾 CACHE UTILITIES
  =============================== */

  const cacheManager = {
    get(key) {
      const cacheKey = `${key}:${userId}`;
      const cached = sessionStorage.getItem(cacheKey);
      const time = sessionStorage.getItem(`${cacheKey}:time`);
      const now = Date.now();

      if (cached && time && now - parseInt(time) < CACHE_DURATION) {
        return JSON.parse(cached);
      }
      
      sessionStorage.removeItem(cacheKey);
      sessionStorage.removeItem(`${cacheKey}:time`);
      return null;
    },

    set(key, data) {
      const cacheKey = `${key}:${userId}`;
      sessionStorage.setItem(cacheKey, JSON.stringify(data));
      sessionStorage.setItem(`${cacheKey}:time`, Date.now());
    },

    invalidate(key) {
      const cacheKey = `${key}:${userId}`;
      sessionStorage.removeItem(cacheKey);
      sessionStorage.removeItem(`${cacheKey}:time`);
    }
  };

  /* ===============================
     🎮 RENDER BADGES
  =============================== */

  function renderBadges() {
    const container = document.getElementById("badgesContainer");
    if (!container) return;
    
    XP_SYSTEM.badges.forEach((badge) => {
      const badgeEl = document.createElement("div");
      badgeEl.className = "badge-item";
      badgeEl.dataset.level = badge.level;
      badgeEl.innerHTML = `
        <div class="badge-icon" style="color: ${badge.color};">${badge.icon}</div>
        <div class="badge-name">${badge.name}</div>
        <div class="badge-range">${badge.minXp} - ${badge.maxXp === Infinity ? '∞' : badge.maxXp} XP</div>
      `;
      container.appendChild(badgeEl);
    });
  }

  /* ===============================
     📊 LOAD TAUTULLI STATS
  =============================== */

  async function loadTautulliStats() {
    try {
      console.log("[STATS] Démarrage fetch...");
      const url = basePath + "/api/stats";
      console.log("[STATS] URL cible:", url);
      
      let data = cacheManager.get("statsCache");

      if (!data) {
        console.log("[STATS] Cache miss - requête API");
        const res = await fetch(url);
        console.log("[STATS] Réponse reçue - status:", res.status, "ok:", res.ok);
        
        if (!res.ok) {
          const text = await res.text();
          console.error("[STATS] ❌ Erreur API:", res.status, text);
          return null;
        }

        data = await res.json();
        console.log("[STATS] ✅ JSON parsé:", data);
        cacheManager.set("statsCache", data);
      } else {
        console.log("[STATS] Cache hit");
      }

      if (!data) {
        console.warn("[STATS] ⚠️ Données null");
        return null;
      }
      
      // Accepter AUSSI les objets avec status="computing" (en attente de résultats)
      if (data.status === "computing") {
        console.log("[STATS] ✅ Calcul en cours - retour du status");
        return data;
      }
      
      // Pour les données complètes, vérifier qu'il y a au moins une donnée valide
      if (!data.joinedAt && !data.lastActivity && !data.sessionCount) {
        console.warn("[STATS] ⚠️ Données incomplètes:", data);
        return null;
      }

      console.log("[STATS] ✅ Données valides retournées");
      return data;
    } catch (err) {
      console.error("[STATS] ❌ Erreur catch:", err.message, err);
      return null;
    }
  }

  /* ===============================
     🎬 LOAD OVERSEERR STATS
  =============================== */

  async function loadOverseerrStats() {
    try {
      console.log("[OVERSEERR] Démarrage fetch...");
      const url = basePath + "/api/overseerr";
      console.log("[OVERSEERR] URL cible:", url);
      
      let data = cacheManager.get("overseerrCache");

      if (!data) {
        console.log("[OVERSEERR] Cache miss - requête API");
        const res = await fetch(url);
        console.log("[OVERSEERR] Réponse reçue - status:", res.status, "ok:", res.ok);
        
        if (!res.ok) {
          const text = await res.text();
          console.error("[OVERSEERR] ❌ Erreur API:", res.status, text);
          return {
            pending: 0,
            approved: 0,
            available: 0,
            total: 0
          };
        }

        data = await res.json();
        console.log("[OVERSEERR] ✅ JSON parsé:", data);
        cacheManager.set("overseerrCache", data);
      } else {
        console.log("[OVERSEERR] Cache hit");
      }

      if (!data) {
        console.warn("[OVERSEERR] ⚠️ Données null, retour défaut");
        return {
          pending: 0,
          approved: 0,
          available: 0,
          total: 0
        };
      }

      console.log("[OVERSEERR] ✅ Données valides retournées - total:", data.total);
      return {
        pending: data.pending || 0,
        approved: data.approved || 0,
        available: data.available || 0,
        unavailable: data.unavailable || 0,
        total: data.total || 0
      };
    } catch (err) {
      console.error("[OVERSEERR] ❌ Erreur catch:", err.message, err);
      return {
        pending: 0,
        approved: 0,
        available: 0,
        total: 0
      };
    }
  }

