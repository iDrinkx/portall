      const subscriptionData = subscriptionRes.status === 'fulfilled' ? subscriptionRes.value || {} : {};
      
      console.log("[PROFIL] ✅ Overseerr + Wizarr chargés - affichage immédiat");
      
      // Afficher les stats Overseerr IMMÉDIATEMENT
      const totalReqEl = document.getElementById("totalRequests");
      const approvedEl = document.getElementById("approvedRequests");
      const pendingEl = document.getElementById("pendingRequests");
      const availableEl = document.getElementById("availableRequests");
      const reqCountEl = document.getElementById("requestCount2");
      
      if (totalReqEl) totalReqEl.textContent = overseerrData.total;
      if (approvedEl) approvedEl.textContent = overseerrData.approved;
      if (pendingEl) pendingEl.textContent = overseerrData.pending;
      if (availableEl) availableEl.textContent = overseerrData.available;
      if (reqCountEl) reqCountEl.textContent = overseerrData.total + " demandes";
      
      console.log("[PROFIL] ✅ Overseerr affiché:", overseerrData);
      
      // Afficher abonnement IMMÉDIATEMENT
      const subCardEl = document.getElementById("subscriptionCard");
      if (subscriptionData && subscriptionData.label) {
        const subHtml = `
          <div class="stat-row">
            <span class="stat-label">Statut</span>
            <span class="stat-value">${subscriptionData.label}</span>
          </div>
          ${subscriptionData.daysLeft ? `
