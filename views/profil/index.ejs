  // Constantes XP — rendues une seule fois côté serveur, accessibles partout
  // v1.13: Nouveau système XP ultra-optimisé — succès ultra-prioritaires
  const XP_MULTIPLIERS = { HOURS: 10, ANCIENNETE: 1.5 };
  const PAGE_UNLOCKED_BADGES = <%= unlockedBadgesCount || 0 %>;
  const PAGE_TOTAL_BADGES    = <%= totalBadgesCount    || 0 %>;
  const PAGE_ACHIEVEMENTS_XP = <%= totalAchievementsXp || 0 %>;
  let _lastProfilRefreshTs = null;
  let _profilRefreshTimerHandle = null;

  function updateProfilRefreshTimer() {
    const el = document.getElementById("profilRefreshTimer");
    if (!el || !_lastProfilRefreshTs) return;
    const diffSec = Math.max(0, Math.floor((Date.now() - _lastProfilRefreshTs) / 1000));
    if (diffSec < 60) {
      el.textContent = `Données actualisées il y a ${diffSec}s`;
      return;
    }
    const diffMin = Math.floor(diffSec / 60);
    if (diffMin < 60) {
      el.textContent = `Données actualisées il y a ${diffMin}m`;
      return;
    }
    const diffHours = Math.floor(diffMin / 60);
    el.textContent = `Données actualisées il y a ${diffHours}h`;
  }

  function markProfilRefreshed() {
    _lastProfilRefreshTs = Date.now();
    updateProfilRefreshTimer();
    if (!_profilRefreshTimerHandle) {
      _profilRefreshTimerHandle = setInterval(updateProfilRefreshTimer, 1000);
    }
  }

  const multipliersHintEl = document.getElementById("xpMultipliersHint");
  if (multipliersHintEl) {
    multipliersHintEl.textContent =
      `Multiplicateurs: Heures = x${XP_MULTIPLIERS.HOURS} XP/h • Ancienneté = x${XP_MULTIPLIERS.ANCIENNETE} XP/jour`;
  }
  let LIVE_UNLOCKED_BADGES = PAGE_UNLOCKED_BADGES;

  function setUnlockedBadgesCount(count) {
    if (!Number.isFinite(count)) return LIVE_UNLOCKED_BADGES;
    LIVE_UNLOCKED_BADGES = Math.max(0, Math.floor(count));
    const detail = document.getElementById("detailProfilBadges");
    if (detail) detail.textContent = LIVE_UNLOCKED_BADGES + "/" + PAGE_TOTAL_BADGES;
    const uc = document.getElementById("xpUnlockedCount");
    if (uc) uc.textContent = LIVE_UNLOCKED_BADGES + " / " + PAGE_TOTAL_BADGES;
    return LIVE_UNLOCKED_BADGES;
  }

  function getUnlockedBadgesCount(snap = null) {
    const snapBadgeCount = snap ? Number(snap.badgeCount) : NaN;
    if (Number.isFinite(snapBadgeCount)) {
      return setUnlockedBadgesCount(snapBadgeCount);
    }
    return LIVE_UNLOCKED_BADGES;
  }

  /* ===============================
     DATE UTILITIES
  =============================== */

  function formatRelativeTime(dateString) {
    const date = new Date(dateString);
    const now = new Date();
    const diffMs = now - date;
    const diffSec = Math.floor(diffMs / 1000);
    const diffMin = Math.floor(diffSec / 60);
    const diffHour = Math.floor(diffMin / 60);
    const diffDay = Math.floor(diffHour / 24);
    const diffWeek = Math.floor(diffDay / 7);
    const diffMonth = Math.floor(diffDay / 30);
    const diffYear = Math.floor(diffDay / 365);

    if (diffYear > 0) return `il y a ${diffYear} an${diffYear > 1 ? 's' : ''}`;
    if (diffMonth > 0) return `il y a ${diffMonth} mois`;
    if (diffWeek > 0) return `il y a ${diffWeek} semaine${diffWeek > 1 ? 's' : ''}`;
    if (diffDay > 0) return `il y a ${diffDay} jour${diffDay > 1 ? 's' : ''}`;
    if (diffHour > 0) return `il y a ${diffHour}h`;
    if (diffMin > 0) return `il y a ${diffMin}min`;
    return 'À l\'instant';
  }

  function formatFullDate(dateString) {
    if (!dateString) return "";
    const date = new Date(dateString);
    return date.toLocaleDateString("fr-FR", {
      year: "numeric",
      month: "long",
      day: "numeric"
    });
  }

  /* ===============================
     💾 CACHE UTILITIES
  =============================== */

  const cacheManager = {
    get(key) {
      const cacheKey = `${key}:${userId}`;
      const cached = sessionStorage.getItem(cacheKey);
      const time = sessionStorage.getItem(`${cacheKey}:time`);
      const now = Date.now();

      if (cached && time && now - parseInt(time) < CACHE_DURATION) {
        return JSON.parse(cached);
      }
      
      sessionStorage.removeItem(cacheKey);
      sessionStorage.removeItem(`${cacheKey}:time`);
      return null;
    },

    set(key, data) {
      const cacheKey = `${key}:${userId}`;
      sessionStorage.setItem(cacheKey, JSON.stringify(data));
      sessionStorage.setItem(`${cacheKey}:time`, Date.now());
    },

    invalidate(key) {
      const cacheKey = `${key}:${userId}`;
      sessionStorage.removeItem(cacheKey);
      sessionStorage.removeItem(`${cacheKey}:time`);
    }
  };

