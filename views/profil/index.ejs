  /* RESPONSIVE */
  @media (max-width: 768px) {
    .now-playing-widget {
      display: none !important;
    }

    .profil-header {
      flex-direction: column;
      text-align: center;
      gap: 20px;
      padding: 20px;
    }

    .profile-info h1 {
      font-size: 24px;
    }

    .profil-grid {
      grid-template-columns: 1fr;
    }

    .badges-container {
      grid-template-columns: repeat(auto-fit, minmax(100px, 1fr));
    }

    .breakdown-grid {
      grid-template-columns: 1fr;
    }
  /* XP SKELETON ================================================= */
  .xp-skel {
    display: inline-block;
    min-width: 90px;
    min-height: 22px;
    border-radius: 8px;
    background: linear-gradient(
      90deg,
      rgba(255,255,255,0.06) 25%,
      rgba(255,255,255,0.14) 50%,
      rgba(255,255,255,0.06) 75%
    );
    background-size: 300% 100%;
    animation: xp-shimmer 1.5s ease-in-out infinite;
    color: transparent !important;
    border-color: transparent !important;
    pointer-events: none;
  }
  @keyframes xp-shimmer {
    0%   { background-position: 200% 0; }
    100% { background-position: -200% 0; }
  }
</style>

<script>
  // XP System Definition
  const XP_SYSTEM = <%- JSON.stringify({badges: XP_SYSTEM.badges}) %>;

  XP_SYSTEM.getBadgeByXp = function(totalXp) {
    return this.badges.find(b => totalXp >= b.minXp && totalXp < b.maxXp) || this.badges[this.badges.length - 1];
  };

  XP_SYSTEM.getProgressToNextBadge = function(totalXp) {
    const currentBadge = this.getBadgeByXp(totalXp);
    const nextBadge = this.badges.find(b => b.level === currentBadge.level + 1);
    if (!nextBadge) {
      return {
        current: currentBadge,
        next: null,
        currentXp: totalXp,
        nextXpThreshold: null,
        progressPercent: 100,
        xpNeeded: 0
      };
    }
    const xpInCurrentBadge = totalXp - currentBadge.minXp;
    const xpNeededForNextBadge = nextBadge.minXp - currentBadge.minXp;
    const progressPercent = Math.floor((xpInCurrentBadge / xpNeededForNextBadge) * 100);
    return {
      current: currentBadge,
      next: nextBadge,
      currentXp: totalXp,
      nextXpThreshold: nextBadge.minXp,
      progressPercent: Math.min(progressPercent, 100),
      xpNeeded: Math.max(nextBadge.minXp - totalXp, 0)
    };
  };

  /* ===============================
     💾 XP SNAPSHOT — stale-while-revalidate
     Stocke le dernier XP calculé en localStorage pour un affichage
     instantané (sans flash "Bronze / 0 XP") à la prochaine visite.
  =============================== */

  // Clé unique par utilisateur, max 24h de validité
  const _XP_CACHE_KEY = () => `xp_snapshot_${document.body.getAttribute("data-user-id") || "guest"}`;
  const _XP_CACHE_TTL  = 24 * 60 * 60 * 1000;

  function applyXpDisplay(snap) {
    const b = snap.badge;
    const xpBadgeEl = document.getElementById("xpBadge");
    const xpAmountEl = document.getElementById("xpAmount");
    const badgeRing  = document.getElementById("badgeRing");
    const avatarEl   = document.getElementById("profileAvatar");
    const xpBarFill  = document.getElementById("xpBarFill");
    const xpNeededEl = document.getElementById("xpNeeded");

    if (xpBadgeEl) {
      xpBadgeEl.textContent    = `${b.icon} ${b.name}`;
      xpBadgeEl.style.background   = b.bgColor;
      xpBadgeEl.style.color        = b.color;
      xpBadgeEl.style.borderColor  = b.borderColor;
      xpBadgeEl.classList.remove("xp-skel");
    }
    if (xpAmountEl) {
      xpAmountEl.textContent = `${(snap.totalXp || 0).toLocaleString("fr-FR")} XP`;
      xpAmountEl.classList.remove("xp-skel");
    }
    if (avatarEl) avatarEl.style.borderColor  = b.borderColor;
    if (badgeRing) badgeRing.style.borderColor = b.borderColor;
    if (xpBarFill)  xpBarFill.style.width = (snap.progressPercent || 0) + "%";
    if (xpNeededEl) {
      xpNeededEl.textContent = snap.xpNeeded > 0
        ? `${snap.xpNeeded.toLocaleString("fr-FR")} XP avant ${snap.nextBadgeName || "max"}`
        : "Max atteint !";
    }
  }

  function saveXpSnapshot(totalXp, badge, progress) {
    try {
      localStorage.setItem(_XP_CACHE_KEY(), JSON.stringify({
        totalXp,
        badge: { icon: badge.icon, name: badge.name, color: badge.color, bgColor: badge.bgColor, borderColor: badge.borderColor },
        progressPercent: progress.progressPercent,
        xpNeeded: progress.xpNeeded,
        nextBadgeName: progress.next?.name || null,
        savedAt: Date.now()
      }));
    } catch (_) {}
  }

  function loadXpSnapshot() {
    try {
      const raw  = localStorage.getItem(_XP_CACHE_KEY());
      if (!raw) return null;
      const snap = JSON.parse(raw);
      if (!snap.savedAt || Date.now() - snap.savedAt > _XP_CACHE_TTL) {
        localStorage.removeItem(_XP_CACHE_KEY());
        return null;
      }
      return snap;
    } catch (_) { return null; }
  }

  const basePath = window.APP_BASE_PATH || "";
  const CACHE_DURATION = 30000; // 30 secondes
  const userId = document.body.getAttribute("data-user-id") || "guest";

  // Constantes XP — rendues une seule fois côté serveur, accessibles partout
  const XP_MULTIPLIERS = { HOURS: 8, BADGE: 140, ANCIENNETE: 5 };
  const PAGE_UNLOCKED_BADGES = <%= unlockedBadgesCount || 0 %>;
  const PAGE_TOTAL_BADGES    = <%= totalBadgesCount    || 0 %>;

  /* ===============================
     DATE UTILITIES
  =============================== */

  function formatRelativeTime(dateString) {
    const date = new Date(dateString);
    const now = new Date();
    const diffMs = now - date;
    const diffSec = Math.floor(diffMs / 1000);
    const diffMin = Math.floor(diffSec / 60);
    const diffHour = Math.floor(diffMin / 60);
    const diffDay = Math.floor(diffHour / 24);
    const diffWeek = Math.floor(diffDay / 7);
    const diffMonth = Math.floor(diffDay / 30);
    const diffYear = Math.floor(diffDay / 365);

    if (diffYear > 0) return `il y a ${diffYear} an${diffYear > 1 ? 's' : ''}`;
    if (diffMonth > 0) return `il y a ${diffMonth} mois`;
    if (diffWeek > 0) return `il y a ${diffWeek} semaine${diffWeek > 1 ? 's' : ''}`;
    if (diffDay > 0) return `il y a ${diffDay} jour${diffDay > 1 ? 's' : ''}`;
    if (diffHour > 0) return `il y a ${diffHour}h`;
    if (diffMin > 0) return `il y a ${diffMin}min`;
    return 'À l\'instant';
  }

  function formatFullDate(dateString) {
    if (!dateString) return "";
    const date = new Date(dateString);
    return date.toLocaleDateString("fr-FR", {
      year: "numeric",
      month: "long",
      day: "numeric"
    });
  }

  /* ===============================
     💾 CACHE UTILITIES
  =============================== */

  const cacheManager = {
    get(key) {
      const cacheKey = `${key}:${userId}`;
      const cached = sessionStorage.getItem(cacheKey);
      const time = sessionStorage.getItem(`${cacheKey}:time`);
      const now = Date.now();

      if (cached && time && now - parseInt(time) < CACHE_DURATION) {
        return JSON.parse(cached);
      }
      
      sessionStorage.removeItem(cacheKey);
      sessionStorage.removeItem(`${cacheKey}:time`);
      return null;
    },

    set(key, data) {
      const cacheKey = `${key}:${userId}`;
      sessionStorage.setItem(cacheKey, JSON.stringify(data));
      sessionStorage.setItem(`${cacheKey}:time`, Date.now());
    },

    invalidate(key) {
      const cacheKey = `${key}:${userId}`;
      sessionStorage.removeItem(cacheKey);
      sessionStorage.removeItem(`${cacheKey}:time`);
    }
  };

  /* ===============================
     🎮 RENDER BADGES
  =============================== */

  function renderBadges() {
    const container = document.getElementById("badgesContainer");
    if (!container) return;
    
    XP_SYSTEM.badges.forEach((badge) => {
      const badgeEl = document.createElement("div");
      badgeEl.className = "badge-item";
      badgeEl.dataset.level = badge.level;
      badgeEl.innerHTML = `
        <div class="badge-icon" style="color: ${badge.color};">${badge.icon}</div>
        <div class="badge-name">${badge.name}</div>
        <div class="badge-range">${badge.minXp} - ${badge.maxXp === Infinity ? '∞' : badge.maxXp} XP</div>
      `;
      container.appendChild(badgeEl);
    });
  }

  /* ===============================
     📊 LOAD TAUTULLI STATS
  =============================== */

  async function loadTautulliStats() {
    try {
      console.log("[STATS] Démarrage fetch...");
      const url = basePath + "/api/stats";
      console.log("[STATS] URL cible:", url);
      
      let data = cacheManager.get("statsCache");

      if (!data) {
        console.log("[STATS] Cache miss - requête API");
        const res = await fetch(url);
        console.log("[STATS] Réponse reçue - status:", res.status, "ok:", res.ok);
        
        if (!res.ok) {
          const text = await res.text();
          console.error("[STATS] ❌ Erreur API:", res.status, text);
          return null;
        }

        data = await res.json();
        console.log("[STATS] ✅ JSON parsé:", data);
        cacheManager.set("statsCache", data);
      } else {
        console.log("[STATS] Cache hit");
      }

      if (!data) {
        console.warn("[STATS] ⚠️ Données null");
        return null;
      }
      
      // Accepter AUSSI les objets avec status="computing" (en attente de résultats)
      if (data.status === "computing") {
        console.log("[STATS] ✅ Calcul en cours - retour du status");
        return data;
      }
      
      // Pour les données complètes, vérifier qu'il y a au moins une donnée valide
      if (!data.joinedAt && !data.lastActivity && !data.sessionCount) {
        console.warn("[STATS] ⚠️ Données incomplètes:", data);
        return null;
      }

      console.log("[STATS] ✅ Données valides retournées");
      return data;
    } catch (err) {
      console.error("[STATS] ❌ Erreur catch:", err.message, err);
      return null;
    }
  }

  /* ===============================
     🎬 LOAD OVERSEERR STATS
  =============================== */

  async function loadSeerrStats() {
    try {
      console.log("[SEERR] Démarrage fetch...");
      const url = basePath + "/api/seerr";
      console.log("[SEERR] URL cible:", url);
      
      let data = cacheManager.get("seerrCache");

      if (!data) {
        console.log("[SEERR] Cache miss - requête API");
        const res = await fetch(url);
        console.log("[SEERR] Réponse reçue - status:", res.status, "ok:", res.ok);
        
        if (!res.ok) {
          const text = await res.text();
          console.error("[SEERR] ❌ Erreur API:", res.status, text);
          return {
            pending: 0,
            approved: 0,
            available: 0,
            total: 0
          };
        }

        data = await res.json();
        console.log("[SEERR] ✅ JSON parsé:", data);
        cacheManager.set("seerrCache", data);
      } else {
        console.log("[SEERR] Cache hit");
      }

      if (!data) {
        console.warn("[SEERR] ⚠️ Données null, retour défaut");
        return {
          pending: 0,
          approved: 0,
          available: 0,
          total: 0
        };
      }

      console.log("[SEERR] ✅ Données valides retournées - total:", data.total);
      return {
        pending: data.pending || 0,
        approved: data.approved || 0,
        available: data.available || 0,
        unavailable: data.unavailable || 0,
        total: data.total || 0
      };
    } catch (err) {
      console.error("[SEERR] ❌ Erreur catch:", err.message, err);
      return {
        pending: 0,
        approved: 0,
        available: 0,
        total: 0
      };
    }
  }

  /* ===============================
     📅 LOAD SUBSCRIPTION
  =============================== */

  async function loadSubscription() {
    try {
      console.log("[SUB] Démarrage fetch...");
      const url = "/api/subscription";
      console.log("[SUB] URL cible:", url);
      
      const res = await fetch(url);
      console.log("[SUB] Réponse reçue - status:", res.status, "ok:", res.ok);
      
      if (!res.ok) {
        const text = await res.text();
        console.error("[SUB] ❌ Erreur API:", res.status, text);
        return null;
      }
      
      const data = await res.json();
      console.log("[SUB] ✅ JSON parsé:", data);
      return data;
    } catch (err) {
      console.error("[SUB] ❌ Erreur catch:", err.message, err);
      return null;
    }
  }

  /* ===============================
     🚀 LOAD ALL DATA
  =============================== */

  document.addEventListener("DOMContentLoaded", async () => {
    console.log("[PROFIL] ========== DÉBUT CHARGEMENT ==========");
    console.log("[PROFIL] basePath:", basePath);
    console.log("[PROFIL] userId:", userId);
    
    renderBadges();

    // ⚡ Stale-While-Revalidate : afficher instantanément la dernière
    //    valeur XP connue pendant que les APIs chargent en arrière-plan.
    const _cachedSnap = loadXpSnapshot();
    if (_cachedSnap) {
      applyXpDisplay(_cachedSnap);
      console.log("[XP-CACHE] ⚡ Snapshot restauré:", _cachedSnap.badge?.name, _cachedSnap.totalXp, "XP");
    }

    try {
      console.log("[PROFIL] 🚀 Chargement progressif des données");
      
      // ÉTAPE 1: Charger rapidement Seerr + Wizarr (pas de timeout long)
      console.log("[PROFIL] Chargement Seerr + Wizarr (rapide)...");
      const [seerrRes, subscriptionRes] = await Promise.allSettled([
        loadSeerrStats(),
        loadSubscription()
      ]);
      
      // ÉTAPE 2: Afficher immédiatement Seerr + Wizarr (sans attendre Tautulli)
      const seerrData = seerrRes.status === 'fulfilled' ? seerrRes.value || { total: 0, pending: 0, approved: 0, available: 0 } : { total: 0, pending: 0, approved: 0, available: 0 };
      const subscriptionData = subscriptionRes.status === 'fulfilled' ? subscriptionRes.value || {} : {};
      
      console.log("[PROFIL] ✅ Seerr + Wizarr chargés - affichage immédiat");
      
      // Afficher les stats Seerr IMMÉDIATEMENT
      const totalReqEl = document.getElementById("totalRequests");
      const approvedEl = document.getElementById("approvedRequests");
      const pendingEl = document.getElementById("pendingRequests");
      const availableEl = document.getElementById("availableRequests");
      const reqCountEl = document.getElementById("requestCount2");
      
      if (totalReqEl) totalReqEl.textContent = seerrData.total;
      if (approvedEl) approvedEl.textContent = seerrData.approved;
      if (pendingEl) pendingEl.textContent = seerrData.pending;
      if (availableEl) availableEl.textContent = seerrData.available;
      if (reqCountEl) reqCountEl.textContent = seerrData.total + " demandes";
      
      console.log("[PROFIL] ✅ Seerr affiché:", seerrData);
      
      // Afficher abonnement IMMÉDIATEMENT
      const profilSubCard    = document.getElementById('profilSubCard');
      const profilSubStatus  = document.getElementById('profilSubStatus');
      const profilSubDays    = document.getElementById('profilSubDays');
      const profilSubExpire  = document.getElementById('profilSubExpire');
      const profilSubProgress = document.getElementById('profilSubProgress');

      if (subscriptionData && subscriptionData.label) {
        if (profilSubCard) profilSubCard.className = 'profil-card profil-sub-card ' + (subscriptionData.status || '');
        if (profilSubStatus) {
          profilSubStatus.className = 'status-badge ' + (subscriptionData.status || '');
          profilSubStatus.textContent = subscriptionData.label;
        }
        if (profilSubDays) profilSubDays.textContent = subscriptionData.daysLeft || '—';
        if (profilSubExpire) profilSubExpire.textContent = subscriptionData.expiresAt || '—';
        if (profilSubProgress) profilSubProgress.style.width = (subscriptionData.progressPercent || 0) + '%';
        console.log('[PROFIL] \u2705 Abonnement affiché');
      } else if (profilSubStatus) {
        profilSubStatus.className = 'status-badge not_found';
        profilSubStatus.textContent = 'Non trouvé';
      }
      
      // ÉTAPE 3: Charger Tautulli en PARALLÈLE (peut prendre du temps)
      console.log("[PROFIL] Chargement Tautulli en arrière-plan (avec polling)...");
      const tautulliRes = await Promise.allSettled([loadTautulliStats()]);
      
      // Extraire les données Tautulli du promise
      const tautulliData = tautulliRes[0].status === 'fulfilled' ? tautulliRes[0].value || {} : {};
      const stats = tautulliData;
      const overseerr = seerrData;
      const subscription = subscriptionData;

      console.log("[PROFIL] ✅ Données chargées - Tautulli:", tautulliData);

      // ===== AFFICHER LES STATS DE VISIONNAGE (Watch Stats) =====
      if (tautulliData && tautulliData.watchStats) {
        const watchStats = tautulliData.watchStats;
        console.log("[WATCH-STATS] 📊 Mise à jour des compteurs:", watchStats);
        
        // Sessions (Lectures Totales)
        const sessionsEl = document.getElementById('counterSessions');
        if (sessionsEl) {
          sessionsEl.textContent = tautulliData.sessionCount || 0;
          sessionsEl.setAttribute('data-target', tautulliData.sessionCount || 0);
          console.log("[WATCH-STATS] ✅ Sessions:", tautulliData.sessionCount);
        }
        // Sous-info : heures totales
        const totalHoursEl = document.getElementById('statTotalHours');
        if (totalHoursEl) {
          const totalH = Math.round((watchStats.totalHours || 0) * 10) / 10;
          totalHoursEl.textContent = totalH + 'h visionnées';
        }
        
        // Films
        const moviesEl = document.getElementById('counterMovies');
        if (moviesEl) {
          moviesEl.textContent = watchStats.movieCount || 0;
          moviesEl.setAttribute('data-target', watchStats.movieCount || 0);
          console.log("[WATCH-STATS] ✅ Films:", watchStats.movieCount);
        }
        // Sous-info : heures films
        const movieHoursEl = document.getElementById('statMovieHours');
        if (movieHoursEl) {
          const movieH = Math.round((watchStats.movieHours || 0) * 10) / 10;
          movieHoursEl.textContent = movieH + 'h de films';
        }
        
        // Épisodes
        const episodesEl = document.getElementById('counterEpisodes');
        if (episodesEl) {
          episodesEl.textContent = watchStats.episodeCount || 0;
          episodesEl.setAttribute('data-target', watchStats.episodeCount || 0);
          console.log("[WATCH-STATS] ✅ Épisodes:", watchStats.episodeCount);
        }
        // Sous-info : heures séries
        const episodeHoursEl = document.getElementById('statEpisodeHours');
        if (episodeHoursEl) {
          const episodeH = Math.round((watchStats.episodeHours || 0) * 10) / 10;
          episodeHoursEl.textContent = episodeH + 'h de séries';
        }
        
        console.log("[WATCH-STATS] 🎉 Compteurs mis à jour");
      }

      // Afficher les stats Tautulli
      const joinedEl = document.getElementById("joinedDate");
      const activityEl = document.getElementById("lastActivity");
      console.log("[DOM] joinedDate element:", joinedEl);
      console.log("[DOM] lastActivity element:", activityEl);
      
      // Déclarer les variables que nous utiliserons partout
      let tautulliSessionCount = 0;
      
      // Vérifier si les données sont en cours de calcul
      if (stats.status === "computing") {
        console.log("[DOM] Stats en cours de calcul - afficher message");
        if (joinedEl) joinedEl.textContent = "En cours...";
        if (activityEl) activityEl.textContent = "En cours...";
        const sessionEl = document.getElementById("sessionCount");
        const sessionEl2 = document.getElementById("sessionCount2");
        if (sessionEl) sessionEl.textContent = "Calcul en cours...";
        if (sessionEl2) sessionEl2.textContent = "Calcul en cours...";
        tautulliSessionCount = 0;
      } else {
        if (joinedEl) joinedEl.textContent = stats.joinedAt ? formatFullDate(stats.joinedAt) : "N/A";
        if (activityEl) activityEl.textContent = stats.lastActivity ? formatRelativeTime(stats.lastActivity) : "Aucune";

        tautulliSessionCount = stats.sessionCount || 0;
        const sessionEl = document.getElementById("sessionCount");
        const sessionEl2 = document.getElementById("sessionCount2");
        console.log("[DOM] sessionCount element:", sessionEl, "value:", tautulliSessionCount);
        
        if (sessionEl) sessionEl.textContent = tautulliSessionCount;
        if (sessionEl2) sessionEl2.textContent = tautulliSessionCount + " sessions";
      }

      // CALCUL XP BREAKDOWN avec 3 sources (fait en premier!)
      // XP_MULTIPLIERS, PAGE_UNLOCKED_BADGES, PAGE_TOTAL_BADGES déclarés en scope global

      // Récupérer les données
      const totalHours = tautulliData?.watchStats?.totalHours || 0;
      const unlockedBadgesCount = PAGE_UNLOCKED_BADGES;
      const joinedAtObj = new Date(stats.joinedAt || Date.now());
      const daysJoined = Math.floor((Date.now() - joinedAtObj.getTime()) / (1000 * 60 * 60 * 24));

      // Calculer les 3 sources
      const hoursXp = Math.round(totalHours * XP_MULTIPLIERS.HOURS);
      const badgesXp = unlockedBadgesCount * XP_MULTIPLIERS.BADGE;
      const ancienneteXp = daysJoined * XP_MULTIPLIERS.ANCIENNETE;

      // TOTAL XP = somme des 3 sources (nouveau système!)
      const totalXp = hoursXp + badgesXp + ancienneteXp;
      console.log("[XP] Calcul NEW: Heures=" + hoursXp + " + Badges=" + badgesXp + " + Ancienneté=" + ancienneteXp + " = " + totalXp + " XP");
      
      const badge = XP_SYSTEM.getBadgeByXp(totalXp);
      const progress = XP_SYSTEM.getProgressToNextBadge(totalXp);
      console.log("[BADGE] Badge calculé:", badge.name);

      // Couleur avatar selon badge
      const avatarEl = document.getElementById("profileAvatar");
      const badgeRing = document.getElementById("badgeRing");
      console.log("[DOM] avatarEl:", !!avatarEl, "badgeRing:", !!badgeRing);
      
      if (avatarEl) {
        avatarEl.style.borderColor = badge.borderColor;
        console.log("[AVATAR] Couleur appliquée:", badge.borderColor);
      }
      if (badgeRing) {
        badgeRing.style.borderColor = badge.borderColor;
      }

      // Afficher badge et XP
      const xpBadgeEl = document.getElementById("xpBadge");
      const xpAmountEl = document.getElementById("xpAmount");
      console.log("[DOM] xpBadge:", !!xpBadgeEl, "xpAmount:", !!xpAmountEl);
      
      if (xpBadgeEl) {
        xpBadgeEl.textContent = `${badge.icon} ${badge.name}`;
        xpBadgeEl.style.background = badge.bgColor;
        xpBadgeEl.style.color = badge.color;
        xpBadgeEl.style.borderColor = badge.borderColor;
        xpBadgeEl.classList.remove("xp-skel");
      }
      if (xpAmountEl) {
        xpAmountEl.textContent = `${totalXp.toLocaleString("fr-FR")} XP`;
        xpAmountEl.classList.remove("xp-skel");
      }

      // Barre de progression
      const xpBarFill = document.getElementById("xpBarFill");
      const xpNeeded = document.getElementById("xpNeeded");
      console.log("[XP-PROGRESS] Sélecteurs - xpBarFill:", !!xpBarFill, "xpNeeded:", !!xpNeeded);
      console.log("[XP-PROGRESS] Total XP:", totalXp, "Progress:", progress);
      
      if (xpBarFill) {
        const percent = progress.progressPercent || 0;
        xpBarFill.style.width = percent + "%";
        console.log("[XP-PROGRESS] ✅ Barre mise à jour - width:", percent + "%");
      } else {
        console.error("[XP-PROGRESS] ❌ xpBarFill non trouvé!");
      }
      
      if (xpNeeded) {
        xpNeeded.textContent = progress.xpNeeded > 0 ? `${progress.xpNeeded.toLocaleString("fr-FR")} XP avant ${progress.next?.name || "max"}` : "Max atteint !";
      }

      // 💾 Persister pour affichage instantané à la prochaine visite
      saveXpSnapshot(totalXp, badge, progress);

      // Calculer les pourcentages de répartition
      const totalXpBreakdown = hoursXp + badgesXp + ancienneteXp;
      const hoursPercent = totalXpBreakdown > 0 ? Math.round((hoursXp / totalXpBreakdown) * 100) : 0;
      const badgesPercent = totalXpBreakdown > 0 ? Math.round((badgesXp / totalXpBreakdown) * 100) : 0;
      const anciennetePercent = totalXpBreakdown > 0 ? Math.round((ancienneteXp / totalXpBreakdown) * 100) : 0;

      // Mettre à jour les sources d'XP
      const xpHoursValue = document.getElementById("xpHoursValue");
      const xpHoursBar = document.getElementById("xpHoursBar");
      const xpHoursPercent = document.getElementById("xpHoursPercent");
      
      if (xpHoursValue) xpHoursValue.textContent = hoursXp.toLocaleString() + " XP";
      if (xpHoursBar) xpHoursBar.style.width = hoursPercent + "%";
      if (xpHoursPercent) xpHoursPercent.textContent = hoursPercent + "%";

      const xpBadgesValue = document.getElementById("xpBadgesValue");
      const xpBadgesBar = document.getElementById("xpBadgesBar");
      const xpBadgesPercent = document.getElementById("xpBadgesPercent");
      
      // Barre = progression de déverrouillage des succès (25/37 → 68%)
      // La valeur affichée reste l'XP, mais la barre reflète la complétion des succès
      const totalBadges = <%= totalBadgesCount || 0 %>;
      const successesProgressPercent = totalBadges > 0 ? Math.round((unlockedBadgesCount / totalBadges) * 100) : 0;
      
      if (xpBadgesValue) xpBadgesValue.textContent = badgesXp.toLocaleString() + " XP";
      if (xpBadgesBar) xpBadgesBar.style.width = successesProgressPercent + "%";
      if (xpBadgesPercent) xpBadgesPercent.textContent = successesProgressPercent + "% (" + unlockedBadgesCount + "/" + totalBadges + " succès)";

      const xpAncienneteValue = document.getElementById("xpAncienneteValue");
      const xpAncienneteBar = document.getElementById("xpAncienneteBar");
      const xpAnciennetePercent = document.getElementById("xpAnciennetePercent");
      
      if (xpAncienneteValue) xpAncienneteValue.textContent = ancienneteXp.toLocaleString() + " XP";
      if (xpAncienneteBar) xpAncienneteBar.style.width = anciennetePercent + "%";
      if (xpAnciennetePercent) xpAnciennetePercent.textContent = anciennetePercent + "%";

      // Mettre à jour les détails par catégorie
      const detailProfilHours = document.getElementById("detailProfilHours");
      const detailProfilBadges = document.getElementById("detailProfilBadges");
      const detailProfilAnciennete = document.getElementById("detailProfilAnciennete");
      
      if (detailProfilHours) detailProfilHours.textContent = Math.round(totalHours * 10) / 10 + "h";
      if (detailProfilAnciennete) detailProfilAnciennete.textContent = daysJoined + " j";

      // Formules XP (anciens éléments - les cacher)
      const formulaSessionEl = document.getElementById("sessionFormulaXp");
      const formulaTotalEl = document.getElementById("totalXpFormula");
      console.log("[DOM] FormulaSessions:", !!formulaSessionEl);
      
      if (formulaSessionEl) formulaSessionEl.style.display = "none";
      if (formulaTotalEl) formulaTotalEl.style.display = "none";

      // Activer les badges débloqués
      const badgeItems = document.querySelectorAll(".badge-item");
      console.log("[BADGES] Nombre de badges trouvés:", badgeItems.length, "Total XP:", totalXp);
      
      badgeItems.forEach(item => {
        const level = parseInt(item.dataset.level);
        const badgeData = XP_SYSTEM.badges[level - 1];
        if (totalXp >= badgeData.minXp) {
          item.classList.add("unlocked");
          console.log("[BADGES] Débloqué - Level", level, '(', badgeData.minXp, 'XP)');
        }
      });

      // Rafraîchissement automatique si calcul en cours
      if (stats.status === "computing") {
        console.log("[PROFIL] � Calcul en cours - Attente SMART (au lieu de 30 polls)...");
        
        // Attendre que le scan finisse (via long-poll)
        // Puis mettre à jour les éléments DOM sans reload
        (async () => {
          try {
            console.log("[PROFIL-UPDATE] Attente du scan Tautulli...");
            const waitRes = await fetch(basePath ? `${basePath}/api/stats-wait` : "/api/stats-wait");
            
            if (!waitRes.ok) throw new Error("Wait API error");
            
            const readyStats = await waitRes.json();
            console.log("[PROFIL-UPDATE] ✅ Scan terminé! Mise à jour dynamique...", readyStats);
            
            // Update sessionCount
            const sessionEl = document.getElementById("sessionCount");
            if (sessionEl && readyStats.sessionCount !== undefined) {
              sessionEl.textContent = readyStats.sessionCount;
            }
            
            // Update xpAmount (recalcul XP basé sur les heures)
            const newTotalHours = readyStats?.watchStats?.totalHours || 0;
            const newTotalXp = Math.round(newTotalHours);
            const xpAmountEl = document.getElementById("xpAmount");
            if (xpAmountEl) {
              xpAmountEl.textContent = newTotalXp;
            }
            
            // Update badges
            const badgeItems = document.querySelectorAll(".badge-item");
            badgeItems.forEach(item => {
              item.classList.remove("unlocked");
              const level = parseInt(item.dataset.level);
              const badgeData = XP_SYSTEM.badges[level - 1];
              if (newTotalXp >= badgeData.minXp) {
                item.classList.add("unlocked");
              }
            });
            
            // Update formules / sources d'XP
            const newHoursXp = Math.round(newTotalHours * 8);
            const newDaysJoined = Math.floor((Date.now() - (new Date(readyStats.joinedAt).getTime())) / (1000 * 60 * 60 * 24));
            const newAncienneteXp = newDaysJoined * 5;
            const newTotalXpBreakdown = newHoursXp + 0 + newAncienneteXp;
            
            const newHoursPercent = newTotalXpBreakdown > 0 ? Math.round((newHoursXp / newTotalXpBreakdown) * 100) : 0;
            const newAnciennetePercent = newTotalXpBreakdown > 0 ? Math.round((newAncienneteXp / newTotalXpBreakdown) * 100) : 0;
            
            const xpHoursValue = document.getElementById("xpHoursValue");
            const xpHoursBar = document.getElementById("xpHoursBar");
            const xpHoursPercent = document.getElementById("xpHoursPercent");
            
            if (xpHoursValue) xpHoursValue.textContent = newHoursXp.toLocaleString() + " XP";
            if (xpHoursBar) xpHoursBar.style.width = newHoursPercent + "%";
            if (xpHoursPercent) xpHoursPercent.textContent = newHoursPercent + "%";
            
            const xpAncienneteValue = document.getElementById("xpAncienneteValue");
            const xpAncienneteBar = document.getElementById("xpAncienneteBar");
            const xpAnciennetePercent = document.getElementById("xpAnciennetePercent");
            
            if (xpAncienneteValue) xpAncienneteValue.textContent = newAncienneteXp.toLocaleString() + " XP";
            if (xpAncienneteBar) xpAncienneteBar.style.width = newAnciennetePercent + "%";
            if (xpAnciennetePercent) xpAnciennetePercent.textContent = newAnciennetePercent + "%";
            
            const detailProfilHours = document.getElementById("detailProfilHours");
            const detailProfilAnciennete = document.getElementById("detailProfilAnciennete");
            
            if (detailProfilHours) detailProfilHours.textContent = Math.round(newTotalHours * 10) / 10 + "h";
            if (detailProfilAnciennete) detailProfilAnciennete.textContent = newDaysJoined + " j";
            
            // Old formulas (hide)
            const formulaSessionEl = document.getElementById("sessionFormulaXp");
            const formulaTotalEl = document.getElementById("totalXpFormula");
            
            if (formulaSessionEl) formulaSessionEl.style.display = "none";
            if (formulaTotalEl) formulaTotalEl.style.display = "none";
            
            // Update badge and avatar color
            const newBadge = XP_SYSTEM.getBadgeByXp(newTotalXp);
            const avatarEl = document.getElementById("profileAvatar");
            const badgeRing = document.getElementById("badgeRing");
            const xpBadgeEl = document.getElementById("xpBadge");
            
            if (avatarEl) avatarEl.style.borderColor = newBadge.borderColor;
            if (badgeRing) badgeRing.style.borderColor = newBadge.borderColor;
            if (xpBadgeEl) {
              xpBadgeEl.textContent = `${newBadge.icon} ${newBadge.name}`;
              xpBadgeEl.style.background = newBadge.bgColor;
              xpBadgeEl.style.color = newBadge.color;
              xpBadgeEl.style.borderColor = newBadge.borderColor;
              xpBadgeEl.classList.remove("xp-skel");
            }

            const xpAmountEl2 = document.getElementById("xpAmount");
            if (xpAmountEl2) {
              xpAmountEl2.textContent = `${newTotalXp.toLocaleString("fr-FR")} XP`;
              xpAmountEl2.classList.remove("xp-skel");
            }
            
            // Update progress bar
            const newProgress = XP_SYSTEM.getProgressToNextBadge(newTotalXp);
            const xpBarFill = document.getElementById("xpBarFill");
            const xpNeeded = document.getElementById("xpNeeded");
            
            if (xpBarFill) {
              xpBarFill.style.width = newProgress.progressPercent + "%";
            }
            if (xpNeeded) {
              xpNeeded.textContent = newProgress.xpNeeded > 0 ? `${newProgress.xpNeeded.toLocaleString("fr-FR")} XP avant ${newProgress.next?.name || "max"}` : "Max atteint !";
            }

            // 💾 Persister
            saveXpSnapshot(newTotalXp, newBadge, newProgress);
            
            console.log("[PROFIL-UPDATE] ✅ Tous les éléments mis à jour!");
          } catch (err) {
            console.error("[PROFIL-UPDATE] ❌ Erreur:", err.message);
            setTimeout(() => window.location.reload(), 5000);
          }
        })();
      }

      console.log("[PROFIL] ✅ Chargement terminé!");
    } catch(err) {
      console.error("[PROFIL] ❌ Erreur:", err);
    }

    // NOW PLAYING — polling toutes les 30s
    async function refreshNowPlaying() {
      try {
        const r = await fetch(basePath + "/api/now-playing");
        const d = await r.json();
        const w = document.getElementById("nowPlayingWidget");
        if (!d.playing) { w.style.display = "none"; return; }

        // Fond flouté = même image que l'affiche
        if (d.thumb) {
          document.getElementById("npBg").style.backgroundImage = `url('${d.thumb}')`;
        }

        // Affiche
        const img = document.getElementById("npThumb");
        if (d.thumb) { img.src = d.thumb; img.style.display = ""; }
        else img.style.display = "none";

        // Textes
        const grand  = document.getElementById("npGrand");
        const title  = document.getElementById("npTitle");
        const player = document.getElementById("npPlayer");
        const pct    = document.getElementById("npPct");
        grand.textContent   = d.grandTitle || "";
        grand.style.display = d.grandTitle ? "" : "none";
        title.textContent   = d.title  || "";
        player.textContent  = d.player ? "📺 " + d.player : "";
        pct.textContent     = d.progressPct != null ? d.progressPct + "%" : "";

        // Barre de progression linéaire
        document.getElementById("npBarFill").style.width = (d.progressPct || 0) + "%";

        // État pause / play
        const isPaused = d.state === "paused";
        w.classList.toggle("np-paused", isPaused);
        const labelEl = document.getElementById("npLabel");
        if (labelEl) labelEl.textContent = isPaused ? "EN PAUSE" : "EN COURS";

        w.style.display = "";
      } catch(e) { /* silencieux */ }
    }
    // =====================================================
    //  RAFRAÎCHISSEMENT AUTOMATIQUE
    //  • Now Playing  : toutes les 10 s
    //  • XP / Badges / Seerr / Abonnement : toutes les 5 min
    //  • Page masquée (onglet arrière-plan) : polling mis en pause
    // =====================================================

    // --- Fonction de refresh XP / Badges / Seerr / Abonnement ---
    async function refreshStats() {
      // Invalider les caches client (30 s) pour forcer un vrai appel API
      cacheManager.invalidate("statsCache");
      cacheManager.invalidate("seerrCache");

      const [statsRes, seerrRes, subRes] = await Promise.allSettled([
        loadTautulliStats(),
        loadSeerrStats(),
        loadSubscription()
      ]);

      const stats = statsRes.status === "fulfilled" ? statsRes.value : null;
      const seerr = seerrRes.status === "fulfilled" ? seerrRes.value : null;
      const sub   = subRes.status   === "fulfilled" ? subRes.value   : null;
      const el = (id) => document.getElementById(id);

      // ---- Seerr ----
      if (seerr) {
        if (el("totalRequests"))    el("totalRequests").textContent    = seerr.total;
        if (el("approvedRequests")) el("approvedRequests").textContent = seerr.approved;
        if (el("pendingRequests"))  el("pendingRequests").textContent  = seerr.pending;
        if (el("availableRequests"))el("availableRequests").textContent= seerr.available;
        if (el("requestCount2"))    el("requestCount2").textContent    = seerr.total + " demandes";
      }

      // ---- Abonnement ----
      if (sub && sub.label) {
        const card = el("profilSubCard");
        if (card) card.className = "profil-card profil-sub-card " + (sub.status || "");
        const badge = el("profilSubStatus");
        if (badge) { badge.className = "status-badge " + (sub.status || ""); badge.textContent = sub.label; }
        if (el("profilSubDays"))     el("profilSubDays").textContent    = sub.daysLeft  || "—";
        if (el("profilSubExpire"))   el("profilSubExpire").textContent  = sub.expiresAt || "—";
        if (el("profilSubProgress")) el("profilSubProgress").style.width = (sub.progressPercent || 0) + "%";
      }

      // ---- Tautulli / XP / Badges ----
      if (!stats || stats.status === "computing") return;

      const watchStats   = stats.watchStats || {};
      const totalHours   = watchStats.totalHours || 0;
      const daysJoined   = Math.floor((Date.now() - new Date(stats.joinedAt).getTime()) / 86400000);

      // Compteurs visionnage
      if (el("counterSessions"))    { el("counterSessions").textContent   = stats.sessionCount || 0; el("counterSessions").setAttribute("data-target", stats.sessionCount || 0); }
      if (el("statTotalHours"))       el("statTotalHours").textContent     = Math.round(totalHours * 10) / 10 + "h visionnées";
      if (el("counterMovies"))      { el("counterMovies").textContent      = watchStats.movieCount   || 0; el("counterMovies").setAttribute("data-target", watchStats.movieCount || 0); }
      if (el("statMovieHours"))       el("statMovieHours").textContent     = Math.round((watchStats.movieHours   || 0) * 10) / 10 + "h de films";
      if (el("counterEpisodes"))    { el("counterEpisodes").textContent    = watchStats.episodeCount || 0; el("counterEpisodes").setAttribute("data-target", watchStats.episodeCount || 0); }
      if (el("statEpisodeHours"))     el("statEpisodeHours").textContent   = Math.round((watchStats.episodeHours || 0) * 10) / 10 + "h de séries";

      // Calcul XP — formule identique au chargement initial
      const hoursXp       = Math.round(totalHours * XP_MULTIPLIERS.HOURS);
      const badgesXp      = PAGE_UNLOCKED_BADGES * XP_MULTIPLIERS.BADGE;
      const ancienneteXp  = daysJoined * XP_MULTIPLIERS.ANCIENNETE;
      const totalXp       = hoursXp + badgesXp + ancienneteXp;
      const totalBreakdown = Math.max(1, totalXp);
      const hoursPercent      = Math.round((hoursXp      / totalBreakdown) * 100);
      const badgesPercent     = Math.round((badgesXp     / totalBreakdown) * 100);
      const anciennetePercent = Math.round((ancienneteXp / totalBreakdown) * 100);
      const successPct        = PAGE_TOTAL_BADGES > 0 ? Math.round((PAGE_UNLOCKED_BADGES / PAGE_TOTAL_BADGES) * 100) : 0;

      if (el("xpAmount"))             el("xpAmount").textContent              = totalXp;
      if (el("xpHoursValue"))         el("xpHoursValue").textContent          = hoursXp.toLocaleString()      + " XP";
      if (el("xpHoursBar"))           el("xpHoursBar").style.width            = hoursPercent      + "%";
      if (el("xpHoursPercent"))       el("xpHoursPercent").textContent        = hoursPercent      + "%";
      if (el("xpBadgesValue"))        el("xpBadgesValue").textContent         = badgesXp.toLocaleString()     + " XP";
      if (el("xpBadgesBar"))          el("xpBadgesBar").style.width           = successPct        + "%";
      if (el("xpBadgesPercent"))      el("xpBadgesPercent").textContent       = successPct + "% (" + PAGE_UNLOCKED_BADGES + "/" + PAGE_TOTAL_BADGES + " succès)";
      if (el("xpAncienneteValue"))    el("xpAncienneteValue").textContent     = ancienneteXp.toLocaleString() + " XP";
      if (el("xpAncienneteBar"))      el("xpAncienneteBar").style.width       = anciennetePercent + "%";
      if (el("xpAnciennetePercent"))  el("xpAnciennetePercent").textContent   = anciennetePercent + "%";
      if (el("detailProfilHours"))    el("detailProfilHours").textContent     = Math.round(totalHours * 10) / 10 + "h";
      if (el("detailProfilAnciennete")) el("detailProfilAnciennete").textContent = daysJoined + " j";

      // Badge courant + barre XP
      const currentBadge = XP_SYSTEM.getBadgeByXp(totalXp);
      const progress     = XP_SYSTEM.getProgressToNextBadge(totalXp);
      const avatar       = el("profileAvatar");
      const badgeRing    = el("badgeRing");
      const xpBadgeEl    = el("xpBadge");
      const xpAmountEl   = el("xpAmount");
      if (avatar)    avatar.style.borderColor    = currentBadge.borderColor;
      if (badgeRing) badgeRing.style.borderColor = currentBadge.borderColor;
      if (xpBadgeEl) {
        xpBadgeEl.textContent       = `${currentBadge.icon} ${currentBadge.name}`;
        xpBadgeEl.style.background  = currentBadge.bgColor;
        xpBadgeEl.style.color       = currentBadge.color;
        xpBadgeEl.style.borderColor = currentBadge.borderColor;
        xpBadgeEl.classList.remove("xp-skel");
      }
      if (xpAmountEl) {
        xpAmountEl.textContent = `${totalXp.toLocaleString("fr-FR")} XP`;
        xpAmountEl.classList.remove("xp-skel");
      }
      if (el("xpBarFill")) el("xpBarFill").style.width = progress.progressPercent + "%";
      if (el("xpNeeded"))  el("xpNeeded").textContent  = progress.xpNeeded > 0
        ? `${progress.xpNeeded.toLocaleString("fr-FR")} XP avant ${progress.next?.name || "max"}`
        : "Max atteint !";

      // 💾 Persister
      saveXpSnapshot(totalXp, currentBadge, progress);

      // Badges débloqués
      const badgeItems = document.querySelectorAll(".badge-item");
      badgeItems.forEach(item => {
        const badgeData = XP_SYSTEM.badges[parseInt(item.dataset.level) - 1];
        if (badgeData) item.classList.toggle("unlocked", totalXp >= badgeData.minXp);
      });
      if (el("detailProfilBadges")) {
        const unlockedCount = [...badgeItems].filter(i => i.classList.contains("unlocked")).length;
        el("detailProfilBadges").textContent = unlockedCount + (XP_SYSTEM.badges.length ? "/" + XP_SYSTEM.badges.length : "");
      }
    }

    // --- Gestion des intervalles (pause si onglet caché) ---
    let _timerNowPlaying = null;
    let _timerStats      = null;

    function startPolling() {
      _timerNowPlaying = setInterval(refreshNowPlaying, 10000);   // 10 s
      _timerStats      = setInterval(refreshStats,      300000);  // 5 min
    }

    function stopPolling() {
      clearInterval(_timerNowPlaying);
      clearInterval(_timerStats);
      _timerNowPlaying = null;
      _timerStats      = null;
    }

    document.addEventListener("visibilitychange", () => {
      if (document.hidden) {
        // Onglet en arrière-plan → on arrête tout
        stopPolling();
      } else {
        // Onglet redevient actif → refresh immédiat + relance
        refreshNowPlaying();
        refreshStats();
        startPolling();
      }
    });

    // Démarrage initial
    refreshNowPlaying();
    startPolling();
  });
</script>
