<!doctype html>
<html lang="<%= locale || 'fr' %>">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <link rel="stylesheet" href="<%= basePath %>/css/style.css" />
  <link rel="icon" type="<%= (siteFavicon && siteFavicon.type) || 'image/png' %>" href="<%= basePath %><%= (siteFavicon && siteFavicon.href) || '/logo.png' %>" />
  <link rel="apple-touch-icon" href="<%= basePath %><%= (siteFavicon && siteFavicon.href) || '/logo.png' %>" />
  <title>Plex-Portal</title>
  <script>
    window.APP_BASE_PATH = "<%= basePath %>";
    window.APP_LOCALE = "<%= locale || 'fr' %>";
    window.APP_RUNTIME_TEXT_MAP = <%- JSON.stringify(runtimeTextMap || {}) %>;
    window.APP_SITE_BACKGROUND = <%- JSON.stringify(siteBackground || { mode: "particles", customUrl: "", customOpacity: 0.34 }) %>;
  </script>
</head>
<body class="site-bg-mode-<%= (siteBackground && siteBackground.mode) || 'particles' %>" style="--site-bg-opacity:<%= siteBackground && siteBackground.customOpacity != null ? siteBackground.customOpacity : 0.34 %>;<% if (siteBackground && siteBackground.mode === 'custom' && siteBackground.customUrl) { %>--site-bg-image:url('<%= siteBackground.customUrl.replace(/'/g, "\\'") %>');<% } %>" <% if (user) { %>data-user-id="<%= user.id %>"<% } %>>
<div class="site-bg site-bg--<%= (siteBackground && siteBackground.mode) || 'particles' %>" aria-hidden="true">
  <div class="site-bg-gradient"></div>
  <div class="site-bg-vignette"></div>
  <div class="site-bg-aurora"></div>
  <div class="site-bg-mesh"></div>
  <div class="site-bg-nebula"></div>
  <div class="site-bg-spotlight"></div>
  <div class="site-bg-waves"></div>
  <div class="site-bg-image"></div>
  <div class="site-particles" id="siteParticles"></div>
</div>

<% if (user) { %>
  <nav class="navbar">

    <!-- Logo -->
    <a href="<%= basePath %>/dashboard" class="brand">
      <img class="brand-logo" src="<%= basePath %>/logo.png" alt="MonPlex"/>
    </a>

    <!-- Desktop Menu -->
    <div class="nav-center desktop-menu">
      <a href="<%= basePath %>/dashboard" class="nav-link nav-link-dashboard"><%= t("nav.dashboard") %>&nbsp;🏠</a>
      <% (dashboardNavItems || []).forEach(function(item) { %>
        <a href="<%= item.href %>" class="nav-link <%= item.className %>"><%= item.label %>&nbsp;<% if (item.kind === "image") { %><img src="<%= item.iconSrc %>" alt="<%= item.iconAlt %>" class="nav-seerr-logo"><% } else if (item.kind === "profile") { %>👤<% } else { %><%= item.icon %><% } %></a>
      <% }) %>
      <% (customNavCards || []).forEach(function(card) { %>
        <a
          href="<%= card.href %>"
          class="nav-link nav-link-custom"
          style="--custom-nav-base:<%= card.navColorBase %>;--custom-nav-hover:<%= card.navColorHover %>;--custom-nav-accent:<%= card.navColorAccent %>;"
          <% if (card.external) { %>target="_blank" rel="noopener noreferrer"<% } %>
        ><%= card.label %>&nbsp;<span class="nav-custom-icon"><% if ((card.integrationKey || "") === "komga_auto") { %><img src="<%= basePath %>/img/komga-icon.svg" alt="Komga" class="nav-custom-icon-logo"><% } else if ((card.integrationKey || "") === "jellyfin_auto") { %><img src="<%= basePath %>/img/jellyfin-icon.svg" alt="Jellyfin" class="nav-custom-icon-logo"><% } else if ((card.integrationKey || "") === "romm_auto") { %><img src="<%= basePath %>/img/romm-icon.svg" alt="RomM" class="nav-custom-icon-logo"><% } else { %><%= card.icon %><% } %></span></a>
      <% }) %>
      <% if (user.isAdmin) { %>
        <a href="<%= basePath %>/parametres" class="nav-link nav-link-settings"><%= t("nav.settings") %>&nbsp;⚙️</a>
      <% } %>
    </div>

    <!-- Desktop Logout -->
    <div class="nav-right desktop-menu">
      <% if (navSubscriptionPillEnabled) { %>
        <a href="<%= basePath %>/profil" class="nav-sub-pill" id="navSubPill">&#x2014;</a>
      <% } %>
      <a class="logout-btn" href="<%= basePath %>/logout"><%= t("nav.logout") %></a>
    </div>

    <!-- Pill abonnement mobile -->
    <% if (navSubscriptionPillEnabled) { %>
      <a href="<%= basePath %>/profil" class="nav-sub-pill mobile-sub-pill" id="mobileSubPill">&#x2014;</a>
    <% } %>
    <!-- Burger Mobile -->
    <div class="burger" id="burger">☰</div>

  </nav>

  <!-- Overlay -->
  <div class="overlay" id="overlay"></div>

  <!-- Mobile Menu -->
  <div class="mobile-menu" id="mobileMenu">
    <a href="<%= basePath %>/dashboard" class="nav-link-dashboard"><%= t("nav.dashboard") %>&nbsp;🏠</a>
    <% (dashboardNavItems || []).forEach(function(item) { %>
      <a href="<%= item.href %>" class="<%= item.className %>"><%= item.label %>&nbsp;<% if (item.kind === "image") { %><img src="<%= item.iconSrc %>" alt="<%= item.iconAlt %>" class="nav-seerr-logo"><% } else if (item.kind === "profile") { %>👤<% } else { %><%= item.icon %><% } %></a>
    <% }) %>
    <% (customNavCards || []).forEach(function(card) { %>
      <a
        href="<%= card.href %>"
        class="nav-link-custom-mobile"
        style="--custom-nav-base:<%= card.navColorBase %>;--custom-nav-hover:<%= card.navColorHover %>;--custom-nav-accent:<%= card.navColorAccent %>;"
        <% if (card.external) { %>target="_blank" rel="noopener noreferrer"<% } %>
      ><%= card.label %>&nbsp;<span class="nav-custom-icon"><% if ((card.integrationKey || "") === "komga_auto") { %><img src="<%= basePath %>/img/komga-icon.svg" alt="Komga" class="nav-custom-icon-logo"><% } else if ((card.integrationKey || "") === "jellyfin_auto") { %><img src="<%= basePath %>/img/jellyfin-icon.svg" alt="Jellyfin" class="nav-custom-icon-logo"><% } else if ((card.integrationKey || "") === "romm_auto") { %><img src="<%= basePath %>/img/romm-icon.svg" alt="RomM" class="nav-custom-icon-logo"><% } else { %><%= card.icon %><% } %></span></a>
    <% }) %>
    <% if (user.isAdmin) { %>
      <a href="<%= basePath %>/parametres" class="nav-link-settings"><%= t("nav.settings") %> ⚙️</a>
    <% } %>
    <a href="<%= basePath %>/logout" class="logout-mobile"><%= t("nav.logout") %></a>
  </div>

<% } %>

<main class="content">
  <%- body %>
</main>

<script>
  (function () {
    if ((window.APP_LOCALE || "fr") === "fr") return;
    const textMap = window.APP_RUNTIME_TEXT_MAP || {};
    const replacers = Object.keys(textMap);
    if (!replacers.length) return;

    function translateText(value) {
      const original = String(value == null ? "" : value);
      const trimmed = original.trim();
      if (!trimmed || !Object.prototype.hasOwnProperty.call(textMap, trimmed)) return original;
      const leading = original.match(/^\s*/)?.[0] || "";
      const trailing = original.match(/\s*$/)?.[0] || "";
      return leading + textMap[trimmed] + trailing;
    }

    function translateNode(root) {
      if (!root) return;
      if (root.nodeType === Node.TEXT_NODE) {
        const next = translateText(root.nodeValue);
        if (next !== root.nodeValue) root.nodeValue = next;
        return;
      }
      if (root.nodeType !== Node.ELEMENT_NODE) return;

      ["placeholder", "title", "aria-label", "value"].forEach(function (attr) {
        if (!root.hasAttribute(attr)) return;
        const current = root.getAttribute(attr);
        const next = translateText(current);
        if (next !== current) root.setAttribute(attr, next);
      });

      Array.from(root.childNodes).forEach(translateNode);
    }

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", function () {
        translateNode(document.body);
      });
    } else {
      translateNode(document.body);
    }

    const observer = new MutationObserver(function (mutations) {
      mutations.forEach(function (mutation) {
        if (mutation.type === "characterData") {
          translateNode(mutation.target);
          return;
        }
        mutation.addedNodes.forEach(translateNode);
      });
    });

    observer.observe(document.body, {
      subtree: true,
      childList: true,
      characterData: true
    });
  })();
</script>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const backgroundMode = (window.APP_SITE_BACKGROUND && window.APP_SITE_BACKGROUND.mode) || "particles";
    const particlesLayer = document.getElementById("siteParticles");
    const reduceMotion = window.matchMedia && window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    if (particlesLayer && backgroundMode === "particles" && !reduceMotion) {
      const particleCount = window.innerWidth <= 768 ? 46 : 92;
      const colors = [
        "rgba(46,136,255,0.96)",
        "rgba(78,182,255,0.96)",
        "rgba(25,220,255,0.98)",
        "rgba(186,230,255,0.98)"
      ];

      const fragment = document.createDocumentFragment();
      const particles = [];
      let viewportW = window.innerWidth;
      let viewportH = window.innerHeight;

      const randomSpeed = (tier) => (
        tier === "far"
          ? (7 + Math.random() * 6)
          : tier === "mid"
            ? (12 + Math.random() * 10)
            : (20 + Math.random() * 12)
      );

      for (let i = 0; i < particleCount; i++) {
        const p = document.createElement("span");
        p.className = "site-particle";

        // 3 couches pour des vitesses vraiment différentes
        const r = Math.random();
        const tier = r < 0.48 ? "far" : r < 0.84 ? "mid" : "near";
        if (tier === "far") p.classList.add("site-particle--far");
        if (tier === "mid") p.classList.add("site-particle--mid");
        if (tier === "near") p.classList.add("site-particle--near");

        const bright = Math.random() < (tier === "near" ? 0.34 : tier === "mid" ? 0.20 : 0.10);

        const size = tier === "far"
          ? (4.7 + Math.random() * 1.26)
          : tier === "mid"
            ? (5.94 + Math.random() * 1.62)
            : (7.56 + Math.random() * 1.98);
        const alpha = bright ? "1" : (tier === "far" ? "0.82" : tier === "mid" ? "0.9" : "0.96");
        const angle = Math.random() * Math.PI * 2;
        const speed = randomSpeed(tier);
        const particle = {
          el: p,
          size,
          x: Math.random() * viewportW,
          y: Math.random() * viewportH,
          vx: Math.cos(angle) * speed,
          vy: Math.sin(angle) * speed
        };

        p.style.setProperty("--size", `${size.toFixed(2)}px`);
        p.style.setProperty("--alpha", alpha);
        p.style.setProperty("--particle-color", colors[Math.floor(Math.random() * colors.length)]);
        if (bright) p.classList.add("site-particle--bright");
        p.style.transform = `translate3d(${particle.x.toFixed(2)}px, ${particle.y.toFixed(2)}px, 0)`;

        particles.push(particle);
        fragment.appendChild(p);
      }
      particlesLayer.appendChild(fragment);

      let lastTs = performance.now();
      const tick = (ts) => {
        const dt = Math.min(0.05, (ts - lastTs) / 1000);
        lastTs = ts;

        for (let i = 0; i < particles.length; i++) {
          const s = particles[i];
          s.x += s.vx * dt;
          s.y += s.vy * dt;

          if (s.x < -s.size) {
            s.x = viewportW + s.size;
            s.y = Math.random() * viewportH;
          } else if (s.x > viewportW + s.size) {
            s.x = -s.size;
            s.y = Math.random() * viewportH;
          }

          if (s.y < -s.size) {
            s.y = viewportH + s.size;
            s.x = Math.random() * viewportW;
          } else if (s.y > viewportH + s.size) {
            s.y = -s.size;
            s.x = Math.random() * viewportW;
          }

          s.el.style.transform = `translate3d(${s.x.toFixed(2)}px, ${s.y.toFixed(2)}px, 0)`;
        }
        window.requestAnimationFrame(tick);
      };
      window.requestAnimationFrame(tick);

      window.addEventListener("resize", () => {
        viewportW = window.innerWidth;
        viewportH = window.innerHeight;
      });
    }

    const burger = document.getElementById("burger");
    const mobileMenu = document.getElementById("mobileMenu");
    const overlay = document.getElementById("overlay");

    if (!burger || !mobileMenu || !overlay) return;

    const openMenu = () => {
      mobileMenu.classList.add("open");
      overlay.classList.add("active");
      document.body.style.overflow = "hidden"; // bloque le scroll
    };

    const closeMenu = () => {
      mobileMenu.classList.remove("open");
      overlay.classList.remove("active");
      document.body.style.overflow = "";
    };

    // Toggle burger
    burger.addEventListener("click", () => {
      if (mobileMenu.classList.contains("open")) {
        closeMenu();
      } else {
        openMenu();
      }
    });

    // Click overlay
    overlay.addEventListener("click", closeMenu);

    // Ferme le menu quand on clique sur un lien
    document.querySelectorAll(".mobile-menu a").forEach(link => {
      link.addEventListener("click", closeMenu);
    });

  });

  <% if (navSubscriptionPillEnabled) { %>
  // --- Bulle abonnement navbar ---
  (function () {
    const pill   = document.getElementById('navSubPill');
    const userId = document.body.getAttribute('data-user-id') || 'guest';
    if (!pill) return;

    const PILL_KEY = 'nav_pill_snap:' + userId;
    const PILL_TTL = 24 * 60 * 60 * 1000; // 24 h

    function applyPill(data) {
      const numMatch = data.daysLeft && String(data.daysLeft).match(/\d+/);
      const text = data.status === 'unlimited' ? '\u221e'
                 : numMatch ? numMatch[0] + '\u00a0jours'
                 : data.label || '\u2014';
      const cls = 'nav-sub-pill--' + (data.status || 'loading');
      [pill, document.getElementById('mobileSubPill')].forEach(el => {
        if (!el) return;
        el.textContent = text;
        el.className = el.className.replace(/\bnav-sub-pill--\S+/g, '');
        el.classList.add(cls);
      });
    }

    // ⚡ Restaurer instantanément depuis le cache
    try {
      const raw = localStorage.getItem(PILL_KEY);
      if (raw) {
        const snap = JSON.parse(raw);
        if (snap.savedAt && Date.now() - snap.savedAt < PILL_TTL) applyPill(snap);
      }
    } catch (_) {}

    // Puis rafraîchir en arrière-plan
    fetch((window.APP_BASE_PATH || '') + '/api/subscription')
      .then(r => r.ok ? r.json() : null)
      .then(data => {
        if (!data) return;
        applyPill(data);
        try { localStorage.setItem(PILL_KEY, JSON.stringify({ ...data, savedAt: Date.now() })); } catch (_) {}
      })
      .catch(() => {});
  })();
  <% } %>

</script>

</body>
</html>
