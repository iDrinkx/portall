<h1 class="dashboard-title">🎬 Activité</h1>

<div class="activity-container">
  <div id="activityContent" style="display: none;" class="activity-info-card">
    <h2 id="username"></h2>
    <div class="activity-grid">
      <div class="activity-stat">
        <div class="stat-label">📅 Inscrit depuis</div>
        <div class="stat-value" id="joinedDate"></div>
      </div>
      <div class="activity-stat">
        <div class="stat-label">⏱️ Dernière activité</div>
        <div class="stat-value" id="lastActivityLabel"></div>
      </div>
    </div>
  </div>

  <div id="activityMessage" class="activity-message">
    <p>Chargement des informations...</p>
  </div>
</div>

<style>
  .activity-container {
    display: flex;
    flex-direction: column;
    gap: 20px;
    max-width: 800px;
    margin: 0 auto;
  }

  .activity-info-card {
    position: relative;
    overflow: hidden;
    background: rgba(14, 22, 34, 0.012);
    border: 1px solid rgba(226, 246, 255, 0.42);
    box-shadow: 0 14px 34px rgba(0, 0, 0, 0.18), 0 0 0 1px rgba(232, 248, 255, 0.2) inset, 0 4px 10px rgba(98, 178, 255, 0.04);
    backdrop-filter: blur(3px) saturate(112%) contrast(1.01) brightness(1.02);
    -webkit-backdrop-filter: blur(3px) saturate(112%) contrast(1.01) brightness(1.02);
    padding: 30px;
    border-radius: 12px;
  }

  .activity-info-card::before,
  .activity-stat::before,
  .activity-message::before {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: inherit;
    pointer-events: none;
    background: linear-gradient(118deg, rgba(255, 255, 255, 0.11) 0%, rgba(255, 255, 255, 0.02) 28%, rgba(255, 255, 255, 0.01) 58%, rgba(255, 255, 255, 0.03) 100%);
    mix-blend-mode: screen;
  }

  .activity-info-card::after,
  .activity-stat::after,
  .activity-message::after {
    content: "";
    position: absolute;
    width: 38%;
    height: 170%;
    left: -20%;
    top: -45%;
    transform: rotate(-15deg);
    pointer-events: none;
    background: radial-gradient(ellipse at center, rgba(255, 255, 255, 0.2) 0%, rgba(255, 255, 255, 0.07) 34%, rgba(255, 255, 255, 0) 72%);
    opacity: 0.2;
  }

  .activity-info-card > *,
  .activity-stat > *,
  .activity-message > * {
    position: relative;
    z-index: 2;
  }

  .activity-info-card h2 {
    margin-bottom: 25px;
    color: #667eea;
    font-size: 28px;
  }

  .activity-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 20px;
  }

  .activity-stat {
    position: relative;
    overflow: hidden;
    background: rgba(14, 22, 34, 0.012);
    padding: 20px;
    border-radius: 8px;
    border: 1px solid rgba(226, 246, 255, 0.42);
    box-shadow: 0 14px 34px rgba(0, 0, 0, 0.18), 0 0 0 1px rgba(232, 248, 255, 0.2) inset, 0 4px 10px rgba(98, 178, 255, 0.04);
    backdrop-filter: blur(3px) saturate(112%) contrast(1.01) brightness(1.02);
    -webkit-backdrop-filter: blur(3px) saturate(112%) contrast(1.01) brightness(1.02);
  }

  .stat-label {
    font-size: 13px;
    color: #888;
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 10px;
  }

  .stat-value {
    font-size: 16px;
    font-weight: 600;
    color: #fff;
  }

  .activity-message {
    position: relative;
    overflow: hidden;
    background: rgba(14, 22, 34, 0.012);
    border: 1px solid rgba(226, 246, 255, 0.42);
    box-shadow: 0 14px 34px rgba(0, 0, 0, 0.18), 0 0 0 1px rgba(232, 248, 255, 0.2) inset, 0 4px 10px rgba(98, 178, 255, 0.04);
    backdrop-filter: blur(3px) saturate(112%) contrast(1.01) brightness(1.02);
    -webkit-backdrop-filter: blur(3px) saturate(112%) contrast(1.01) brightness(1.02);
    padding: 30px;
    border-radius: 12px;
    text-align: center;
    color: #aaa;
  }

  .activity-message p {
    margin: 10px 0;
    line-height: 1.6;
  }

  .info-badge {
    display: inline-block;
    background: rgba(102, 126, 234, 0.3);
    color: #667eea;
    padding: 8px 16px;
    border-radius: 20px;
    font-size: 12px;
    font-weight: 600;
    margin-top: 15px;
  }

  .activity-error {
    background: rgba(239, 68, 68, 0.1);
    border: 1px solid rgba(239, 68, 68, 0.3);
    padding: 30px;
    border-radius: 12px;
    color: #fca5a5;
    text-align: center;
  }
</style>

<script>
  document.addEventListener("DOMContentLoaded", async () => {
    const basePath = window.APP_BASE_PATH || "";

    function formatRelativeTime(dateString) {
      if (!dateString) return "Aucune activité";
      
      const date = new Date(dateString);
      const now = new Date();
      const diffMs = now - date;
      const diffSec = Math.floor(diffMs / 1000);
      const diffMin = Math.floor(diffSec / 60);
      const diffHour = Math.floor(diffMin / 60);
      const diffDay = Math.floor(diffHour / 24);
      const diffWeek = Math.floor(diffDay / 7);
      const diffMonth = Math.floor(diffDay / 30);
      const diffYear = Math.floor(diffDay / 365);

      if (diffYear > 0) return `il y a ${diffYear} an${diffYear > 1 ? 's' : ''}`;
      if (diffMonth > 0) return `il y a ${diffMonth} mois`;
      if (diffWeek > 0) return `il y a ${diffWeek} semaine${diffWeek > 1 ? 's' : ''}`;
      if (diffDay > 0) return `il y a ${diffDay} jour${diffDay > 1 ? 's' : ''}`;
      if (diffHour > 0) return `il y a ${diffHour}h`;
      if (diffMin > 0) return `il y a ${diffMin}min`;
      return 'À l\'instant';
    }

    function formatFullDate(dateString) {
      if (!dateString) return "";
      const date = new Date(dateString);
      return date.toLocaleDateString('fr-FR', {
        year: 'numeric',
        month: 'long',
        day: 'numeric',
        hour: '2-digit',
        minute: '2-digit'
      });
    }

    try {
      const res = await fetch(basePath + "/api/activity");
      if (!res.ok) throw new Error(`API error: ${res.status}`);
      const data = await res.json();

      const contentDiv = document.getElementById("activityContent");
      const messageDiv = document.getElementById("activityMessage");

      if (!data || !data.user) {
        messageDiv.innerHTML = `<div class="activity-error">❌ Impossible de récupérer les informations d'activité</div>`;
        return;
      }

      // Afficher les infos de l'utilisateur
      document.getElementById("username").textContent = data.user.username;
      document.getElementById("joinedDate").textContent = formatFullDate(data.user.createdAt);
      document.getElementById("lastActivityLabel").textContent = formatRelativeTime(data.user.lastActivityAt);

      contentDiv.style.display = "block";

      // Message informatif
      const lastActivityDate = data.user.lastActivityAt 
        ? `${formatRelativeTime(data.user.lastActivityAt)} (${formatFullDate(data.user.lastActivityAt)})`
        : "Aucune activité enregistrée";

      messageDiv.innerHTML = `
        <p><strong>ℹ️ Information:</strong></p>
        <p>Tautulli fournit uniquement la date de dernière activité via son API publique.</p>
        <p>L'historique détaillé des contenus regardés n'est pas disponible.</p>
        <div class="info-badge">📌 Dernière activité: ${lastActivityDate}</div>
      `;

    } catch (err) {
      console.error("Activity load error:", err);
      document.getElementById("activityMessage").innerHTML = `<div class="activity-error">❌ Erreur lors du chargement de l'activité</div>`;
    }
  });
</script>
