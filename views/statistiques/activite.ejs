<h1 class="dashboard-title">🎬 Activité</h1>

<div class="activity-container">
  <div id="activityList" class="activity-list">
    Chargement de l'activité...
  </div>
</div>

<style>
  .activity-container {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .activity-list {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .activity-item {
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    padding: 16px;
    border-radius: 8px;
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    transition: background 0.3s ease;
  }

  .activity-item:hover {
    background: rgba(255, 255, 255, 0.08);
    border-color: rgba(255, 255, 255, 0.2);
  }

  .activity-content {
    flex: 1;
  }

  .activity-type {
    display: inline-block;
    padding: 4px 12px;
    background: rgba(102, 126, 234, 0.3);
    color: #667eea;
    border-radius: 20px;
    font-size: 12px;
    font-weight: 600;
    margin-bottom: 8px;
  }

  .activity-title {
    font-size: 16px;
    font-weight: 500;
    margin-bottom: 6px;
    color: white;
  }

  .activity-description {
    font-size: 13px;
    color: #aaa;
    margin-bottom: 8px;
  }

  .activity-meta {
    font-size: 12px;
    color: #888;
  }

  .activity-time {
    text-align: right;
    font-size: 13px;
    color: #888;
    white-space: nowrap;
    margin-left: 16px;
  }

  .activity-empty {
    text-align: center;
    padding: 40px 20px;
    color: #888;
  }

  .activity-empty p {
    font-size: 14px;
  }

  .activity-error {
    background: rgba(239, 68, 68, 0.1);
    border: 1px solid rgba(239, 68, 68, 0.3);
    padding: 20px;
    border-radius: 8px;
    color: #fca5a5;
    text-align: center;
  }
</style>

<script>
  document.addEventListener("DOMContentLoaded", async () => {
    const basePath = window.APP_BASE_PATH || "";

    function formatRelativeTime(dateString) {
      const date = new Date(dateString);
      const now = new Date();
      const diffMs = now - date;
      const diffSec = Math.floor(diffMs / 1000);
      const diffMin = Math.floor(diffSec / 60);
      const diffHour = Math.floor(diffMin / 60);
      const diffDay = Math.floor(diffHour / 24);
      const diffWeek = Math.floor(diffDay / 7);
      const diffMonth = Math.floor(diffDay / 30);
      const diffYear = Math.floor(diffDay / 365);

      if (diffYear > 0) return `il y a ${diffYear} an${diffYear > 1 ? 's' : ''}`;
      if (diffMonth > 0) return `il y a ${diffMonth} mois`;
      if (diffWeek > 0) return `il y a ${diffWeek} semaine${diffWeek > 1 ? 's' : ''}`;
      if (diffDay > 0) return `il y a ${diffDay} jour${diffDay > 1 ? 's' : ''}`;
      if (diffHour > 0) return `il y a ${diffHour}h`;
      if (diffMin > 0) return `il y a ${diffMin}min`;
      return 'À l\'instant';
    }

    function formatFullDate(dateString) {
      const date = new Date(dateString);
      return date.toLocaleDateString('fr-FR', {
        year: 'numeric',
        month: 'long',
        day: 'numeric',
        hour: '2-digit',
        minute: '2-digit'
      });
    }

    try {
      const res = await fetch(basePath + "/api/activity");
      if (!res.ok) throw new Error(`API error: ${res.status}`);
      const data = await res.json();

      const listDiv = document.getElementById("activityList");

      if (!data || !data.activities || data.activities.length === 0) {
        listDiv.innerHTML = `<div class="activity-empty"><p>Aucune activité enregistrée</p></div>`;
        return;
      }

      listDiv.innerHTML = data.activities.map(activity => {
        const typeEmoji = activity.type === 'WATCHED' ? '👀' : 
                          activity.type === 'ADDED' ? '➕' : 
                          activity.type === 'UPDATED' ? '🔄' : '📌';
        
        const typeLabel = activity.type === 'WATCHED' ? 'Regardé' :
                          activity.type === 'ADDED' ? 'Ajouté' :
                          activity.type === 'UPDATED' ? 'Mis à jour' : activity.type;

        return `
          <div class="activity-item">
            <div class="activity-content">
              <span class="activity-type">${typeEmoji} ${typeLabel}</span>
              <div class="activity-title">${activity.title || 'Activité sans titre'}</div>
              ${activity.description ? `<div class="activity-description">${activity.description}</div>` : ''}
              <div class="activity-meta">
                ${activity.mediaType ? `<span>📺 ${activity.mediaType}</span>` : ''}
              </div>
            </div>
            <div class="activity-time">
              <div>${formatRelativeTime(activity.date || activity.createdAt)}</div>
              <div style="font-size: 11px; margin-top: 4px;">${formatFullDate(activity.date || activity.createdAt)}</div>
            </div>
          </div>
        `;
      }).join('');

    } catch (err) {
      console.error("Activity load error:", err);
      document.getElementById("activityList").innerHTML = `<div class="activity-error">❌ Erreur lors du chargement de l'activité</div>`;
    }
  });
</script>
