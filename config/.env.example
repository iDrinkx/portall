# ============================================
# PLEX PORTAL - Docker env file
# Copy this file to config/.env then edit values.
# ============================================

# Required in production: generate with `openssl rand -hex 32`
SESSION_SECRET=change-me-to-a-secure-key

# Set true behind HTTPS reverse proxy
COOKIE_SECURE=true

# Optional app overrides
NODE_ENV=production
# APP_URL=https://example.com
# BASE_PATH=/plex-portal
# PORT=3000
# DEBUG=true

# Optional integrations
# WIZARR_URL=http://wizarr.local
# WIZARR_API_KEY=your-wizarr-api-key

# Tautulli direct DB (recommended if mounted in docker-compose)
TAUTULLI_DB_PATH=/tautulli-data/tautulli.db
# TAUTULLI_URL=http://tautulli.local:8181
# TAUTULLI_API_KEY=your-tautulli-api-key

# Seerr / Overseerr
# SEERR_URL=http://overseerr:5055
# SEERR_PUBLIC_URL=https://seerr.example.com
# SEERR_API_KEY=your-seerr-api-key

# Komga (preconfig auto-auth cards)
# KOMGA_URL=http://komga:25600
# KOMGA_PUBLIC_URL=https://komga.example.com
# KOMGA_API_KEY=your-komga-api-key

# Jellyfin (preconfig iframe cards)
# JELLYFIN_PUBLIC_URL=https://jellyfin.example.com

# Plex whitelist security
# PLEX_URL=http://plex:32400
# PLEX_TOKEN=your-plex-token

# Calendar (Radarr/Sonarr)
# RADARR_URL=http://radarr:7878
# RADARR_API_KEY=your-radarr-api-key
# SONARR_URL=http://sonarr:8989
# SONARR_API_KEY=your-sonarr-api-key
