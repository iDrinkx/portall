# ============================================
# PLEX PORTAL - Configuration d'environnement
# ============================================
#
# L'application détecte AUTOMATIQUEMENT la configuration
# via les headers du reverse proxy (X-Forwarded-*)
#
# Dans la plupart des cas, vous n'avez besoin de rien configurer!

# ============================================
# 🔓 SÉCURITÉ & SESSION (OBLIGATOIRE)
# ============================================

# Clé secrète pour les sessions
# ⚠️ CHANGEZ CETTE VALEUR EN PRODUCTION!
# Générez une clé sécurisée: openssl rand -hex 32
SESSION_SECRET=change-me-to-a-secure-key

# ============================================
# 🌐 URL PUBLIQUE (OPTIONNEL)
# ============================================
#
# L'app détecte automatiquement l'URL via les headers du reverse proxy
# Vous n'avez besoin de le configurer que si:
#  - Vous êtes en local ET accédez via une URL personnalisée
#  - Vous voulez override le comportement auto-détecté
#
# Exemples:
#   APP_URL=http://localhost:3000
#   APP_URL=http://192.168.10.104:3000
#   APP_URL=https://example.com
#   APP_URL=https://example.com/plex-portal
#
# APP_URL=

# ============================================
# 🔀 REVERSE PROXY (OPTIONNEL)
# ============================================
#
# L'app détecte automatiquement le BASE_PATH via X-Forwarded-Prefix
# Vous n'avez besoin de le configurer que si:
#  - Vous voulez override le comportement auto-détecté
#  - Votre reverse proxy n'envoie pas X-Forwarded-Prefix
#
# Exemples:
#   BASE_PATH=          (vide pour local)
#   BASE_PATH=/plex-portal
#
# BASE_PATH=

# PORT (optionnel)
# PORT=3000

# DEBUG (optionnel)
# Affiche les logs de détection du reverse proxy
# DEBUG=true

# ============================================
# 🔐 PLEX SERVER (OPTIONNEL mais RECOMMANDÉ)
# ============================================
#
# Pour la sécurité, il est TRÈS RECOMMANDÉ de:
# - Restreindre l'accès aux utilisateurs du serveur Plex uniquement
# - Récupérer la date "Membre depuis" depuis Plex (plus fiable)
#
# Comment obtenir PLEX_TOKEN:
#   1. Allez sur https://app.plex.tv/web/app
#   2. Ouvrez la Console (F12)
#   3. Allez dans Storage > Local Storage > app.plex.tv
#   4. Cherchez la clé "myPlexAccessToken"
#
# PLEX_URL=http://192.168.x.x:32400
# PLEX_TOKEN=your-plex-token-here

# ============================================
# 📚 WIZARR (optionnel)
# ============================================

# WIZARR_URL=http://wizarr.local
# WIZARR_API_KEY=your-api-key

# ============================================
# 📊 TAUTULLI (pour les stats de visionnage)
# ============================================

# TAUTULLI_URL=http://tautulli.local
# TAUTULLI_API_KEY=your-api-key

# ============================================
# 🎬 OVERSEERR (optionnel)
# ============================================

# OVERSEERR_URL=http://overseerr.local
# OVERSEERR_API_KEY=your-api-key

# ============================================
# 📚 KOMGA (optionnel - pour cartes preconfig auto-auth)
# ============================================
#
# KOMGA_URL        : URL interne (API, ex: http://komga:25600)
# KOMGA_PUBLIC_URL : URL publique utilisée en iframe
# KOMGA_API_KEY    : clé API Komga (mode recommandé)
#
# KOMGA_URL=http://komga:25600
# KOMGA_PUBLIC_URL=https://komga.example.com
# KOMGA_API_KEY=your-komga-api-key
#
# Fallback possible (si nécessaire) :
# KOMGA_USERNAME=admin
# KOMGA_PASSWORD=change-me

# ============================================
# 🍿 JELLYFIN (optionnel - pour cartes preconfig iframe)
# ============================================
#
# JELLYFIN_PUBLIC_URL=https://jellyfin.example.com

# ============================================
# 📅 RADARR & SONARR (pour le calendrier)
# ============================================
#
# Affiche un calendrier des sorties films/séries à venir
# Basé sur les données Radarr et Sonarr
#
# Comment obtenir les clés API:
#   Radarr: Settings > General > API Key
#   Sonarr: Settings > General > API Key
#

# RADARR_URL=http://radarr:7878
# RADARR_API_KEY=your-radarr-api-key

# SONARR_URL=http://sonarr:8989
# SONARR_API_KEY=your-sonarr-api-key
